            <%
              const requestAppIds = Array.from(new Set(
                dashboardModules
                  .filter((entry) => ['pulsarr', 'seerr'].includes(entry.app.id) && ['recent-requests', 'most-watchlisted'].includes(entry.element.id))
                  .map((entry) => entry.app.id)
