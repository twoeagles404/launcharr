  <% if (dashboardModules.some((item) => isArrAppId(item.app.id) && (item.element.id === 'downloading-soon' || item.element.id === 'recently-downloaded' || item.element.id === 'activity-queue' || item.element.id === 'calendar'))) { %>
    <%
