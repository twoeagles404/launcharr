<%- include('partials/head', { pageTitle: 'Launcharr · Dashboard', extraCss: ['/styles-layout.css', '/styles-overview.css', '/table-cards-overrides.css'] }) %>
<body class="dash-body">
  <%
    const multiInstanceBaseIdsList = (Array.isArray(multiInstanceBaseIds) ? multiInstanceBaseIds : [])
      .map((item) => String(item || '').trim().toLowerCase())
      .filter(Boolean);
    const hasDashboardContent = Boolean(
      Array.isArray(dashboardModules) && dashboardModules.length
    );
    const dashboardNavEntries = (Array.isArray(dashboardDefinitions) ? dashboardDefinitions : [])
      .map((entry) => ({
        id: String(entry?.id || '').trim() || 'main',
        name: String(entry?.name || '').trim() || 'Dashboard',
        icon: String(entry?.icon || '/icons/dashboard.svg').trim() || '/icons/dashboard.svg',
      }))
      .filter((entry, index, list) => entry.id && list.findIndex((candidate) => candidate.id === entry.id) === index);
    const activeDashboardEntry = (() => {
      const requestedId = String(activeDashboard?.id || 'main').trim() || 'main';
      return dashboardNavEntries.find((entry) => entry.id === requestedId)
        || dashboardNavEntries[0]
        || { id: 'main', name: 'Dashboard', icon: '/icons/dashboard.svg' };
    })();
    const mainDashboardNavEntry = dashboardNavEntries.find((entry) => entry.id === 'main')
      || { id: 'main', name: 'Dashboard', icon: '/icons/dashboard.svg' };
    const primaryDashboardNavEntry = mainDashboardNavEntry?.id && dashboardNavEntries.some((entry) => entry.id === mainDashboardNavEntry.id)
      ? mainDashboardNavEntry
      : (dashboardNavEntries[0] || { id: 'main', name: 'Dashboard', icon: '/icons/dashboard.svg' });
    const secondaryDashboardNavEntries = dashboardNavEntries.filter((entry) => entry.id !== primaryDashboardNavEntry.id);
    const resolveAppBaseId = (value) => {
      const id = String(value || '').trim().toLowerCase();
      if (!id) return '';
      const matched = multiInstanceBaseIdsList
        .slice()
        .sort((a, b) => b.length - a.length)
        .find((baseId) => {
          if (id === baseId) return true;
          if (!id.startsWith(baseId + '-')) return false;
          return /^\d+$/.test(id.slice(baseId.length + 1));
        });
      return matched || id;
    };
    const isArrAppId = (value) => ['sonarr', 'radarr', 'lidarr', 'readarr'].includes(resolveAppBaseId(value));
    const hasBaseId = (ids, baseId) => Array.isArray(ids) && ids.some((id) => resolveAppBaseId(id) === baseId);
    const resolveAppIconPath = (appItem) => {
      const customIcon = String(appItem?.icon || '').trim();
      if (customIcon) return customIcon;
      const baseId = resolveAppBaseId(appItem?.id);
      if (['plex', 'tautulli', 'radarr', 'sonarr', 'lidarr', 'readarr', 'pulsarr', 'seerr', 'prowlarr', 'cleanuparr', 'huntarr', 'transmission', 'qbittorrent', 'sabnzbd', 'jellyfin', 'emby', 'bazarr'].includes(baseId)) {
        return `/icons/${baseId}.png`;
      }
      return `/icons/${baseId || 'app'}.svg`;
    };
  %>
  <div class="dash-frame">
    <aside class="dash-sidebar">
      <div class="dash-brand">
        <span class="dash-logo">
          <img class="nav-icon app-icon" src="/icons/launcharr-icon.png" alt="Launcharr" />
        </span>
        <div>
          <div class="dash-title">Launcharr</div>
        </div>
      </div>

      <div class="dash-nav">
        <% if (dashboardNavEntries.length) { %>
          <a class="nav-item<%= activeDashboardEntry.id === primaryDashboardNavEntry.id ? ' active' : '' %>" href="/dashboard?dashboard=<%= encodeURIComponent(primaryDashboardNavEntry.id || 'main') %>">
            <img class="nav-icon" src="<%= primaryDashboardNavEntry.icon || '/icons/dashboard.svg' %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
            <span class="nav-label"><%= primaryDashboardNavEntry.name || 'Dashboard' %></span>
          </a>
          <% if (secondaryDashboardNavEntries.length) { %>
            <% secondaryDashboardNavEntries.forEach((dashboardLink) => { %>
              <a class="nav-item nav-item--dashboard-child<%= activeDashboardEntry.id === dashboardLink.id ? ' active' : '' %>" href="/dashboard?dashboard=<%= encodeURIComponent(dashboardLink.id) %>">
                <img class="nav-icon" src="<%= dashboardLink.icon || '/icons/dashboard.svg' %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
                <span class="nav-label"><%= dashboardLink.name %></span>
              </a>
            <% }) %>
          <% } %>
        <% } %>
        <%- include('partials/nav-categories', { navDashHasEntries: dashboardNavEntries.length > 0, navActiveAppId: null, navActivePage: null }) %>
      </div>

      <%- include('partials/user-menu') %>
    </aside>

    <section class="dash-main">
      <div class="main-window-bar">
        <button class="sidebar-toggle main-toggle left-toggle" type="button" aria-label="Toggle sidebar">
          <img class="toggle-icon" src="/icons/sidebar-toggle.svg" alt="" />
        </button>
        <div class="main-window-title">
          <img class="main-window-icon" src="<%= activeDashboardEntry.icon || '/icons/dashboard.svg' %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
          <span class="main-window-app">Launcharr</span>
          <span class="main-window-rest">| <%= activeDashboardEntry.name || 'Dashboard' %></span>
        </div>
        <div class="main-window-spacer"></div>
        <div class="main-window-status">
          <span class="status-dot"></span>
        </div>
      </div>

      <% if (hasDashboardContent) { %>
        <%
          const hasPlexActive = dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'plex' && item.element.id === 'active' && !item.mediaCombined);
          const hasPlexRecent = dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'plex' && item.element.id === 'recent' && !item.mediaCombined);
          const hasPlexWatchlisted = dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'plex' && item.element.id === 'watchlisted');
          const hasTautulliStats = dashboardModules.some((item) => item.app.id === 'tautulli' && item.element.id === 'watch-stats');
          const hasMediaCombinedModules = dashboardModules.some((item) => item.mediaCombined && ['active', 'recent'].includes(item.element.id));
          const hasRequestModules = dashboardModules.some((item) => ['pulsarr', 'seerr'].includes(item.app.id) && (item.element.id === 'recent-requests' || item.element.id === 'most-watchlisted'));
        %>
        <div class="plex-overview">
          <% dashboardModules.forEach((item) => { %>
            <% if (item.widgetBar) { %>
              <section class="dashboard-widget-bar"
                data-widget-bar-id="<%= item.widgetBar.id %>"
                data-refresh-seconds="<%= item.widgetBar.refreshSeconds ?? 60 %>">
                <div class="plex-topbar dashboard-widget-bar-topbar">
                  <div class="plex-title-wrap">
                    <div class="plex-title">
                      <img class="plex-logo" src="<%= item.widgetBar.icon || '/icons/dashboard.svg' %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
                      <span class="plex-titletext"><%= item.widgetBar.name || 'Widget Bar' %></span>
                    </div>
                  </div>
                  <div class="dashboard-widget-bar-topbar-actions">
                    <button class="plex-iconbtn" type="button" data-widget-bar-scroll-prev aria-label="Previous" title="Previous">
                      <div class="plex-chev plex-left"></div>
                    </button>
                    <button class="plex-iconbtn" type="button" data-widget-bar-scroll-next aria-label="Next" title="Next">
                      <div class="plex-chev plex-right"></div>
                    </button>
                    <button class="plex-iconbtn" type="button" data-widget-bar-collapse-toggle aria-expanded="true" aria-label="Collapse" title="Collapse">
                      <div class="plex-doublechev">
                        <div class="plex-chev plex-up"></div>
                        <div class="plex-chev plex-down"></div>
                      </div>
                    </button>
                  </div>
                </div>
                <div class="plex-panel dashboard-widget-bar-panel">
                  <% (item.widgetBar.rows || []).forEach(function(row) {
                    const rowSettings = row.settings || {};
                    const rowClasses = ['dashboard-widget-bar-row',
                      rowSettings.fixedWidth ? 'row--fixed-width' : '',
                      rowSettings.scroll ? 'row--scroll' : '',
                      rowSettings.fill ? 'row--fill' : '',
                    ].filter(Boolean).join(' ');
                    const maxCols = rowSettings.maxCols > 0 ? rowSettings.maxCols : 0;
                  %>
                    <div class="<%= rowClasses %>" data-row-id="<%= row.id %>"<% if (maxCols > 0) { %> style="--row-max-cols: <%= maxCols %>"<% } %>>
                      <% (row.widgets || []).forEach(function(widget) { %>
                        <%
                          const dashboardWidgetApp = apps.find(function(appEntry) { return String(appEntry?.id || '') === String(widget.appId || ''); }) || null;
                          const dashboardWidgetLaunchMode = String(dashboardWidgetApp?.effectiveLaunchMode || '').trim().toLowerCase() || 'disabled';
                          const dashboardWidgetLaunchEnabled = dashboardWidgetLaunchMode !== 'disabled';
                          const dashboardWidgetLaunchHref = dashboardWidgetLaunchEnabled ? ('/apps/' + encodeURIComponent(String(widget.appId || '')) + '/launch') : '';
                          const dashboardWidgetSelectedMetricKeys = Array.isArray(widget.selectedMetricKeys)
                            ? widget.selectedMetricKeys.map(function(k) { return String(k || '').trim().toLowerCase(); }).filter(Boolean)
                            : null;
                          const dashboardWidgetMetricColumns = Number.isFinite(Number(widget.metricColumns)) ? Math.max(1, Math.min(4, Math.round(Number(widget.metricColumns)))) : null;
                          const dashboardWidgetLibraryKeys = (widget.selectedLibraryKeys && typeof widget.selectedLibraryKeys === 'object' && !Array.isArray(widget.selectedLibraryKeys) && Object.keys(widget.selectedLibraryKeys).length) ? widget.selectedLibraryKeys : null;
                        %>
                        <% if (widget.systemType === 'sys-resources') { %>
                          <div class="dashboard-system-bar"
                            data-system-type="sys-resources"
                            data-widget-id="<%= widget.id %>"
                            data-system-config="<%= JSON.stringify(widget.systemConfig || {}) %>">
                          </div>
                        <% } else if (widget.systemType === 'links') { %>
                          <div class="dashboard-links-widget"
                            data-system-type="links"
                            data-widget-id="<%= widget.id %>"
                            data-system-config="<%= JSON.stringify(widget.systemConfig || {}) %>">
                          </div>
                        <% } else if (widget.systemType === 'deployment-summary') { %>
                          <div class="dashboard-stat-card deployment-summary-stat-card is-loading"
                            data-system-type="deployment-summary"
                            data-widget-id="<%= widget.id %>"
                            data-widget-metric-cols="3"
                            data-system-config="<%= JSON.stringify(widget.systemConfig || {}) %>">
                            <div class="stat-card-header">
                              <img class="stat-card-icon" src="/icons/launcharr-icon.png" alt="" onerror="this.src='/icons/app.svg'" />
                              <span class="stat-card-name">Launcharr</span>
                              <span class="stat-card-status is-unknown">Unknown</span>
                            </div>
                            <div class="stat-card-metrics">
                              <span class="stat-card-metric" data-deployment-stat="online"><span class="stat-card-metric-value">0</span><span class="stat-card-metric-label">Online</span></span>
                              <span class="stat-card-metric" data-deployment-stat="offline"><span class="stat-card-metric-value">0</span><span class="stat-card-metric-label">Offline</span></span>
                              <span class="stat-card-metric" data-deployment-stat="total"><span class="stat-card-metric-value">0</span><span class="stat-card-metric-label">Total</span></span>
                            </div>
                          </div>
                        <% } else if (!widget.systemType) { %>
                        <div class="dashboard-stat-card is-loading"
                          data-app-id="<%= widget.appId %>"
                          data-widget-id="<%= widget.id %>"
                          data-launch-mode="<%= dashboardWidgetLaunchMode %>"
                          <% if (dashboardWidgetLaunchHref) { %>data-launch-href="<%= dashboardWidgetLaunchHref %>" <% } %>
                          <% if (dashboardWidgetLaunchEnabled) { %>tabindex="0" role="link" aria-label="Open <%= widget.typeName || widget.appId %>" <% } %>
                          <% if (dashboardWidgetMetricColumns) { %>data-widget-metric-cols="<%= dashboardWidgetMetricColumns %>" <% } %>
                          <% if (widget.typeId) { %>data-widget-type-id="<%= widget.typeId %>" <% } %>
                          <% if (dashboardWidgetSelectedMetricKeys !== null) { %>data-has-selected-metric-keys="1" data-selected-metric-keys="<%= dashboardWidgetSelectedMetricKeys.join(',') %>" <% } %>
                          <% if (dashboardWidgetLibraryKeys) { %>data-selected-library-keys="<%= JSON.stringify(dashboardWidgetLibraryKeys) %>" <% } %>>
                          <div class="stat-card-header">
                            <img class="stat-card-icon" src="<%= widget.icon || '/icons/app.svg' %>" alt=""
                              onerror="this.src='/icons/app.svg'" />
                            <span class="stat-card-name"><%= widget.typeName || widget.appId %></span>
                            <span class="stat-card-status">···</span>
                          </div>
                          <div class="stat-card-metrics"></div>
                        </div>
                        <% } %>
                      <% }) %>
                    </div>
                  <% }) %>
                </div>
              </section>
            <% } else if (item.mediaCombined && item.element.id === 'active') { %>
              <%
                const moduleKey = String(item.mediaCombined?.moduleKey || 'mediacombined-active').trim() || 'mediacombined-active';
                const moduleId = moduleKey;
                const controlPrefix = moduleKey.replace(/[^a-zA-Z0-9_-]+/g, '') || 'mediacombinedActive';
                const combinedSourceApps = Array.isArray(item.mediaCombined?.appIds)
                  ? item.mediaCombined.appIds
                    .map((appId) => apps.find((entry) => entry.id === appId))
                    .filter(Boolean)
                  : [];
                const defaultLogo = String(item.mediaCombined?.iconPath || '/icons/media-play.svg').trim() || '/icons/media-play.svg';
                const title = String(item.mediaCombined?.displayName || 'Active Streams').trim() || 'Active Streams';
              %>
              <section class="plex-module plex-module--no-subtitle" id="<%= moduleId %>">
                <div class="plex-topbar">
                  <div class="plex-title-wrap">
                    <div class="plex-title">
                      <img
                        class="plex-logo"
                        id="<%= controlPrefix %>Logo"
                        src="<%= defaultLogo %>"
                        data-default-icon="<%= defaultLogo %>"
                        alt="Combined media"
                        loading="eager"
                      />
                      <span><%= title %></span>
                    </div>
                    <div class="plex-subtitle"></div>
                  </div>
                  <div class="plex-spacer"></div>

                  <div class="plex-controls-right">
                    <% if (combinedSourceApps.length > 1) { %>
                      <div class="plex-select plex-icon plex-filter-media" title="Source">
                        <select id="<%= controlPrefix %>SourceFilter" aria-label="Source">
                          <option value="all" selected>All</option>
                          <% combinedSourceApps.forEach((sourceApp) => { %>
                            <option value="<%= sourceApp.id %>" data-icon="<%= sourceApp.id === 'jellyfin' ? '/icons/jellyfin.png' : (sourceApp.id === 'emby' ? '/icons/emby.png' : '/icons/plex.png') %>"><%= sourceApp.name %></option>
                          <% }) %>
                        </select>
                      </div>
                    <% } %>
                    <button class="plex-iconbtn" id="<%= controlPrefix %>PrevBtn" type="button" aria-label="Previous"><div class="plex-chev plex-left"></div></button>
                    <button class="plex-iconbtn" id="<%= controlPrefix %>NextBtn" type="button" aria-label="Next"><div class="plex-chev plex-right"></div></button>
                    <button class="plex-iconbtn plex-collapse-btn" type="button" aria-label="Collapse" data-target="<%= moduleId %>" data-collapse-global="true">
                      <div class="plex-doublechev">
                        <div class="plex-chev plex-up"></div>
                        <div class="plex-chev plex-down"></div>
                      </div>
                    </button>
                  </div>
                </div>

                <div class="plex-panel">
                  <div id="<%= controlPrefix %>Viewport" class="plex-carousel-viewport">
                    <div id="<%= controlPrefix %>Track" class="plex-carousel-track">
                      <div class="plex-empty">Loading…</div>
                    </div>
                  </div>
                </div>
              </section>
            <% } %>
            <% if (item.mediaCombined && item.element.id === 'recent') { %>
              <%
                const moduleKey = String(item.mediaCombined?.moduleKey || 'mediacombined-recent').trim() || 'mediacombined-recent';
                const moduleId = moduleKey;
                const controlPrefix = moduleKey.replace(/[^a-zA-Z0-9_-]+/g, '') || 'mediacombinedRecent';
                const combinedSourceApps = Array.isArray(item.mediaCombined?.appIds)
                  ? item.mediaCombined.appIds
                    .map((appId) => apps.find((entry) => entry.id === appId))
                    .filter(Boolean)
                  : [];
                const defaultLogo = String(item.mediaCombined?.iconPath || '/icons/media-play.svg').trim() || '/icons/media-play.svg';
                const title = String(item.mediaCombined?.displayName || 'Recently Added').trim() || 'Recently Added';
              %>
              <section class="plex-module plex-module--no-subtitle" id="<%= moduleId %>">
                <div class="plex-topbar">
                  <div class="plex-title-wrap">
                    <div class="plex-title">
                      <img
                        class="plex-logo"
                        id="<%= controlPrefix %>Logo"
                        src="<%= defaultLogo %>"
                        data-default-icon="<%= defaultLogo %>"
                        alt="Combined media"
                        loading="eager"
                      />
                      <span><%= title %></span>
                    </div>
                    <div class="plex-subtitle"></div>
                  </div>
                  <div class="plex-spacer"></div>

                  <div class="plex-controls-right">
                    <% if (combinedSourceApps.length > 1) { %>
                      <div class="plex-select plex-icon plex-filter-media" title="Source">
                        <select id="<%= controlPrefix %>SourceFilter" aria-label="Source">
                          <option value="all" selected>All</option>
                          <% combinedSourceApps.forEach((sourceApp) => { %>
                            <option value="<%= sourceApp.id %>" data-icon="<%= sourceApp.id === 'jellyfin' ? '/icons/jellyfin.png' : (sourceApp.id === 'emby' ? '/icons/emby.png' : '/icons/plex.png') %>"><%= sourceApp.name %></option>
                          <% }) %>
                        </select>
                      </div>
                    <% } %>
                    <div class="plex-select plex-icon plex-filter-media" title="Media type">
                      <select id="<%= controlPrefix %>TypeFilter" aria-label="Media type">
                        <option value="movie" selected>Movies</option>
                        <option value="show">TV</option>
                        <option value="all">All</option>
                      </select>
                    </div>
                    <div class="plex-select plex-xsmall" title="Limit">
                      <select id="<%= controlPrefix %>LimitSelect" aria-label="Limit">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                      </select>
                    </div>
                    <button class="plex-iconbtn" id="<%= controlPrefix %>PrevBtn" type="button" aria-label="Previous"><div class="plex-chev plex-left"></div></button>
                    <button class="plex-iconbtn" id="<%= controlPrefix %>NextBtn" type="button" aria-label="Next"><div class="plex-chev plex-right"></div></button>
                    <button class="plex-iconbtn plex-collapse-btn" type="button" aria-label="Collapse" data-target="<%= moduleId %>" data-collapse-global="true">
                      <div class="plex-doublechev">
                        <div class="plex-chev plex-up"></div>
                        <div class="plex-chev plex-down"></div>
                      </div>
                    </button>
                  </div>
                </div>

                <div class="plex-panel">
                  <div id="<%= controlPrefix %>Viewport" class="plex-carousel-viewport">
                    <div id="<%= controlPrefix %>Track" class="plex-carousel-track">
                      <div class="plex-empty">Loading…</div>
                    </div>
                  </div>
                </div>
              </section>
            <% } %>
            <% if (resolveAppBaseId(item.app.id) === 'plex' && item.element.id === 'active' && !item.mediaCombined) { %>
              <section class="plex-module plex-module--no-subtitle" id="plex-active">
                <div class="plex-topbar">
                  <div class="plex-title-wrap">
                    <div class="plex-title">
                      <img class="plex-logo" src="/icons/plex.png" alt="Plex" loading="eager" />
                      <span>Active Streams</span>
                    </div>
                    <div class="plex-subtitle"></div>
                  </div>
                  <div class="plex-spacer"></div>

                  <div class="plex-controls-right">
                    <button class="plex-iconbtn" id="plexActivePrevBtn" type="button" aria-label="Previous"><div class="plex-chev plex-left"></div></button>
                    <button class="plex-iconbtn" id="plexActiveNextBtn" type="button" aria-label="Next"><div class="plex-chev plex-right"></div></button>
                    <button class="plex-iconbtn plex-collapse-btn" type="button" aria-label="Collapse" data-target="plex-active">
                      <div class="plex-doublechev">
                        <div class="plex-chev plex-up"></div>
                        <div class="plex-chev plex-down"></div>
                      </div>
                    </button>
                  </div>
                </div>

                <div class="plex-panel">
                  <div id="plexActiveViewport" class="plex-carousel-viewport">
                    <div id="plexActiveTrack" class="plex-carousel-track">
                      <div class="plex-empty">Loading…</div>
                    </div>
                  </div>
                </div>
              </section>
            <% } %>
            <% if (resolveAppBaseId(item.app.id) === 'plex' && item.element.id === 'recent' && !item.mediaCombined) { %>
              <section class="plex-module plex-module--no-subtitle" id="plex-recent">
                <div class="plex-topbar">
                  <div class="plex-title-wrap">
                    <div class="plex-title">
                      <img class="plex-logo" src="/icons/plex.png" alt="Plex" loading="eager" />
                      <span>Recently Added</span>
                    </div>
                    <div class="plex-subtitle"></div>
                  </div>

                  <div class="plex-spacer"></div>

                  <div class="plex-controls-right">
                    <div class="plex-select plex-icon plex-filter-media" id="plexRecentTypeWrap" title="Media type">
                      <select id="plexRecentTypeFilter" aria-label="Media type">
                        <option value="movie" selected>Movies</option>
                        <option value="show">TV</option>
                      </select>
                    </div>

                    <div class="plex-select plex-icon plex-filter-window" title="Window">
                      <select id="plexRecentWindowFilter" aria-label="Window">
                        <option value="today">Today</option>
                        <option value="week">Week</option>
                        <option value="month" selected>Month</option>
                      </select>
                    </div>

                    <button class="plex-iconbtn" id="plexRecentPrevBtn" type="button" aria-label="Previous"><div class="plex-chev plex-left"></div></button>
                    <button class="plex-iconbtn" id="plexRecentNextBtn" type="button" aria-label="Next"><div class="plex-chev plex-right"></div></button>
                    <button class="plex-iconbtn plex-collapse-btn" type="button" aria-label="Collapse" data-target="plex-recent">
                      <div class="plex-doublechev">
                        <div class="plex-chev plex-up"></div>
                        <div class="plex-chev plex-down"></div>
                      </div>
                    </button>
                  </div>
                </div>

                <div class="plex-panel">
                  <div id="plexRecentViewport" class="plex-carousel-viewport">
                    <div id="plexRecentTrack" class="plex-carousel-track">
                      <div class="plex-empty">Loading…</div>
                    </div>
                  </div>
                </div>
              </section>
            <% } %>
            <% if (resolveAppBaseId(item.app.id) === 'plex' && item.element.id === 'watchlisted') { %>
              <section class="plex-module plex-module--no-subtitle" id="plex-watchlisted">
                <div class="plex-topbar">
                  <div class="plex-title-wrap">
                    <div class="plex-title">
                      <img class="plex-logo" src="/icons/plex.png" alt="Plex" loading="eager" />
                      <span>Most Watchlisted This Week</span>
                    </div>
                    <div class="plex-subtitle"></div>
                  </div>

                  <div class="plex-spacer"></div>

                  <div class="plex-controls-right">
                    <div class="plex-select plex-icon plex-filter-media" id="plexWatchlistedTypeWrap" title="Media type">
                      <select id="plexWatchlistedTypeFilter" aria-label="Media type">
                        <option value="all" selected>All</option>
                        <option value="movie">Movies</option>
                        <option value="show">TV</option>
                      </select>
                    </div>

                    <button class="plex-iconbtn" id="plexWatchlistedPrevBtn" type="button" aria-label="Previous"><div class="plex-chev plex-left"></div></button>
                    <button class="plex-iconbtn" id="plexWatchlistedNextBtn" type="button" aria-label="Next"><div class="plex-chev plex-right"></div></button>
                    <button class="plex-iconbtn plex-collapse-btn" type="button" aria-label="Collapse" data-target="plex-watchlisted">
                      <div class="plex-doublechev">
                        <div class="plex-chev plex-up"></div>
                        <div class="plex-chev plex-down"></div>
                      </div>
                    </button>
                  </div>
                </div>

                <div class="plex-panel">
                  <div id="plexWatchlistedViewport" class="plex-carousel-viewport">
                    <div id="plexWatchlistedTrack" class="plex-carousel-track">
                      <div class="plex-empty">Loading…</div>
                    </div>
                  </div>
                </div>
              </section>
            <% } %>
