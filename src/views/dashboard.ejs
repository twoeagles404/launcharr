          domPrefix: requestApp.id,
          appName: requestApp.name,
          baseUrl: (appBaseUrls && appBaseUrls[requestApp.id]) || requestApp.localUrl || requestApp.remoteUrl || requestApp.url || '',
          apiKey: requestApp.apiKey || '',
          displaySettings: dashboardModules
            .filter((item) => item.app.id === requestApp.id)
            .reduce((acc, item) => {
              if (!item?.element?.id) return acc;
              acc[item.element.id] = {
                showSubtitle: item.element.showSubtitle !== false,
                showMeta: item.element.showMeta !== false,
                showPill: item.element.showPill !== false,
                showTypeIcon: item.element.showTypeIcon !== false,
                showViewIcon: item.element.showViewIcon !== false,
                showUsername: item.element.showUsername !== false,
              };
              return acc;
            }, {})
        }) %>;
      </script>
      <script src="/pulsarr-overview.js?v=<%= assetVersion %>"></script>
    <% }) %>
  <% } %>
  <% if (dashboardModules.some((item) => ['prowlarr', 'jackett'].includes(resolveAppBaseId(item.app.id)) && item.element.id === 'search')) { %>
    <%
      const indexerSearchApps = Array.from(new Set(
        dashboardModules
          .filter((item) => ['prowlarr', 'jackett'].includes(resolveAppBaseId(item.app.id)) && item.element.id === 'search')
          .map((item) => item.app.id)
      )).map((id) => dashboardModules.find((entry) => entry.app.id === id)?.app).filter(Boolean);
      const indexerSearchConfigs = indexerSearchApps.map((searchApp) => {
        const baseId = resolveAppBaseId(searchApp.id);
        const isJackett = baseId === 'jackett';
        return {
          appId: searchApp.id,
          appName: searchApp.name,
          prefix: isJackett ? 'jackett' : 'prowlarr',
          endpoint: isJackett ? '/api/jackett/search' : '/api/prowlarr/search',
          filtersEndpoint: isJackett ? '/api/jackett/search/filters' : '/api/prowlarr/search/filters',
          canDownload: !isJackett,
          downloadEndpoint: '/api/prowlarr/download',
        };
      });
    %>
    <% if (indexerSearchConfigs.length) { %>
      <script>
        window.INDEXER_SEARCH_CONFIGS = <%- JSON.stringify(indexerSearchConfigs) %>;
      </script>
      <script src="/indexer-search.js?v=<%= assetVersion %>"></script>
    <% } %>
  <% } %>
  <% if (dashboardModules.some((item) => item.app.id === 'romm' && ['recently-added', 'consoles'].includes(item.element.id))) { %>
    <%
      const rommOverviewConfigs = dashboardModules
        .filter((item) => item.app.id === 'romm' && ['recently-added', 'consoles'].includes(item.element.id))
        .map((item) => {
          const isRecentlyAdded = item.element.id === 'recently-added';
          return {
            appId: item.app.id,
            appName: item.app.name || 'Romm',
            sectionId: item.element.id,
            controlPrefix: `${item.app.id}${isRecentlyAdded ? 'RecentlyAdded' : 'Consoles'}`,
            endpoint: isRecentlyAdded ? '/api/romm/recently-added' : '/api/romm/consoles?limit=all',
            displaySettings: {
              showSubtitle: item.element.showSubtitle !== false,
              showMeta: item.element.showMeta !== false,
              showPill: item.element.showPill !== false,
              showTypeIcon: item.element.showTypeIcon !== false,
              showViewIcon: item.element.showViewIcon !== false,
              showUsername: item.element.showUsername !== false,
            },
          };
        });
    %>
    <% if (rommOverviewConfigs.length) { %>
      <script>
        window.ROMM_OVERVIEW_CONFIGS = <%- JSON.stringify(rommOverviewConfigs) %>;
      </script>
      <script src="/romm-overview.js?v=<%= assetVersion %>"></script>
    <% } %>
  <% } %>
  <% if (dashboardModules.some((item) => item.app.id === 'maintainerr' && ['library-media', 'rules', 'collections-media'].includes(item.element.id))) { %>
    <%
      const maintainerrOverviewConfigs = dashboardModules
        .filter((item) => item.app.id === 'maintainerr' && ['library-media', 'rules', 'collections-media'].includes(item.element.id))
        .map((item) => {
          const isLibraryMedia = item.element.id === 'library-media';
          const isRules = item.element.id === 'rules';
          return {
            appId: item.app.id,
            appName: item.app.name || 'Maintainerr',
            sectionId: item.element.id,
            controlPrefix: `${item.app.id}${isLibraryMedia ? 'LibraryMedia' : (isRules ? 'Rules' : 'CollectionsMedia')}`,
            endpoint: isLibraryMedia
              ? '/api/maintainerr/library-media?limit=all'
              : (isRules ? '/api/maintainerr/rules' : '/api/maintainerr/collections-media?limit=200'),
            displaySettings: {
              showSubtitle: item.element.showSubtitle !== false,
              showMeta: item.element.showMeta !== false,
              showPill: item.element.showPill !== false,
              showTypeIcon: item.element.showTypeIcon !== false,
              showViewIcon: item.element.showViewIcon !== false,
              showUsername: item.element.showUsername !== false,
            },
          };
        });
    %>
    <% if (maintainerrOverviewConfigs.length) { %>
      <script>
        window.MAINTAINERR_OVERVIEW_CONFIGS = <%- JSON.stringify(maintainerrOverviewConfigs) %>;
      </script>
      <script src="/maintainerr-overview.js?v=<%= assetVersion %>"></script>
    <% } %>
  <% } %>
  <% if (dashboardModules.some((item) => (item.app.id === 'bazarr' && item.element.id === 'subtitle-queue') || (item.app.id === 'autobrr' && item.element.id === 'recent-matches'))) { %>
    <%
      const queueCardConfigs = dashboardModules
        .filter((item) => (item.app.id === 'bazarr' && item.element.id === 'subtitle-queue') || (item.app.id === 'autobrr' && item.element.id === 'recent-matches'))
        .map((item) => {
          if (item.app.id === 'bazarr') {
            const controlPrefix = `${item.app.id}SubtitleQueue`;
            return {
              moduleId: `${item.app.id}-subtitle-queue`,
              bodyId: `${controlPrefix}Body`,
              typeFilterId: `${controlPrefix}TypeFilter`,
              statusFilterId: `${controlPrefix}StatusFilter`,
              endpoint: '/api/bazarr/subtitle-queue',
              appName: item.app.name || 'Bazarr',
            };
          }
          const isRecentMatches = item.element.id === 'recent-matches';
          const controlPrefix = `${item.app.id}${isRecentMatches ? 'RecentMatches' : 'DeliveryQueue'}`;
          return {
            moduleId: `${item.app.id}-${item.element.id}`,
            bodyId: `${controlPrefix}Body`,
            typeFilterId: `${controlPrefix}TypeFilter`,
            statusFilterId: `${controlPrefix}StatusFilter`,
            endpoint: `/api/autobrr/${item.element.id}`,
            appName: item.app.name || 'Autobrr',
            mode: isRecentMatches ? 'releases' : '',
          };
        });
    %>
    <% if (queueCardConfigs.length) { %>
      <script>
        window.QUEUE_CARD_CONFIGS = <%- JSON.stringify(queueCardConfigs) %>;
      </script>
      <script src="/queue-cards.js?v=<%= assetVersion %>"></script>
    <% } %>
  <% } %>
  <% if (dashboardModules.some((item) => ['prowlarr', 'jackett'].includes(item.app.id) && item.element.id === 'search')) { %>
    <script src="/indexer-table-sort.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => item.widgetBar)) { %>
    <script src="/widgets-stat-cards.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'immich' && item.element.id === 'recent')) { %>
    <%
      const immichDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'immich' && item.element.id === 'recent')?.app;
    %>
    <script>window.IMMICH_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: immichDashApp.id, appName: immichDashApp.name }) %>;</script>
    <script src="/immich-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'audiobookshelf' && item.element.id === 'recently-added')) { %>
    <%
      const absDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'audiobookshelf' && item.element.id === 'recently-added')?.app;
    %>
    <script>window.ABS_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: absDashApp.id, appName: absDashApp.name }) %>;</script>
    <script src="/audiobookshelf-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'metube' && item.element.id === 'queue')) { %>
    <%
      const metubeDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'metube' && item.element.id === 'queue')?.app;
    %>
    <script>window.METUBE_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: metubeDashApp.id, appName: metubeDashApp.name }) %>;</script>
    <script src="/metube-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'tdarr' && item.element.id === 'stats')) { %>
    <%
      const tdarrDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'tdarr' && item.element.id === 'stats')?.app;
    %>
    <script>window.TDARR_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: tdarrDashApp.id, appName: tdarrDashApp.name }) %>;</script>
    <script src="/tdarr-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'uptime-kuma' && item.element.id === 'status')) { %>
    <%
      const ukDashItem = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'uptime-kuma' && item.element.id === 'status');
      const ukDashApp = ukDashItem?.app;
      const ukDashEl = ukDashItem?.element || {};
    %>
    <script>window.UPTIME_KUMA_OVERVIEW_CONFIG = <%- JSON.stringify({
      appId: ukDashApp.id,
      appName: ukDashApp.name,
      queueVisibleRows: ukDashEl.queueVisibleRows || 10,
      queueShowDetail: ukDashEl.queueShowDetail !== false,
      queueShowTimeLeft: ukDashEl.queueShowTimeLeft !== false,
      queueShowProgress: ukDashEl.queueShowProgress !== false,
    }) %>;</script>
    <script src="/uptime-kuma-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'wizarr' && (item.element.id === 'users' || item.element.id === 'invitations'))) { %>
    <%
      const wizDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'wizarr')?.app;
    %>
    <script>window.WIZARR_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: wizDashApp.id, appName: wizDashApp.name }) %>;</script>
    <script src="/wizarr-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'guacamole' && (item.element.id === 'active-sessions' || item.element.id === 'connections'))) { %>
    <%
      const guacDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'guacamole')?.app;
    %>
    <script>window.GUACAMOLE_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: guacDashApp.id, appName: guacDashApp.name }) %>;</script>
    <script src="/guacamole-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <% if (dashboardModules.some((item) => resolveAppBaseId(item.app.id) === 'traefik' && (item.element.id === 'routers' || item.element.id === 'services'))) { %>
    <%
      const traefikDashApp = dashboardModules.find((item) => resolveAppBaseId(item.app.id) === 'traefik')?.app;
    %>
    <script>window.TRAEFIK_OVERVIEW_CONFIG = <%- JSON.stringify({ appId: traefikDashApp.id, appName: traefikDashApp.name }) %>;</script>
    <script src="/traefik-overview.js?v=<%= assetVersion %>"></script>
  <% } %>
  <script src="/table-pagination.js?v=<%= assetVersion %>"></script>
  <script src="/version-badge.js?v=<%= assetVersion %>"></script>
  <script src="/brand-menu.js?v=<%= assetVersion %>"></script>
  <script src="/starfield-3d.js"></script>
  <script src="/pwa.js?v=<%= assetVersion %>"></script>
</body>
</html>
