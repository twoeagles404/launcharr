<%
  const _navActiveAppId = locals.navActiveAppId || null;
  const _navActivePage = locals.navActivePage || null;
  const _navActiveSubpageId = String(locals.navActiveSubpageId || '').trim().toLowerCase();
  const _navDashHasEntries = Boolean(locals.navDashHasEntries);
  const _navMultiInstanceBaseIdsList = (Array.isArray(locals.multiInstanceBaseIds) ? locals.multiInstanceBaseIds : [])
    .map((item) => String(item || '').trim().toLowerCase())
    .filter(Boolean);
  const _navResolveAppBaseId = (value) => {
    const id = String(value || '').trim().toLowerCase();
    if (!id) return '';
    const matched = _navMultiInstanceBaseIdsList
      .slice()
      .sort((a, b) => b.length - a.length)
      .find((baseId) => {
        if (id === baseId) return true;
        if (!id.startsWith(baseId + '-')) return false;
        return /^\d+$/.test(id.slice(baseId.length + 1));
      });
    return matched || id;
  };
  const _navResolveAppIconPath = (appItem) => {
    const customIcon = String(appItem?.icon || '').trim();
    if (customIcon) return customIcon;
    const baseId = _navResolveAppBaseId(appItem?.id);
    if (['plex', 'tautulli', 'radarr', 'sonarr', 'lidarr', 'readarr', 'pulsarr', 'seerr', 'prowlarr', 'cleanuparr', 'huntarr', 'transmission', 'nzbget', 'qbittorrent', 'sabnzbd', 'jellyfin', 'emby', 'bazarr'].includes(baseId)) {
      return `/icons/${baseId}.png`;
    }
    return `/icons/${baseId || 'app'}.svg`;
  };
%>
<% if (navCategories && navCategories.length) { %>
  <% if (_navDashHasEntries) { %><div class="nav-divider"></div><% } %>
  <div class="nav-accordion">
    <% navCategories.forEach((category) => { %>
      <% if (category.sidebarMenu) { %>
        <% const _navCategoryOpen = _navActiveAppId ? category.apps.some((item) => item.id === _navActiveAppId && !item.navFavourite && !((item.favourite || item.favorite))) : false; %>
        <div class="nav-accordion-item nav-accordion-item--category<%= _navCategoryOpen ? ' open' : '' %>">
          <button class="nav-accordion-trigger nav-accordion-trigger--category" type="button">
            <img class="nav-icon" src="<%= category.icon || '/icons/category.svg' %>" alt="" onerror="this.src='/icons/category.svg'" />
            <span class="nav-label"><%= category.name %></span>
          </button>
          <div class="nav-accordion-panel nav-accordion-panel--category">
            <div class="nav-accordion nav-accordion--nested">
              <% category.apps.forEach((appItem) => { %>
                <% const _navAppOpen = _navActiveAppId ? (appItem.id === _navActiveAppId && (!((appItem.favourite || appItem.favorite)) || appItem.navFavourite)) : false; %>
                <% const _navSubmenuLinks = Array.isArray(appItem.submenuLinks) ? appItem.submenuLinks : []; %>
                <div class="nav-accordion-item<%= _navAppOpen ? ' open' : '' %>">
                  <button class="nav-accordion-trigger" type="button">
                    <img class="nav-icon app-icon" src="<%= _navResolveAppIconPath(appItem) %>" alt="" onerror="this.src='/icons/app.svg'" />
                    <span class="nav-label"><%= appItem.name %></span>
                  </button>
                  <div class="nav-accordion-panel">
                    <% _navSubmenuLinks.forEach((submenuItem) => { %>
                      <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'launch' && _navActiveSubpageId === submenuItem.id ? ' active' : '' %>" href="/apps/<%= appItem.id %>/launch?page=<%= encodeURIComponent(submenuItem.id) %>" data-launch-mode="<%= appItem.effectiveLaunchMode %>" <%= appItem.effectiveLaunchMode === 'new-tab' ? 'target=\"_blank\" rel=\"noreferrer\"' : '' %>>
                        <img class="nav-subicon" src="<%= submenuItem.icon || '/icons/launch.svg' %>" alt="" onerror="this.src='/icons/launch.svg'" />
                        <span><%= submenuItem.label %></span>
                      </a>
                    <% }) %>
                    <% if (appItem.menuAccess.overview && !appItem.hideDefaultOverviewLink) { %>
                      <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'overview' ? ' active' : '' %>" href="/apps/<%= appItem.id %>">
                        <img class="nav-subicon" src="/icons/overview.svg" alt="" />
                        <span>Overview</span>
                      </a>
                    <% } %>
                    <% if (appItem.menuAccess.launch && !appItem.hideDefaultLaunchLink) { %>
                      <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'launch' ? ' active' : '' %>" href="/apps/<%= appItem.id %>/launch" data-launch-mode="<%= appItem.effectiveLaunchMode %>" <%= appItem.effectiveLaunchMode === 'new-tab' ? 'target="_blank" rel="noreferrer"' : '' %>>
                        <img class="nav-subicon" src="/icons/launch.svg" alt="" />
                        <span>Launch</span>
                      </a>
                    <% } %>
                    <% if (appItem.menuAccess.settings) { %>
                      <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'settings' ? ' active' : '' %>" href="/apps/<%= appItem.id %>/settings">
                        <img class="nav-subicon" src="/icons/settings.svg" alt="" />
                        <span>App settings</span>
                      </a>
                    <% } %>
                    <% if (appItem.menuAccess.activity) { %>
                      <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'activity' ? ' active' : '' %>" href="/apps/<%= appItem.id %>/activity">
                        <img class="nav-subicon" src="/icons/activity-queue.svg" alt="" />
                        <span>Activity</span>
                      </a>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      <% } else { %>
        <% category.apps.forEach((appItem) => { %>
          <% const _navAppOpen = _navActiveAppId ? (appItem.id === _navActiveAppId && (!((appItem.favourite || appItem.favorite)) || appItem.navFavourite)) : false; %>
          <% const _navSubmenuLinks = Array.isArray(appItem.submenuLinks) ? appItem.submenuLinks : []; %>
          <div class="nav-accordion-item<%= _navAppOpen ? ' open' : '' %>">
            <button class="nav-accordion-trigger" type="button">
              <img class="nav-icon app-icon" src="<%= _navResolveAppIconPath(appItem) %>" alt="" onerror="this.src='/icons/app.svg'" />
              <span class="nav-label"><%= appItem.name %></span>
            </button>
            <div class="nav-accordion-panel">
              <% _navSubmenuLinks.forEach((submenuItem) => { %>
                <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'launch' && _navActiveSubpageId === submenuItem.id ? ' active' : '' %>" href="/apps/<%= appItem.id %>/launch?page=<%= encodeURIComponent(submenuItem.id) %>" data-launch-mode="<%= appItem.effectiveLaunchMode %>" <%= appItem.effectiveLaunchMode === 'new-tab' ? 'target=\"_blank\" rel=\"noreferrer\"' : '' %>>
                  <img class="nav-subicon" src="<%= submenuItem.icon || '/icons/launch.svg' %>" alt="" onerror="this.src='/icons/launch.svg'" />
                  <span><%= submenuItem.label %></span>
                </a>
              <% }) %>
              <% if (appItem.menuAccess.overview && !appItem.hideDefaultOverviewLink) { %>
                <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'overview' ? ' active' : '' %>" href="/apps/<%= appItem.id %>">
                  <img class="nav-subicon" src="/icons/overview.svg" alt="" />
                  <span>Overview</span>
                </a>
              <% } %>
              <% if (appItem.menuAccess.launch && !appItem.hideDefaultLaunchLink) { %>
                <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'launch' ? ' active' : '' %>" href="/apps/<%= appItem.id %>/launch" data-launch-mode="<%= appItem.effectiveLaunchMode %>" <%= appItem.effectiveLaunchMode === 'new-tab' ? 'target="_blank" rel="noreferrer"' : '' %>>
                  <img class="nav-subicon" src="/icons/launch.svg" alt="" />
                  <span>Launch</span>
                </a>
              <% } %>
              <% if (appItem.menuAccess.settings) { %>
                <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'settings' ? ' active' : '' %>" href="/apps/<%= appItem.id %>/settings">
                  <img class="nav-subicon" src="/icons/settings.svg" alt="" />
                  <span>App settings</span>
                </a>
              <% } %>
              <% if (appItem.menuAccess.activity) { %>
                <a class="nav-subitem<%= _navActiveAppId && appItem.id === _navActiveAppId && _navActivePage === 'activity' ? ' active' : '' %>" href="/apps/<%= appItem.id %>/activity">
                  <img class="nav-subicon" src="/icons/activity-queue.svg" alt="" />
                  <span>Activity</span>
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    <% }) %>
  </div>
<% } %>
