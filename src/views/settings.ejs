      const fallbackLatest = normalizeVersionTag(settingsAboutLatest?.textContent || '');
      if (fallbackLatest && settingsAboutLatest) settingsAboutLatest.textContent = fallbackLatest;
      if (fallbackCurrent && settingsAboutVersion) settingsAboutVersion.textContent = fallbackCurrent;
      if (fallbackCurrent && fallbackLatest && fallbackCurrent === fallbackLatest) {
        setVersionState('Up to Date', 'ok');
      } else if (fallbackLatest) {
        setVersionState('Update Available', 'warn');
      } else {
        setVersionState('Unknown');
      }

      fetch('/api/version')
        .then((response) => (response.ok ? response.json() : null))
        .then((payload) => {
          if (!payload) return;
          const current = normalizeVersionTag(payload.current || fallbackCurrent);
          const latest = normalizeVersionTag(payload.latest || fallbackLatest);
          if (settingsAboutVersion && current) settingsAboutVersion.textContent = current;
          if (settingsAboutLatest && latest) settingsAboutLatest.textContent = latest;
          if (current && latest && current === latest) {
            setVersionState('Up to Date', 'ok');
          } else if (current && latest && current !== latest) {
            setVersionState('Update Available', 'warn');
          } else {
            setVersionState('Version Info', '');
          }
        })
        .catch(() => {
          setVersionState('Version Info', '');
        });
