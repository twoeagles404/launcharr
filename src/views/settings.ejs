      const plexButtons = Array.from(document.querySelectorAll('[data-plex-action]'));
      if (!plexButtons.length) return;

      const runPlexAction = async (button) => {
        const action = String(button?.dataset?.plexAction || '').trim().toLowerCase();
        if (action !== 'token' && action !== 'machine') return;
        const form = button.closest('form');
        if (!form) return;
        const targetInput = form.querySelector(`[data-plex-field="${action}"]`);
        if (!targetInput) return;

        try {
          button.disabled = true;
          const endpoint = action === 'token' ? '/api/plex/token' : '/api/plex/machine';
          const response = await fetch(endpoint);
          const data = await response.json().catch(() => ({}));
          if (action === 'token') {
            if (!response.ok || data?.error) throw new Error(data?.error || 'Failed to fetch Plex token.');
            const nextToken = String(data.token || '').trim();
            if (nextToken.split('.').length >= 3) {
              throw new Error('Resolved token looks like a Plex auth JWT. Please set Plex Machine/URL and try again.');
            }
            targetInput.value = nextToken;
          } else {
            if (!response.ok) throw new Error(data?.error || 'Failed to fetch Plex machine.');
            targetInput.value = data.machineId || '';
          }
        } catch (err) {
          console.error(`[Launcharr] Plex ${action} fetch failed`, err);
        } finally {
          button.disabled = false;
        }
