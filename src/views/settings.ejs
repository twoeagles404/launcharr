<%- include('partials/head', { pageTitle: 'Launcharr - Settings', extraCss: ['/styles-layout.css', '/styles-settings.css', '/styles-overview.css'] }) %>
<body class="dash-body">
  <div class="dash-frame">
    <aside class="dash-sidebar">
      <div class="dash-brand">
        <span class="dash-logo">
          <img class="nav-icon app-icon" src="/icons/launcharr-icon.png" alt="Launcharr" />
        </span>
        <div>
          <div class="dash-title">Launcharr</div>
        </div>
      </div>

      <div class="dash-nav">
        <%
          const settingsSidebarDashboards = Array.isArray(sidebarDashboardDefinitions)
            ? sidebarDashboardDefinitions
            : dashboardDefinitions;
          const settingsDashboardNavEntries = (Array.isArray(settingsSidebarDashboards) ? settingsSidebarDashboards : [])
            .map((entry) => ({
              id: String(entry?.id || '').trim() || 'main',
              name: String(entry?.name || '').trim() || 'Dashboard',
              icon: String(entry?.icon || '/icons/dashboard.svg').trim() || '/icons/dashboard.svg',
            }))
            .filter((entry, index, list) => entry.id && list.findIndex((candidate) => candidate.id === entry.id) === index);
          const activeSettingsDashboardNavId = String((sidebarActiveDashboard || activeDashboard)?.id || 'main').trim() || 'main';
          const mainSettingsDashboardNavEntry = settingsDashboardNavEntries.find((entry) => entry.id === 'main')
            || { id: 'main', name: 'Dashboard', icon: '/icons/dashboard.svg' };
          const primarySettingsDashboardNavEntry = mainSettingsDashboardNavEntry?.id && settingsDashboardNavEntries.some((entry) => entry.id === mainSettingsDashboardNavEntry.id)
            ? mainSettingsDashboardNavEntry
            : (settingsDashboardNavEntries[0] || { id: 'main', name: 'Dashboard', icon: '/icons/dashboard.svg' });
          const secondarySettingsDashboardNavEntries = settingsDashboardNavEntries.filter((entry) => entry.id !== primarySettingsDashboardNavEntry.id);
        %>
        <% if (settingsDashboardNavEntries.length) { %>
          <a class="nav-item<%= activeSettingsDashboardNavId === primarySettingsDashboardNavEntry.id ? ' active' : '' %>" href="/dashboard?dashboard=<%= encodeURIComponent(primarySettingsDashboardNavEntry.id || 'main') %>">
            <img class="nav-icon" src="<%= primarySettingsDashboardNavEntry.icon || '/icons/dashboard.svg' %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
            <span class="nav-label"><%= primarySettingsDashboardNavEntry.name || 'Dashboard' %></span>
          </a>
          <% if (secondarySettingsDashboardNavEntries.length) { %>
            <% secondarySettingsDashboardNavEntries.forEach((dashboardLink) => { %>
              <a class="nav-item nav-item--dashboard-child<%= activeSettingsDashboardNavId === dashboardLink.id ? ' active' : '' %>" href="/dashboard?dashboard=<%= encodeURIComponent(dashboardLink.id) %>">
                <img class="nav-icon" src="<%= dashboardLink.icon || '/icons/dashboard.svg' %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
                <span class="nav-label"><%= dashboardLink.name %></span>
              </a>
            <% }) %>
          <% } %>
        <% } %>
        <%- include('partials/nav-categories', { navDashHasEntries: settingsDashboardNavEntries.length > 0, navActiveAppId: null, navActivePage: null }) %>
      </div>

      <%- include('partials/user-menu') %>
    </aside>

    <section class="dash-main">
      <div class="main-window-bar">
        <button class="sidebar-toggle main-toggle left-toggle" type="button" aria-label="Toggle sidebar">
          <img class="toggle-icon" src="/icons/sidebar-toggle.svg" alt="" />
        </button>
        <div class="main-window-title">
          <img class="main-window-icon" src="/icons/settings.svg" alt="" />
          <span class="main-window-app">Settings</span>
        </div>
      <div class="main-window-spacer"></div>
      <div class="main-window-status">
        <span class="status-dot"></span>
      </div>
    </div>
    <div class="settings-debug" id="settingsDebug" style="display:none;"></div>

      <% const safeJson = (value) => JSON.stringify(value)
        .replace(/</g, '\\u003c')
        .replace(/\u2028/g, '\\u2028')
        .replace(/\u2029/g, '\\u2029'); %>
      <%
        const multiInstanceBaseIdsList = (Array.isArray(multiInstanceBaseIds) ? multiInstanceBaseIds : [])
          .map((item) => String(item || '').trim().toLowerCase())
          .filter(Boolean);
        const resolveAppBaseId = (value) => {
          const id = String(value || '').trim().toLowerCase();
          if (!id) return '';
          const matched = multiInstanceBaseIdsList
            .slice()
            .sort((a, b) => b.length - a.length)
            .find((baseId) => {
              if (id === baseId) return true;
              if (!id.startsWith(baseId + '-')) return false;
              return /^\d+$/.test(id.slice(baseId.length + 1));
            });
          return matched || id;
        };
        const appInstanceBaseTitles = (multiInstanceTitleMap && typeof multiInstanceTitleMap === 'object')
          ? multiInstanceTitleMap
          : {};
        const resolveAppBaseTitle = (value) => {
          const key = resolveAppBaseId(value);
          if (!key) return 'App';
          if (appInstanceBaseTitles[key]) return appInstanceBaseTitles[key];
          return key.charAt(0).toUpperCase() + key.slice(1);
        };
        const resolveAppInstanceSuffix = (value, baseHint = '') => {
          const id = String(value || '').trim().toLowerCase();
          const baseId = resolveAppBaseId(baseHint || id);
          if (!id || !baseId) return NaN;
          const match = id.match(new RegExp(`^${baseId}-(\\d+)$`));
          if (!match) return id === baseId ? 1 : NaN;
          return Number(match[1]);
        };
        const resolveInstanceTabLabel = (appItem) => {
          const baseId = resolveAppBaseId(appItem?.id);
          const baseTitle = resolveAppBaseTitle(baseId);
          const instanceName = String(appItem?.instanceName || '').trim();
          if (instanceName && instanceName.toLowerCase() !== baseTitle.toLowerCase()) {
            return instanceName;
          }
          const suffix = resolveAppInstanceSuffix(appItem?.id, baseId);
          if (Number.isFinite(suffix) && suffix > 1) return `${baseTitle} ${suffix}`;
          return baseTitle;
        };
        const resolveAppIconPath = (appItem) => {
          const customIcon = String(appItem?.icon || '').trim();
          if (customIcon) return customIcon;
          const baseId = resolveAppBaseId(appItem?.id);
          if (['plex', 'tautulli', 'radarr', 'sonarr', 'lidarr', 'readarr', 'pulsarr', 'seerr', 'prowlarr', 'cleanuparr', 'huntarr', 'transmission', 'nzbget', 'qbittorrent', 'sabnzbd', 'jellyfin', 'emby', 'bazarr'].includes(baseId)) {
            return `/icons/${baseId}.png`;
          }
          return `/icons/${baseId || 'app'}.svg`;
        };
      %>
      <div class="settings-tabs" role="tablist" aria-label="Settings tabs">
        <button class="settings-tab-btn is-active" type="button" data-tab="general">
          <img class="settings-tab-icon" src="/icons/settings.svg" alt="" />
          <span class="settings-tab-text">General</span>
        </button>
        <button class="settings-tab-btn" type="button" data-tab="app">
          <img class="settings-tab-icon" src="/icons/app.svg" alt="" />
          <span class="settings-tab-text">Apps</span>
        </button>
        <button class="settings-tab-btn" type="button" data-tab="custom">
          <img class="settings-tab-icon" src="/icons/tools.svg" alt="" />
          <span class="settings-tab-text">Custom</span>
        </button>
        <button class="settings-tab-btn" type="button" data-tab="user">
          <img class="settings-tab-icon" src="/icons/user-profile.svg" alt="" />
          <span class="settings-tab-text">User</span>
        </button>
        <button class="settings-tab-btn" type="button" data-tab="notifications">
          <img class="settings-tab-icon" src="/icons/status.svg" alt="" />
          <span class="settings-tab-text">Notifications</span>
        </button>
        <button class="settings-tab-btn" type="button" data-tab="log">
          <img class="settings-tab-icon" src="/icons/activity-queue.svg" alt="" />
          <span class="settings-tab-text">Logs</span>
        </button>
        <button class="settings-tab-btn" type="button" data-tab="about">
          <img class="settings-tab-icon" src="/icons/about.svg" alt="" />
          <span class="settings-tab-text">About</span>
        </button>
      </div>

      <div class="settings-tab-panel is-active" data-tab="general">
        <div class="dash-panel">
          <form method="post" action="/settings/general" class="settings-form">
            <div class="settings-card">
              <div class="settings-card-title">Server Identity</div>
              <div class="settings-card-sub">Remote URL is used for external links and sharing. Local URL is preferred for LAN Plex SSO. Use Base URL Path when Launcharr is served behind a subpath (for example <code>/launcharr</code>).</div>
              <label class="field">
                <span>Server Name</span>
                <input
                  type="text"
                  name="server_name"
                  value="<%= generalSettings?.serverName || 'Launcharr' %>"
                  placeholder="Launcharr"
                />
              </label>
              <label class="field">
                <span>Remote URL</span>
                <input
                  type="text"
                  name="remote_url"
                  value="<%= generalSettings?.remoteUrl || '' %>"
                  placeholder="https://example.com"
                />
              </label>
              <label class="field">
                <span>Local URL</span>
                <input
                  type="text"
                  name="local_url"
                  value="<%= generalSettings?.localUrl || '' %>"
                  placeholder="http://192.168.0.2:3333"
                />
              </label>
              <label class="field">
                <span>Base URL Path</span>
                <input
                  type="text"
                  name="base_path"
                  value="<%= generalSettings?.basePath || '' %>"
                  placeholder="/launcharr"
                />
              </label>
              <label class="settings-toggle">
                <input type="checkbox" name="restrictGuests" <%= generalSettings?.restrictGuests ? 'checked' : '' %> />
                <span class="settings-toggle-slider" aria-hidden="true"></span>
                <span class="settings-toggle-text">Restrict guest users</span>
              </label>
            </div>
            <button class="primary-button" type="submit">Save general settings</button>
          </form>
        </div>
      </div>

      <div class="settings-tab-panel" data-tab="custom">
        <div class="dash-panel">
          <div class="settings-subtabs" role="tablist" aria-label="Custom settings pages">
            <button class="settings-subtab-btn is-active" type="button" data-subtab="categories">
              <img class="settings-subtab-icon" src="/icons/category.svg" alt="" />
              <span class="settings-subtab-text">Categories</span>
            </button>
            <button class="settings-subtab-btn" type="button" data-subtab="apps">
              <img class="settings-subtab-icon" src="/icons/sidebar-toggle.svg" alt="" />
              <span class="settings-subtab-text">Sidebar</span>
            </button>
            <button class="settings-subtab-btn" type="button" data-subtab="dashboard">
              <img class="settings-subtab-icon" src="/icons/dashboard.svg" alt="" />
              <span class="settings-subtab-text">Dashboard</span>
            </button>
            <button class="settings-subtab-btn" type="button" data-subtab="widgets">
              <img class="settings-subtab-icon" src="/icons/dashboard.svg" alt="" />
              <span class="settings-subtab-text">Widgets</span>
            </button>
            <button class="settings-subtab-btn" type="button" data-subtab="images">
              <img class="settings-subtab-icon" src="/icons/view.svg" alt="" />
              <span class="settings-subtab-text">Images</span>
            </button>
            <button class="settings-subtab-btn" type="button" data-subtab="themes">
              <img class="settings-subtab-icon" src="/icons/sun.svg" alt="" />
              <span class="settings-subtab-text">Themes</span>
            </button>
          </div>
          <div class="settings-subtab-panel is-active" data-subtab="categories">
            <form method="post" action="/settings/categories" class="settings-form" id="categoryManagerForm">
              <input type="hidden" id="categoryManagerJson" name="categories_json" />
              <div class="settings-table settings-table--categories">
                <div class="settings-row settings-row--categories settings-head">
                  <div>
                    <img class="settings-head-icon" src="/icons/category.svg" alt="" />
                    <span class="settings-head-label">Category</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/app.svg" alt="" />
                    <span class="settings-head-label">Icon</span>
                  </div>
                  <div class="settings-col-visibility">
                    <img class="settings-head-icon" src="/icons/view.svg" alt="" />
                    <span class="settings-head-label">Visibility</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/edit.svg" alt="" />
                    <span class="settings-head-label">Edit</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/delete.svg" alt="" />
                    <span class="settings-head-label">Delete</span>
                  </div>
                </div>
                <div id="categoryRows">
                  <% const categoryManagerEntries = Array.isArray(categoryEntries) && categoryEntries.length
                    ? categoryEntries
                    : ['Tools'].map((name) => ({ name, sidebarMenu: false, sidebarMinRole: 'disabled', icon: '/icons/category.svg' })); %>
                  <% const defaultCategoryCatalogList = Array.isArray(defaultCategoryCatalog) ? defaultCategoryCatalog : []; %>
                  <% const defaultCategoryNameSet = new Set(defaultCategoryCatalogList.map((entry) => String(entry?.name || '').trim().toLowerCase()).filter(Boolean)); %>
                  <% const existingCategoryNameSet = new Set(categoryManagerEntries.map((entry) => String(entry?.name || '').trim().toLowerCase()).filter(Boolean)); %>
                  <% const categoryVisibilityRoles = [
                    { value: 'guest', label: 'Guest' },
                    { value: 'user', label: 'User' },
                    { value: 'co-admin', label: 'Co-admin' },
                    { value: 'admin', label: 'Admin' },
                  ]; %>
                  <% const missingDefaultCategories = defaultCategoryCatalogList
                    .filter((entry) => !existingCategoryNameSet.has(String(entry?.name || '').trim().toLowerCase()))
                    .sort((a, b) => String(a?.name || '').localeCompare(String(b?.name || ''))); %>
                  <% categoryManagerEntries.forEach((entry, index) => { %>
                    <% const iconValue = entry.icon || '/icons/category.svg'; %>
                    <% const isDefaultCategory = defaultCategoryNameSet.has(String(entry.name || '').trim().toLowerCase()); %>
                    <% const _rawVisRoles = Array.isArray(entry?.visibilityRoles) ? entry.visibilityRoles : null; %>
                    <% const _legacyMinRole = String(entry?.sidebarMinRole || (entry?.sidebarMenu ? 'user' : 'disabled')).trim().toLowerCase() || 'disabled'; %>
                    <% const _roleOrder = ['guest', 'user', 'co-admin', 'admin']; %>
                    <% const entryVisibilityRoles = _rawVisRoles ? _rawVisRoles.filter((r) => _roleOrder.includes(r)) : (_legacyMinRole === 'disabled' ? [] : _roleOrder.filter((r, i) => _roleOrder.indexOf(r) >= _roleOrder.indexOf(_legacyMinRole))); %>
                    <div class="settings-row settings-row--categories category-row<%= entryVisibilityRoles.length === 0 ? ' is-disabled' : '' %>" draggable="true" data-category="<%= entry.name %>" data-visibility-roles="<%= entryVisibilityRoles.join(',') %>" data-icon="<%= iconValue %>" data-default="<%= isDefaultCategory ? 'true' : 'false' %>">
                      <div class="settings-app settings-app--category">
                        <button class="order-button category-drag-handle" type="button" title="Drag to reorder" aria-label="Drag to reorder">&#x2630;</button>
                        <img class="nav-icon category-icon-preview" src="<%= iconValue %>" alt="" onerror="this.src='/icons/category.svg'" />
                        <span class="settings-app-name settings-app-name--category"><%= entry.name %></span>
                      </div>
                      <div class="settings-cell">
                        <div class="category-icon-display" aria-label="Category icon in use">
                          <img class="category-icon-display-img" src="<%= iconValue %>" alt="" onerror="this.src='/icons/category.svg'" />
                          <span class="category-icon-display-text"><%= String(iconValue || '').replace('/icons/', '') %></span>
                        </div>
                      </div>
                      <div class="settings-cell settings-cell--visibility settings-col-visibility">
                        <div class="settings-visibility-popover" data-category-visibility-popover>
                          <button class="settings-visibility-trigger" type="button" aria-label="Configure category sidebar roles" aria-expanded="false" aria-haspopup="true"></button>
                          <div class="settings-visibility-menu settings-filter-menu settings-category-role-filter-menu" hidden>
                            <div class="settings-filter-group-title">Sidebar Visibility</div>
                            <div class="settings-dashboard-role-filter-list">
                              <% categoryVisibilityRoles.forEach((option) => { %>
                                <label class="settings-dashboard-role-filter-option">
                                  <input type="checkbox" class="category-visibility-checkbox" value="<%= option.value %>" <%= entryVisibilityRoles.includes(option.value) ? 'checked' : '' %> />
                                  <span class="settings-dashboard-role-filter-option-label"><%= option.label %></span>
                                </label>
                              <% }) %>
                            </div>
                            <div class="settings-users-note settings-category-role-filter-note">No roles selected hides this category.</div>
                          </div>
                        </div>
                      </div>
                      <div class="settings-cell">
                        <button class="order-button category-edit-button" type="button" title="<%= isDefaultCategory ? 'Default categories cannot be edited.' : 'Edit category' %>" aria-label="Edit category" <%= isDefaultCategory ? 'disabled' : '' %>>Edit</button>
                      </div>
                      <div class="settings-cell">
                        <button class="order-button category-delete-button" type="button" title="Delete category" aria-label="Delete category">&times;</button>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
              <div class="category-manager-add">
                <input type="text" id="categoryManagerInput" class="category-manager-input" placeholder="New category name" autocomplete="off" />
                <div class="icon-picker" data-icon-picker>
                  <button class="settings-select icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                    <span class="icon-picker-preview" aria-hidden="true"></span>
                    <span class="icon-picker-label">Select icon</span>
                  </button>
                  <div class="icon-picker-menu" role="listbox" aria-label="Category icon">
                    <% (Array.isArray(categoryIcons) ? categoryIcons : []).forEach((iconPath) => { %>
                      <button class="icon-picker-option" type="button" data-value="<%= iconPath %>" data-label="<%= iconPath.replace('/icons/', '') %>" role="option">
                        <img class="icon-picker-icon" src="<%= iconPath %>" alt="" />
                        <span class="icon-picker-option-label"><%= iconPath.replace('/icons/', '') %></span>
                      </button>
                    <% }) %>
                  </div>
                  <input type="hidden" id="categoryManagerIconSelect" value="" />
                </div>
                <button class="primary-button" type="button" id="categoryManagerAddBtn">Add category</button>
              </div>
              <div class="category-manager-add app-manager-add default-category-add-row" id="defaultCategoryForm">
                <div class="icon-picker default-category-picker" data-default-category-picker>
                  <button class="settings-select icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                    <span class="icon-picker-preview" aria-hidden="true"></span>
                    <span class="icon-picker-label">Select default category</span>
                  </button>
                  <div class="icon-picker-menu" role="listbox" aria-label="Default category">
                    <% if (missingDefaultCategories.length) { %>
                      <% missingDefaultCategories.forEach((entry) => { %>
                        <% const defaultIcon = String(entry?.icon || '/icons/category.svg').trim() || '/icons/category.svg'; %>
                        <% const _defEntryRoles = Array.isArray(entry?.visibilityRoles) ? entry.visibilityRoles.filter((r) => ['guest','user','co-admin','admin'].includes(r)) : (String(entry?.sidebarMinRole || (entry?.sidebarMenu ? 'user' : 'disabled')).trim().toLowerCase() === 'disabled' ? [] : ['guest','user','co-admin','admin'].slice(['guest','user','co-admin','admin'].indexOf(String(entry?.sidebarMinRole || 'user').trim().toLowerCase()))); %>
                        <button
                          class="icon-picker-option"
                          type="button"
                          role="option"
                          data-default-category-option
                          data-value="<%= entry.name %>"
                          data-label="<%= entry.name %>"
                          data-default-icon="<%= defaultIcon %>"
                          data-default-visibility-roles="<%= _defEntryRoles.join(',') %>"
                          data-preview="<%= defaultIcon %>"
                        >
                          <img class="icon-picker-icon" src="<%= defaultIcon %>" alt="" onerror="this.src='/icons/category.svg'" />
                          <span class="icon-picker-option-label"><%= entry.name %></span>
                        </button>
                      <% }) %>
                    <% } else { %>
                      <div class="icon-picker-empty">No default categories available</div>
                    <% } %>
                  </div>
                  <input type="hidden" id="defaultCategorySelect" value="" />
                </div>
                <button class="primary-button default-category-add-btn" type="button" id="defaultCategoryAddBtn" <%= missingDefaultCategories.length ? '' : 'disabled' %>>Add default category</button>
              </div>
              <span class="settings-users-note" id="categoryManagerNote">Manage categories, including removing and re-adding defaults.</span>
              <button class="primary-button" type="submit">Save category settings</button>
            </form>
          </div>
          <div class="settings-subtab-panel" data-subtab="apps">
            <form method="post" action="/settings/apps" class="settings-form">
              <% const availableCategories = Array.isArray(categories) && categories.length ? categories : ['Tools']; %>
              <% const defaultCatalog = Array.isArray(defaultAppCatalog) ? defaultAppCatalog : []; %>
              <% const defaultAppIdSet = new Set(defaultCatalog.map((entry) => String(entry?.id || '').trim().toLowerCase()).filter(Boolean)); %>
              <% const displayApps = (Array.isArray(apps) ? apps : []).filter((appItem) => !appItem?.removed); %>
              <% const fallbackMissingDefaultApps = (Array.isArray(apps) ? apps : [])
                .filter((appItem) => {
                  if (!Boolean(appItem?.removed)) return false;
                  if (!Boolean(appItem?.canRemoveDefaultApp)) return false;
                  const targetId = String(appItem?.id || '').trim().toLowerCase();
                  return Boolean(targetId) && !defaultAppIdSet.has(targetId);
                })
                .map((appItem) => ({
                  id: String(appItem?.id || '').trim().toLowerCase(),
                  name: String(appItem?.name || '').trim() || 'App',
                  icon: resolveAppIconPath(appItem),
                  category: String(appItem?.category || 'Tools').trim() || 'Tools',
                  order: Number.isFinite(Number(appItem?.order)) ? Number(appItem.order) : Number.MAX_SAFE_INTEGER,
                })); %>
              <% const resolveMissingDefaultCategoryRank = (categoryName) => {
                const normalized = String(categoryName || '').trim().toLowerCase();
                const index = availableCategories.findIndex((entry) => String(entry || '').trim().toLowerCase() === normalized);
                return index === -1 ? Number.MAX_SAFE_INTEGER : index;
              }; %>
              <% const missingDefaultApps = defaultCatalog
                .filter((entry) => {
                  const targetId = String(entry?.id || '').trim().toLowerCase();
                  if (!targetId) return false;
                  const existing = (Array.isArray(apps) ? apps : []).find((appItem) => String(appItem?.id || '').trim().toLowerCase() === targetId);
                  return !existing || Boolean(existing?.removed);
                })
                .concat(fallbackMissingDefaultApps)
                .sort((a, b) => {
                  const categoryDelta = resolveMissingDefaultCategoryRank(a?.category) - resolveMissingDefaultCategoryRank(b?.category);
                  if (categoryDelta !== 0) return categoryDelta;
                  const categoryNameDelta = String(a?.category || '').localeCompare(String(b?.category || ''));
                  if (categoryNameDelta !== 0) return categoryNameDelta;
                  const leftOrder = Number(a?.order);
                  const rightOrder = Number(b?.order);
                  const orderDelta = (Number.isFinite(leftOrder) ? leftOrder : Number.MAX_SAFE_INTEGER)
                    - (Number.isFinite(rightOrder) ? rightOrder : Number.MAX_SAFE_INTEGER);
                  if (orderDelta !== 0) return orderDelta;
                  return String(a?.name || '').localeCompare(String(b?.name || ''));
                }); %>
              <% const missingDefaultAppGroups = missingDefaultApps.reduce((acc, entry) => {
                const group = String(entry?.category || 'Tools').trim() || 'Tools';
                if (!acc[group]) acc[group] = [];
                acc[group].push(entry);
                return acc;
              }, {}); %>
              <% const categoryOptions = availableCategories.map((value) => {
                const label = String(value || '').trim();
                const initials = label
                  .split(/\s+/)
                  .map((part) => part.charAt(0))
                  .join('')
                  .toUpperCase();
                const short = initials || label.slice(0, 3).toUpperCase();
                return { value: label, label, short };
              }); %>
              <% const visibilityRoles = [
                { value: 'disabled', label: 'Disabled' },
                { value: 'guest', label: 'Guest' },
                { value: 'user', label: 'User' },
                { value: 'co-admin', label: 'Co-admin' },
                { value: 'admin', label: 'Admin' },
              ]; %>
              <% const visibilityRoleRank = { disabled: -1, guest: 0, user: 1, 'co-admin': 2, admin: 3 }; %>
              <% const visibilityRoleMultiOptions = visibilityRoles.filter((option) => option.value !== 'disabled'); %>
              <% const parseVisibilityRole = (value) => {
                const raw = String(value || '').trim().toLowerCase();
                if (!raw) return '';
                if (raw === 'coadmin' || raw === 'co_admin') return 'co-admin';
                return Object.prototype.hasOwnProperty.call(visibilityRoleRank, raw) ? raw : '';
              }; %>
              <% const normalizeVisibilityRole = (value, fallback = 'disabled') => {
                const parsed = parseVisibilityRole(value);
                if (parsed) return parsed;
                const fallbackParsed = parseVisibilityRole(fallback);
                return fallbackParsed || 'disabled';
              }; %>
              <% const normalizeVisibilityRoleList = (value, fallback = 'disabled') => {
                const sourceList = Array.isArray(value)
                  ? value
                  : (typeof value === 'string' && value.includes(','))
                    ? value.split(',')
                    : (value === undefined ? [] : [value]);
                const parsed = Array.from(new Set(
                  sourceList
                    .map((entry) => parseVisibilityRole(entry))
                    .filter((entry) => entry && entry !== 'disabled')
                ));
                if (parsed.length) {
                  return visibilityRoleMultiOptions
                    .map((option) => option.value)
                    .filter((roleValue) => parsed.includes(roleValue));
                }
                const fallbackRole = normalizeVisibilityRole(fallback, 'disabled');
                if (fallbackRole === 'disabled') return [];
                return visibilityRoleMultiOptions
                  .map((option) => option.value)
                  .filter((roleValue) => Number(visibilityRoleRank[roleValue]) >= Number(visibilityRoleRank[fallbackRole]));
              }; %>
              <% const deriveSectionMinRoleFromLegacy = (sectionName, section) => {
                const userAllowed = Boolean(section?.user);
                const adminAllowed = Boolean(section?.admin);
                if (userAllowed) return 'user';
                if (adminAllowed) return sectionName === 'settings' ? 'admin' : 'co-admin';
                return 'disabled';
              }; %>
              <% const resolveSectionMinRole = (sectionName, section, fallback = 'disabled') => {
                const explicit = parseVisibilityRole(section?.minRole);
                if (explicit) return explicit;
                const legacy = deriveSectionMinRoleFromLegacy(sectionName, section);
                return normalizeVisibilityRole(legacy, fallback);
              }; %>
              <% const deriveSidebarMinRole = (sidebar, sectionRoles) => {
                const explicit = parseVisibilityRole(sidebar?.minRole);
                if (explicit) return explicit;
                const enabled = (Array.isArray(sectionRoles) ? sectionRoles : [])
                  .map((entry) => normalizeVisibilityRole(entry, 'disabled'))
                  .filter((entry) => entry !== 'disabled');
                if (!enabled.length) return 'disabled';
                return enabled.reduce((lowest, nextRole) => {
                  const lowestRank = Number(visibilityRoleRank[normalizeVisibilityRole(lowest, 'disabled')]);
                  const nextRank = Number(visibilityRoleRank[normalizeVisibilityRole(nextRole, 'disabled')]);
                  return nextRank < lowestRank ? nextRole : lowest;
                }, enabled[0]);
              }; %>
              <% const launchOptions = [
                { value: 'new-tab', label: 'New Tab', short: 'Tab' },
                { value: 'iframe', label: 'iFrame', short: 'Frame' },
              ]; %>
              <div class="category-manager-add app-manager-add default-app-add-row" id="defaultAppForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
                <input type="hidden" name="settings_tab" value="custom" />
                <div class="icon-picker default-app-picker" data-default-app-picker>
                  <button class="settings-select icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                    <span class="icon-picker-preview" aria-hidden="true"></span>
                    <span class="icon-picker-label">Select default app</span>
                  </button>
                  <div class="icon-picker-menu" role="listbox" aria-label="Default app">
                    <% if (missingDefaultApps.length) { %>
                      <% Object.keys(missingDefaultAppGroups).sort((a, b) => {
                        const categoryDelta = resolveMissingDefaultCategoryRank(a) - resolveMissingDefaultCategoryRank(b);
                        if (categoryDelta !== 0) return categoryDelta;
                        return String(a || '').localeCompare(String(b || ''));
                      }).forEach((groupName) => { %>
                        <div class="icon-picker-group-label"><%= groupName %></div>
                        <% missingDefaultAppGroups[groupName].forEach((entry) => { %>
                          <button
                            class="icon-picker-option"
                            type="button"
                            role="option"
                            data-default-app-option
                            data-value="<%= entry.id %>"
                            data-label="<%= entry.name %>"
                            data-default-category="<%= String(entry.category || 'Tools') %>"
                            data-preview="<%= entry.icon || '/icons/app.svg' %>"
                          >
                            <img class="icon-picker-icon" src="<%= entry.icon || '/icons/app.svg' %>" alt="" onerror="this.src='/icons/app.svg'" />
                            <span class="icon-picker-option-label"><%= entry.name %></span>
                          </button>
                        <% }) %>
                      <% }) %>
                    <% } else { %>
                      <div class="icon-picker-empty">No default apps available</div>
                    <% } %>
                  </div>
                  <input type="hidden" name="default_app_id" id="defaultAppSelect" value="" />
                </div>
                <select class="settings-select app-manager-select default-app-category-select" name="default_app_category" id="defaultAppCategory">
                  <% categoryOptions.forEach((option) => { %>
                    <option value="<%= option.value %>"><%= option.label %></option>
                  <% }) %>
                </select>
                <button class="primary-button default-app-add-btn" type="submit" formaction="/settings/default-apps/add" formmethod="post" <%= missingDefaultApps.length ? '' : 'disabled' %>>Add default app</button>
              </div>
              <%
                const defaultAppResultMap = {
                  added: 'Default app added. It is disabled for sidebar, overview, and dashboard by default.',
                  removed: 'Default app removed from sidebar manager. Re-add it anytime from the dropdown.',
                };
                const defaultAppNotice = defaultAppError
                  ? defaultAppError
                  : (defaultAppResultMap[defaultAppResult] || 'Add or remove default apps from sidebar manager.');
              %>
              <span class="settings-users-note<%= defaultAppError ? ' settings-users-note--error' : '' %>" id="defaultAppNote"><%= defaultAppNotice %></span>
              <div class="category-manager-add app-manager-add" id="customAppForm">
                <input type="text" id="customAppName" class="category-manager-input" placeholder="Custom app name" />
                <select id="customAppCategory" class="settings-select app-manager-select">
                  <% (Array.isArray(categories) && categories.length ? categories : ['Tools']).forEach((category) => { %>
                    <option value="<%= category %>"><%= category %></option>
                  <% }) %>
                </select>
                <div class="icon-picker" data-app-icon-picker>
                  <button class="settings-select icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                    <span class="icon-picker-preview" aria-hidden="true"></span>
                    <span class="icon-picker-label">Select icon</span>
                  </button>
                  <div class="icon-picker-menu" role="listbox" aria-label="App icon">
                    <% (Array.isArray(appIcons) ? appIcons : []).forEach((iconPath) => { %>
                      <button class="icon-picker-option" type="button" data-value="<%= iconPath %>" data-label="<%= iconPath.replace('/icons/', '') %>" role="option">
                        <img class="icon-picker-icon" src="<%= iconPath %>" alt="" />
                        <span class="icon-picker-option-label"><%= iconPath.replace('/icons/', '') %></span>
                      </button>
                    <% }) %>
                  </div>
                  <input type="hidden" id="customAppIconSelect" value="" />
                </div>
                <button class="primary-button" type="button" id="customAppSubmit">Add custom app</button>
                <button class="order-button" type="button" id="customAppCancel" style="display:none;">Cancel edit</button>
              </div>
              <span class="settings-users-note" id="customAppNote">Overview is disabled for custom apps.</span>
              <div class="settings-table settings-table--display" id="displayAppsTable">
                <div class="settings-row settings-row--display settings-head">
                  <div>
                    <img class="settings-head-icon" src="/icons/app.svg" alt="" />
                    <span class="settings-head-label">Application</span>
                  </div>
                  <div class="settings-col-visibility">
                    <img class="settings-head-icon" src="/icons/view.svg" alt="" />
                    <span class="settings-head-label">Visibility</span>
                  </div>
                  <div class="settings-col-launch">
                    <img class="settings-head-icon" src="/icons/launch.svg" alt="" />
                    <span class="settings-head-label">Launch</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/favourite.svg" alt="" />
                    <span class="settings-head-label">Favourite</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/category.svg" alt="" />
                    <span class="settings-head-label">Category</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/edit.svg" alt="" />
                    <span class="settings-head-label">Edit</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/delete.svg" alt="" />
                    <span class="settings-head-label">Delete</span>
                  </div>
                </div>
                <% displayApps.forEach((app, index) => { %>
                  <% const menu = app.menu || {}; %>
                  <% const sidebarOverview = menu.sidebarOverview || {}; %>
                  <% const sidebarSettings = menu.sidebarSettings || {}; %>
                  <% const sidebarActivity = menu.sidebarActivity || {}; %>
                  <% const overview = menu.overview || {}; %>
                  <% const launch = menu.launch || {}; %>
                  <% const settings = menu.settings || {}; %>
                  <% const overviewMinRole = resolveSectionMinRole('overview', overview, 'disabled'); %>
                  <% const launchMinRole = resolveSectionMinRole('launch', launch, 'disabled'); %>
                  <% const settingsMinRole = resolveSectionMinRole('settings', settings, 'admin'); %>
                  <% const sidebarVisibilityRoles = normalizeVisibilityRoleList(
                    Array.isArray(menu?.sidebar?.visibilityRoles) ? menu.sidebar.visibilityRoles : undefined,
                    deriveSidebarMinRole(menu.sidebar || {}, [overviewMinRole, launchMinRole, settingsMinRole])
                  ); %>
                  <% const sidebarEnabled = sidebarVisibilityRoles.length > 0; %>
                  <% const appLaunchOptions = launchOptions; %>
                  <% const modeValues = appLaunchOptions.map((option) => option.value); %>
                  <% const currentLaunchMode = modeValues.includes(app.launchMode) ? app.launchMode : 'new-tab'; %>
                  <% const categoryValues = categoryOptions.map((option) => option.value); %>
                  <% const currentCategory = categoryValues.includes(app.category) ? app.category : categoryOptions[0].value; %>
                  <% const isCustomApp = Boolean(app.isCustomApp || app.custom || String(app.id || '').trim().toLowerCase().startsWith('custom-')); %>
                  <% const orderValue = Number.isFinite(app.order) ? app.order : index + 1; %>
                  <% const favouriteValue = Boolean(app.favourite || app.favorite); %>
                  <% const isDefaultApp = defaultAppIdSet.has(String(app.id || '').trim().toLowerCase()); %>
                  <% const canRemoveDefaultApp = Boolean(app.canRemoveDefaultApp || isDefaultApp); %>
                  <% const categoryRank = Math.max(0, categoryOptions.findIndex((option) => option.value === currentCategory)); %>
                  <div class="settings-row settings-row--display settings-row--draggable <%= sidebarEnabled ? '' : 'is-disabled' %>" data-category="<%= currentCategory %>" data-category-rank="<%= categoryRank %>" draggable="true">
                    <div class="settings-app settings-app--draggable">
                      <button class="order-button settings-drag-handle settings-drag-handle--app" type="button" title="Drag to reorder within category" aria-label="Drag to reorder within category">&#x2630;</button>
                      <img class="nav-icon app-icon" src="<%= resolveAppIconPath(app) %>" alt="" onerror="this.src='/icons/app.svg'" />
                      <span class="settings-app-name"><%= app.name %></span>
                    </div>
                    <div class="settings-cell settings-cell--visibility settings-col-visibility">
                      <div class="settings-visibility-popover" data-visibility-popover>
                        <button class="settings-visibility-trigger" type="button" aria-label="Configure visibility roles" aria-expanded="false" aria-haspopup="true"></button>
                        <div class="settings-visibility-menu settings-filter-menu settings-sidebar-role-filter-menu" hidden>
                          <div class="settings-filter-group-title">Sidebar Visibility</div>
                          <input type="hidden" name="display_sidebar_visibility_roles_present_<%= app.id %>" value="1" />
                          <div class="settings-dashboard-role-filter-list">
                            <% visibilityRoleMultiOptions.forEach((option) => { %>
                              <label class="settings-dashboard-role-filter-option">
                                <input type="checkbox" name="display_sidebar_visibility_roles_<%= app.id %>" value="<%= option.value %>" <%= sidebarVisibilityRoles.includes(option.value) ? 'checked' : '' %> />
                                <span class="settings-dashboard-role-filter-option-label"><%= option.label %></span>
                              </label>
                            <% }) %>
                          </div>
                          <div class="settings-users-note settings-dashboard-role-filter-note">No roles selected hides this app from sidebar.</div>
                        </div>
                      </div>
                    </div>
                    <div class="settings-cell settings-cell--launch settings-col-launch">
                      <select class="settings-select settings-launch-mode" name="display_launch_mode_<%= app.id %>" title="<%= (() => { const baseId = resolveAppBaseId(app.id); if (baseId === 'tautulli') return 'Tautulli iFrame mode is overridden to New Tab on local/private host access.'; if (baseId === 'agregarr') return 'Agregarr iFrame mode is overridden to New Tab for Plex SSO compatibility.'; if (baseId === 'sortarr') return 'Sortarr iFrame mode is overridden to New Tab for compatibility.'; return 'Choose how launch opens.'; })() %>">
                        <% appLaunchOptions.forEach((option) => { %>
                          <option value="<%= option.value %>" <%= option.value === currentLaunchMode ? 'selected' : '' %> data-full="<%= option.label %>" data-short="<%= option.short %>" title="<%= option.label %>"><%= option.label %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="settings-cell">
                      <button class="settings-favourite-toggle <%= favouriteValue ? 'is-active' : '' %>" type="button" aria-pressed="<%= favouriteValue ? 'true' : 'false' %>" aria-label="Toggle favourite">
                        <img class="settings-favourite-icon" src="<%= favouriteValue ? '/icons/favourite-solid.svg' : '/icons/favourite.svg' %>" alt="" />
                      </button>
                      <input class="settings-favourite-input" type="checkbox" name="display_favourite_<%= app.id %>" <%= favouriteValue ? 'checked' : '' %> />
                    </div>
                    <div class="settings-cell">
                      <select class="settings-select settings-category" name="display_category_<%= app.id %>">
                        <% categoryOptions.forEach((option) => { %>
                          <option value="<%= option.value %>" <%= option.value === currentCategory ? 'selected' : '' %> data-full="<%= option.label %>" data-short="<%= option.short %>" title="<%= option.value %>"><%= option.label %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="settings-cell">
                <button class="order-button custom-app-edit" type="button" title="<%= isCustomApp ? 'Edit custom app' : 'Only custom apps can be edited' %>" aria-label="Edit app" <%= isCustomApp ? 'data-app-id="' + app.id + '" data-app-name="' + app.name + '" data-app-category="' + (app.category || 'Tools') + '" data-app-icon="' + (app.icon || '') + '"' : 'disabled' %>>Edit</button>
                    </div>
                    <div class="settings-cell">
                      <% if (isCustomApp) { %>
                        <button class="order-button custom-app-delete" type="button" title="Delete custom app" aria-label="Delete app" data-app-id="<%= app.id %>">&times;</button>
                      <% } else if (canRemoveDefaultApp) { %>
                        <button
                          class="order-button default-app-delete"
                          type="button"
                          data-default-app-id="<%= app.id %>"
                          title="Remove built-in app"
                          aria-label="Remove built-in app"
                        >&times;</button>
                      <% } else { %>
                        <button class="order-button default-app-delete" type="button" title="Only custom/built-in primary apps can be deleted here" aria-label="Delete app" disabled>&times;</button>
                      <% } %>
                  </div>
                  <input type="hidden" class="settings-order-input" name="display_order_<%= app.id %>" value="<%= orderValue %>" />
                </div>
                <% }) %>
              </div>
              <button class="primary-button" type="submit">Save display settings</button>
            </form>
          </div>
          <div class="settings-subtab-panel" data-subtab="dashboard">
            <form method="post" action="/settings/dashboard-elements" class="settings-form" id="dashboardElementsForm">
              <%
                const dashboardTabs = (Array.isArray(dashboardDefinitions) ? dashboardDefinitions : [])
                  .map((entry) => ({
                    id: String(entry?.id || '').trim() || 'main',
                    name: String(entry?.name || '').trim() || 'Dashboard',
                    icon: String(entry?.icon || '/icons/dashboard.svg').trim() || '/icons/dashboard.svg',
                    visibilityRole: String(entry?.visibilityRole || 'user').trim() || 'user',
                    visibilityRoles: Array.isArray(entry?.visibilityRoles) ? entry.visibilityRoles : [],
                  }))
                  .filter((entry, index, list) => (
                    entry.id && list.findIndex((candidate) => candidate.id === entry.id) === index
                  ));
                if (!dashboardTabs.length) {
                  dashboardTabs.push({
                    id: 'main',
                    name: 'Dashboard',
                    icon: '/icons/dashboard.svg',
                    visibilityRole: 'user',
                  });
                }
                const activeDashboardId = String(activeDashboard?.id || 'main').trim() || 'main';
                const activeDashboardEntry = dashboardTabs.find((entry) => entry.id === activeDashboardId) || dashboardTabs[0];
                const dashboardIconOptions = [
                  ...(Array.isArray(systemIconDefaults) ? systemIconDefaults : []),
                  ...(Array.isArray(systemIconCustom) ? systemIconCustom : []),
                ];
                const dashboardVisibilityRoles = [
                  { value: 'disabled', label: 'Disabled' },
                  { value: 'guest', label: 'Guest' },
                  { value: 'user', label: 'User' },
                  { value: 'co-admin', label: 'Co-admin' },
                  { value: 'admin', label: 'Admin' },
                ];
                const dashboardInstanceVisibilityRoles = dashboardVisibilityRoles.filter((option) => option.value !== 'disabled');
                const parseDashboardVisibilityRole = (value) => {
                  const raw = String(value || '').trim().toLowerCase();
                  if (!raw) return '';
                  if (raw === 'coadmin' || raw === 'co_admin') return 'co-admin';
                  return ['disabled', 'guest', 'user', 'co-admin', 'admin'].includes(raw) ? raw : '';
                };
                const normalizeDashboardVisibilityRole = (value, fallback = 'user') => {
                  const parsed = parseDashboardVisibilityRole(value);
                  if (parsed) return parsed;
                  const fallbackParsed = parseDashboardVisibilityRole(fallback);
                  return fallbackParsed || 'user';
                };
                const normalizeDashboardVisibilityRoleList = (value, fallback) => {
                  const sourceList = Array.isArray(value) ? value : (value ? [value] : []);
                  const parsed = sourceList
                    .map((item) => parseDashboardVisibilityRole(item))
                    .filter((role, index, list) => role && role !== 'disabled' && list.indexOf(role) === index);
                  if (parsed.length) {
                    return dashboardInstanceVisibilityRoles
                      .map((option) => option.value)
                      .filter((role) => parsed.includes(role));
                  }
                  const fallbackRole = normalizeDashboardVisibilityRole(fallback, 'user');
                  if (fallbackRole === 'disabled') return [];
                  const roleOrder = dashboardInstanceVisibilityRoles.map((option) => option.value);
                  const fallbackIndex = roleOrder.indexOf(fallbackRole);
                  if (fallbackIndex < 0) return ['user', 'co-admin', 'admin'];
                  return roleOrder.slice(fallbackIndex);
                };
                const resolveCombinedDashboardVisibilityRoleView = (settings, fallback = 'user') => {
                  const source = settings && typeof settings === 'object' ? settings : {};
                  const explicit = parseDashboardVisibilityRole(source.visibilityRole);
                  if (explicit) return explicit;
                  const enabled = source.enable === undefined ? true : Boolean(source.enable);
                  const dashboard = source.dashboard === undefined ? true : Boolean(source.dashboard);
                  if (!enabled || !dashboard) return 'disabled';
                  return normalizeDashboardVisibilityRole(fallback, 'user');
                };
                activeDashboardEntry.visibilityRoles = normalizeDashboardVisibilityRoleList(
                  activeDashboardEntry.visibilityRoles,
                  activeDashboardEntry.visibilityRole
                );
                const activeDashboardVisibilityRoles = activeDashboardEntry.visibilityRoles;
                const activeDashboardVisibilitySummary = activeDashboardVisibilityRoles.length === 0
                  ? 'Hidden (no roles selected)'
                  : (activeDashboardVisibilityRoles.length === dashboardInstanceVisibilityRoles.length
                    ? 'All roles'
                    : dashboardInstanceVisibilityRoles
                      .filter((option) => activeDashboardVisibilityRoles.includes(option.value))
                      .map((option) => option.label)
                      .join(', '));
                const deletableDashboardTabs = dashboardTabs.filter((entry) => entry.id !== 'main');
              %>
              <input type="hidden" name="dashboardId" value="<%= activeDashboardEntry.id %>" />
              <input type="hidden" name="dashboard_duplicate_source" value="blank" data-dashboard-duplicate-source />
              <input type="hidden" name="deleteDashboardId" value="<%= deletableDashboardTabs[0]?.id || '' %>" data-dashboard-delete-target />
              <div class="settings-subtabs app-instance-tabs" role="tablist" aria-label="Dashboard tabs">
                <% dashboardTabs.forEach((dashboardTab, dashboardTabIndex) => { %>
                  <% const isMainDashboardTab = dashboardTab.id === 'main'; %>
                  <div class="app-instance-tab-entry">
                    <a
                      class="settings-subtab-btn<%= dashboardTab.id === activeDashboardEntry.id ? ' is-active' : '' %>"
                      href="/settings?tab=custom&settingsCustomTab=dashboard&dashboard=<%= encodeURIComponent(dashboardTab.id) %>"
                      data-dashboard-id="<%= dashboardTab.id %>"
                    >
                      <span class="settings-subtab-text"><%= dashboardTab.name %></span>
                    </a>
                  </div>
                <% }) %>
                <% if (dashboardTabs.length < 10) { %>
                  <div class="app-instance-tab-add-form settings-visibility-popover" data-dashboard-duplicate-popover>
                    <button
                      class="settings-subtab-btn app-instance-tab-add"
                      type="button"
                      title="Duplicate source: Blank"
                      aria-label="Choose dashboard duplicate source (Blank)"
                      aria-haspopup="true"
                      aria-expanded="false"
                      data-dashboard-duplicate-trigger
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                      </svg>
                    </button>
                    <div class="settings-visibility-menu settings-filter-menu" hidden data-dashboard-duplicate-menu>
                      <div class="settings-filter-group-title">Duplicate Source</div>
                      <div class="settings-dashboard-role-filter-list">
                        <label class="settings-dashboard-role-filter-option">
                          <input type="radio" name="dashboard_duplicate_source_choice" value="blank" checked data-dashboard-duplicate-option />
                          <span class="settings-dashboard-role-filter-option-label">Blank</span>
                        </label>
                        <% dashboardTabs.forEach((dashboardTab) => { %>
                          <label class="settings-dashboard-role-filter-option">
                            <input type="radio" name="dashboard_duplicate_source_choice" value="<%= dashboardTab.id %>" data-dashboard-duplicate-option />
                            <span class="settings-dashboard-role-filter-option-label"><%= dashboardTab.name %><%= dashboardTab.id === activeDashboardEntry.id ? ' (Current)' : '' %></span>
                          </label>
                        <% }) %>
                      </div>
                      <div class="settings-users-note settings-dashboard-role-filter-note">Pick a dashboard to duplicate, or leave Blank to create an empty dashboard.</div>
                      <button
                        class="settings-subtab-btn settings-dashboard-duplicate-submit"
                        type="submit"
                        formaction="/settings/dashboards/add"
                        formmethod="post"
                        formnovalidate
                      >
                        + Dashboard
                      </button>
                    </div>
                  </div>
                <% } %>
                <% if (deletableDashboardTabs.length) { %>
                  <div class="app-instance-tab-add-form settings-visibility-popover" data-dashboard-delete-popover>
                    <button
                      class="settings-subtab-btn app-instance-tab-add settings-dashboard-delete-trigger"
                      type="button"
                      title="Delete dashboard: <%= deletableDashboardTabs[0].name %>"
                      aria-label="Choose dashboard to delete (<%= deletableDashboardTabs[0].name %>)"
                      aria-haspopup="true"
                      aria-expanded="false"
                      data-dashboard-delete-trigger
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <path d="M3 6h18"></path>
                        <path d="M8 6V4h8v2"></path>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                        <path d="M10 11v6"></path>
                        <path d="M14 11v6"></path>
                      </svg>
                    </button>
                    <div class="settings-visibility-menu settings-filter-menu" hidden data-dashboard-delete-menu>
                      <div class="settings-filter-group-title">Delete Dashboard</div>
                      <div class="settings-dashboard-role-filter-list">
                        <% deletableDashboardTabs.forEach((dashboardTab, deleteTabIndex) => { %>
                          <label class="settings-dashboard-role-filter-option">
                            <input
                              type="radio"
                              name="dashboard_delete_target_choice"
                              value="<%= dashboardTab.id %>"
                              <%= deleteTabIndex === 0 ? 'checked' : '' %>
                              data-dashboard-delete-option
                            />
                            <span class="settings-dashboard-role-filter-option-label"><%= dashboardTab.name %><%= dashboardTab.id === activeDashboardEntry.id ? ' (Current)' : '' %></span>
                          </label>
                        <% }) %>
                      </div>
                      <div class="settings-users-note settings-dashboard-role-filter-note">Select a dashboard to remove. The default Dashboard cannot be deleted.</div>
                      <button
                        class="settings-subtab-btn settings-dashboard-delete-submit"
                        type="submit"
                        formaction="/settings/dashboards/delete"
                        formmethod="post"
                        formnovalidate
                        onclick="return confirm('Delete this dashboard? This cannot be undone.');"
                      >
                        - Dashboard
                      </button>
                    </div>
                  </div>
                <% } %>
              </div>
              <div class="settings-grid settings-grid--dashboard-meta" style="margin-bottom:12px;">
                <label class="field field--dashboard-name">
                  <span>Dashboard name</span>
                  <input
                    type="text"
                    name="dashboard_name"
                    value="<%= activeDashboardEntry.name %>"
                    placeholder="<%= activeDashboardEntry.id === 'main' ? 'Dashboard' : 'Dashboard name' %>"
                    maxlength="48"
                  />
                </label>
                <label class="field field--dashboard-icon">
                  <span>Dashboard icon</span>
                  <div class="icon-picker" data-dashboard-meta-icon-picker>
                    <button class="settings-select icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                      <span class="icon-picker-preview" aria-hidden="true"></span>
                      <span class="icon-picker-label">Select icon</span>
                    </button>
                    <div class="icon-picker-menu" role="listbox" aria-label="Dashboard icon">
                      <% dashboardIconOptions.forEach((iconPath) => { %>
                        <button class="icon-picker-option" type="button" data-value="<%= iconPath %>" data-label="<%= iconPath.replace('/icons/', '') %>" role="option">
                          <img class="icon-picker-icon" src="<%= iconPath %>" alt="" />
                          <span class="icon-picker-option-label"><%= iconPath.replace('/icons/', '') %></span>
                        </button>
                      <% }) %>
                    </div>
                    <input type="hidden" id="dashboardMetaIconSelect" name="dashboard_icon" value="<%= activeDashboardEntry.icon %>" />
                  </div>
                </label>
                <label class="field field--dashboard-role">
                  <span>Visibility</span>
                  <input type="hidden" name="dashboard_visibility_roles_present" value="1" />
                  <div class="settings-dashboard-role-filter settings-visibility-popover" data-dashboard-role-filter>
                    <button
                      class="settings-visibility-trigger settings-dashboard-role-filter-trigger"
                      type="button"
                      aria-label="Configure dashboard visibility"
                      aria-haspopup="true"
                      aria-expanded="false"
                      data-dashboard-role-filter-trigger
                    ></button>
                    <div class="settings-visibility-menu settings-filter-menu settings-dashboard-role-filter-menu" hidden data-dashboard-role-filter-menu>
                      <div class="settings-filter-group-title">Visible To Roles</div>
                      <div class="settings-dashboard-role-filter-list">
                        <% dashboardInstanceVisibilityRoles.forEach((option) => { %>
                          <label class="settings-dashboard-role-filter-option">
                            <input
                              type="checkbox"
                              name="dashboard_visibility_roles"
                              value="<%= option.value %>"
                              <%= activeDashboardVisibilityRoles.includes(option.value) ? 'checked' : '' %>
                            />
                            <span class="settings-dashboard-role-filter-option-label"><%= option.label %></span>
                          </label>
                        <% }) %>
                      </div>
                      <div class="settings-users-note settings-dashboard-role-filter-note">No roles selected hides this dashboard.</div>
                    </div>
                  </div>
                </label>
              </div>
              <% const tautulliItems = Array.isArray(tautulliCards) ? tautulliCards : []; %>
              <% if (tautulliItems.length) { %>
                <input type="hidden" name="tautulliCardsForm" value="1" />
              <% } %>
              <div class="settings-table settings-table--elements" id="dashboardElementsTable">
                <div class="settings-row settings-head settings-row--elements settings-row--with-expand">
                  <div>
                    <img class="settings-head-icon" src="/icons/overview.svg" alt="" />
                    <span class="settings-head-label">Name</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/all-type.svg" alt="" />
                    <span class="settings-head-label">Filter</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/view.svg" alt="" />
                    <span class="settings-head-label">Visibility</span>
                  </div>
                  <div>
                    <img class="settings-head-icon" src="/icons/delete.svg" alt="" />
                    <span class="settings-head-label">Delete</span>
                  </div>
                </div>
                <% (Array.isArray(dashboardElements) ? dashboardElements : []).forEach((item, index) => { %>
                  <% const element = item.element || {}; %>
                  <% const combinedRowToken = item.combined
                    ? `${String(item.combinedType || 'combined')}-${String(item.combinedSection || element.id || index)}`
                    : `single-${index}`; %>
                  <% const rowKey = `${String(item.appId)}-${String(element.id || index)}-${combinedRowToken}`; %>
                  <% const categoryRank = Math.max(0, (categories || []).indexOf(item.category || 'Tools')); %>
                  <% const displayName = item.displayName || element.name; %>
                  <% const elementIcon = item.iconPath || resolveAppIconPath({ id: item.appId }); %>
                  <% const isArrCombined = item.combined && (item.combinedType === 'arr' || item.combinedType === 'arrcustom'); %>
                  <% const isCustomArrCombined = item.combinedType === 'arrcustom'; %>
                  <% const canRemoveDashboardItem = Boolean(item.dashboardElementKey); %>
                  <% const showWatchCardsPanel = item.appId === 'tautulli' && element.id === 'watch-stats' && tautulliItems.length; %>
                  <% const tautulliStatsView = element.tautulliStatsView === 'wheel' ? 'wheel' : 'list'; %>
                  <% const combinedOrderKey = item.combined ? `combined:${item.combinedType || 'mixed'}:${item.combinedSection || element.id || 'unknown'}` : ''; %>
                  <% const combinedOrderValue = combinedOrderKey && dashboardCombinedOrder ? Number(dashboardCombinedOrder[combinedOrderKey]) : NaN; %>
                  <% const orderValue = Number.isFinite(combinedOrderValue) ? combinedOrderValue : (Number.isFinite(element.order) ? element.order : index + 1); %>
                  <% const isQueue = element.id === 'activity-queue'; %>
                  <% const isTableCard = ['activity-queue', 'subtitle-queue', 'recent-matches', 'delivery-queue', 'search'].includes(element.id); %>
                  <% const isSpecialtyTable = !item.combined && !item.dashboardIsDeprecated && (
                    (resolveAppBaseId(item.appId) === 'metube' && element.id === 'queue') ||
                    (resolveAppBaseId(item.appId) === 'wizarr' && (element.id === 'users' || element.id === 'invitations')) ||
                    (resolveAppBaseId(item.appId) === 'uptime-kuma' && element.id === 'status') ||
                    (resolveAppBaseId(item.appId) === 'guacamole' && (element.id === 'active-sessions' || element.id === 'connections')) ||
                    (resolveAppBaseId(item.appId) === 'traefik' && (element.id === 'routers' || element.id === 'services'))
                  ); %>
                  <% const isDisabled = Boolean(item.appAccess === false); %>
                  <% const isUnifiedArrCard = isArrCombined; %>
                  <% const arrSectionKey = isUnifiedArrCard ? (item.arrCombined?.sectionKey || item.combinedSection || 'activityQueue') : ''; %>
                  <% const arrSectionElementId = arrSectionKey === 'downloadingSoon'
                    ? 'downloading-soon'
                    : (arrSectionKey === 'recentlyDownloaded'
                      ? 'recently-downloaded'
                      : (arrSectionKey === 'calendar' ? 'calendar' : 'activity-queue')); %>
                  <% const arrSectionLabel = arrSectionKey === 'downloadingSoon'
                    ? 'Downloading Soon'
                    : (arrSectionKey === 'recentlyDownloaded'
                      ? 'Recently Downloaded'
                      : (arrSectionKey === 'calendar' ? 'Calendar' : 'Activity Queue')); %>
                  <% const arrCustomCardId = isUnifiedArrCard ? String(item.arrCombined?.cardId || item.combinedSection || 'card').trim() : ''; %>
                  <% const arrCardToken = isUnifiedArrCard ? String(arrCustomCardId || `legacy-${arrSectionKey}`).trim() : ''; %>
                  <% const combinedArrApps = isUnifiedArrCard
                    ? ((Array.isArray(arrApps) && arrApps.length)
                      ? arrApps
                      : (Array.isArray(apps) ? apps.filter((appItem) => ['radarr', 'sonarr', 'lidarr', 'readarr'].includes(resolveAppBaseId(appItem.id))) : []))
                    : []; %>
                  <% const isUnifiedDownloaderCard = item.combined && (item.combinedType === 'downloader' || item.combinedType === 'downloadercustom'); %>
                  <% const downloaderSectionKey = isUnifiedDownloaderCard ? (item.downloaderCombined?.sectionKey || item.combinedSection || 'activityQueue') : ''; %>
                  <% const downloaderSectionElementId = downloaderSectionKey === 'activityQueue' ? 'activity-queue' : 'activity-queue'; %>
                  <% const downloaderSectionLabel = downloaderSectionKey === 'activityQueue' ? 'Download Queue' : 'Download Queue'; %>
                  <% const isCustomDownloaderCombined = item.combinedType === 'downloadercustom'; %>
                  <% const downloaderCustomCardId = isUnifiedDownloaderCard ? String(item.downloaderCombined?.cardId || item.combinedSection || 'card').trim() : ''; %>
                  <% const downloaderCardToken = isUnifiedDownloaderCard ? String(downloaderCustomCardId || `legacy-${downloaderSectionKey}`).trim() : ''; %>
                  <% const combinedDownloaderApps = isUnifiedDownloaderCard
                    ? ((Array.isArray(downloaderApps) && downloaderApps.length)
                      ? downloaderApps
                      : (Array.isArray(apps) ? apps.filter((appItem) => ['transmission', 'nzbget', 'qbittorrent', 'sabnzbd'].includes(resolveAppBaseId(appItem.id))) : []))
                    : []; %>
                  <% const isUnifiedMediaCard = item.combined && (item.combinedType === 'media' || item.combinedType === 'mediacustom'); %>
                  <% const mediaSectionKey = isUnifiedMediaCard ? (item.mediaCombined?.sectionKey || item.combinedSection || 'active') : ''; %>
                  <% const mediaSectionLabel = mediaSectionKey === 'recent' ? 'Recently Added' : 'Active Streams'; %>
                  <% const isCustomMediaCombined = item.combinedType === 'mediacustom'; %>
                  <% const mediaCustomCardId = isUnifiedMediaCard ? (item.mediaCombined?.cardId || item.combinedSection || 'card') : ''; %>
                  <% const mediaCardToken = isUnifiedMediaCard ? String(mediaCustomCardId || `legacy-${mediaSectionKey}`).trim() : ''; %>
                  <% const isUnifiedCard = isUnifiedMediaCard || isUnifiedArrCard || isUnifiedDownloaderCard; %>
                  <% const combinedMediaApps = isUnifiedMediaCard
                    ? ((Array.isArray(mediaApps) && mediaApps.length)
                      ? mediaApps
                      : (Array.isArray(apps) ? apps.filter((appItem) => ['plex', 'jellyfin', 'emby'].includes(appItem.id)) : []))
                    : []; %>
                  <% const unifiedOverviewApps = isUnifiedMediaCard
                    ? combinedMediaApps
                    : (isUnifiedArrCard ? combinedArrApps : (isUnifiedDownloaderCard ? combinedDownloaderApps : [])); %>
                  <% const unifiedOverviewPrefix = isUnifiedMediaCard
                    ? 'media'
                    : (isUnifiedArrCard ? 'arr' : (isUnifiedDownloaderCard ? 'downloader' : '')); %>
                  <% const unifiedSectionKey = isUnifiedMediaCard
                    ? mediaSectionKey
                    : (isUnifiedArrCard ? arrSectionKey : (isUnifiedDownloaderCard ? downloaderSectionKey : '')); %>
                  <% const unifiedElementId = isUnifiedMediaCard
                    ? mediaSectionKey
                    : (isUnifiedArrCard ? arrSectionElementId : (isUnifiedDownloaderCard ? downloaderSectionElementId : '')); %>
                  <% const unifiedCardToken = isUnifiedMediaCard
                    ? mediaCardToken
                    : (isUnifiedArrCard ? arrCardToken : (isUnifiedDownloaderCard ? downloaderCardToken : '')); %>
                  <% const hasCarouselDisplayOptions = element.id !== 'activity-queue' && element.id !== 'stats' && !isTableCard && !isSpecialtyTable && !item.isWidgetBar; %>
                  <% const showAppDisplayOptionsInFilter = !item.combined && !item.dashboardIsDeprecated && (isQueue || isTableCard || isSpecialtyTable); %>
                  <% const hasFilterPanel = isUnifiedMediaCard
                    || isUnifiedArrCard
                    || isUnifiedDownloaderCard
                    || showWatchCardsPanel
                    || hasCarouselDisplayOptions
                    || showAppDisplayOptionsInFilter; %>
                  <% const hasOptionsPanel = ((isQueue && !item.combined) && !showAppDisplayOptionsInFilter)
                    || ((!item.combined && isTableCard) && !showAppDisplayOptionsInFilter); %>
                  <% const combinedKey = item.combined ? `combined:${item.combinedType || 'mixed'}:${item.combinedSection || element.id || 'unknown'}` : ''; %>
                  <% const combinedSettings = combinedKey && dashboardCombinedSettings ? dashboardCombinedSettings[combinedKey] : null; %>
                  <% const baseVisibilityRole = item.combined
                    ? resolveCombinedDashboardVisibilityRoleView(combinedSettings, 'user')
                    : normalizeDashboardVisibilityRole(
                      element.dashboardVisibilityRole,
                      (element.enable === false && element.dashboard === false) ? 'disabled' : 'user'
                    ); %>
                  <% const effectiveVisibilityRole = isDisabled ? 'disabled' : baseVisibilityRole; %>
                  <% const rowVisibilityRoles = isDisabled ? [] : normalizeDashboardVisibilityRoleList([], effectiveVisibilityRole); %>
                  <% const rowVisibilitySummary = rowVisibilityRoles.length === 0
                    ? 'Hidden (no roles selected)'
                    : (rowVisibilityRoles.length === dashboardInstanceVisibilityRoles.length
                      ? 'All roles'
                      : dashboardInstanceVisibilityRoles
                        .filter((option) => rowVisibilityRoles.includes(option.value))
                        .map((option) => option.label)
                        .join(', ')); %>
                  <% const combinedPrefix = item.combined ? `dashboard_combined_${item.combinedType || 'mixed'}_${item.combinedSection || element.id}` : `dashboard_${item.appId}_${element.id}`; %>
                  <div class="settings-row settings-row--elements settings-row--with-expand settings-row--draggable <%= item.dashboardIsCurrent ? 'settings-row--card-current' : '' %> <%= item.dashboardIsDeprecated ? 'settings-row--card-deprecated' : '' %> <%= effectiveVisibilityRole === 'disabled' ? 'is-disabled' : '' %>" data-app-id="<%= item.appId %>" data-category="<%= item.category || 'Tools' %>" data-category-rank="<%= categoryRank %>" data-app-access-disabled="<%= isDisabled ? '1' : '0' %>" draggable="true">
                    <div class="settings-element">
                      <button class="order-button settings-drag-handle" type="button" title="Drag to reorder" aria-label="Drag to reorder">&#x2630;</button>
                      <img class="settings-element-icon" src="<%= elementIcon %>" alt="" onerror="this.src='/icons/app.svg'" />
                      <span class="settings-element-name"><%= displayName %></span>
                    </div>
                    <div class="settings-cell settings-cell--visibility settings-col-visibility">
                      <% if (!item.isWidgetBar) { %>
                      <div class="settings-visibility-popover" data-dashboard-visibility-popover>
                        <button
                          class="settings-visibility-trigger"
                          type="button"
                          aria-label="Configure visibility (<%= rowVisibilitySummary %>)"
                          title="<%= rowVisibilitySummary %>"
                          aria-expanded="false"
                          aria-haspopup="true"
                          data-dashboard-visibility-trigger
                          <%= isDisabled ? 'disabled' : '' %>
                        ></button>
                        <div class="settings-visibility-menu settings-filter-menu" hidden>
                          <input type="hidden" name="<%= combinedPrefix %>_visibility_role" value="<%= effectiveVisibilityRole %>" data-dashboard-visibility-role-hidden />
                          <input type="hidden" name="<%= combinedPrefix %>_overview_visibility_role" value="<%= effectiveVisibilityRole %>" data-dashboard-overview-visibility-role-hidden />
                          <input type="hidden" name="<%= combinedPrefix %>_visibility_roles_present" value="1" />
                          <div class="settings-filter-group-title">Visible To Roles</div>
                          <div class="settings-dashboard-role-filter-list">
                            <% dashboardInstanceVisibilityRoles.forEach((option) => { %>
                              <label class="settings-dashboard-role-filter-option">
                                <input
                                  type="checkbox"
                                  name="<%= combinedPrefix %>_visibility_roles"
                                  value="<%= option.value %>"
                                  data-dashboard-visibility-role-checkbox
                                  <%= rowVisibilityRoles.includes(option.value) ? 'checked' : '' %>
                                  <%= isDisabled ? 'disabled' : '' %>
                                />
                                <span class="settings-dashboard-role-filter-option-label"><%= option.label %></span>
                              </label>
                            <% }) %>
                          </div>
                          <div class="settings-users-note settings-dashboard-role-filter-note">No roles selected hides this item from both dashboard and overview.</div>
                        </div>
                      </div>
                      <% } %>
                    </div>
                    <div class="settings-cell settings-cell--visibility settings-col-filter">
                      <% if (hasFilterPanel) { %>
                        <div class="settings-visibility-popover" data-dashboard-filter-popover>
                          <button class="settings-visibility-trigger" type="button" aria-label="Configure filters and display options" aria-expanded="false" aria-haspopup="true" <%= isDisabled ? 'disabled' : '' %>></button>
                          <div class="settings-visibility-menu settings-filter-menu" hidden>
                            <% if (isUnifiedMediaCard) { %>
                              <div class="settings-filter-group-title"><%= mediaSectionLabel %> Apps</div>
                              <div class="settings-unified-source-list">
                                <% combinedMediaApps.forEach((app) => { %>
                                  <% const iconPath = app.icon || (app.id === 'jellyfin'
                                    ? '/icons/jellyfin.png'
                                    : (app.id === 'emby' ? '/icons/emby.png' : '/icons/plex.png')); %>
                                  <% const sourceName = isCustomMediaCombined
                                    ? (`mediacustom_combine_${mediaCustomCardId}_${app.id}`)
                                    : (`media_combine_${mediaSectionKey}_${app.id}`); %>
                                  <% const sourceEnabled = isCustomMediaCombined
                                    ? (Array.isArray(item.mediaCombined?.appIds) && item.mediaCombined.appIds.includes(app.id))
                                    : Boolean(mediaDashboardCombine?.[mediaSectionKey]?.[app.id]); %>
                                  <div class="settings-unified-source-row settings-unified-source-row--source">
                                    <label class="settings-unified-source-toggle" aria-label="Toggle source for <%= app.name %>">
                                      <input
                                        type="checkbox"
                                        name="<%= sourceName %>"
                                        data-combined-source-toggle
                                        data-media-source-toggle
                                        data-media-app-id="<%= app.id %>"
                                        data-combined-source-app-id="<%= app.id %>"
                                        <%= sourceEnabled ? 'checked' : '' %>
                                      />
                                    </label>
                                    <div class="settings-unified-source-app">
                                      <img class="settings-combined-icon" src="<%= iconPath %>" alt="" onerror="this.src='/icons/app.svg'" />
                                      <span class="settings-combined-name"><%= app.name %></span>
                                    </div>
                                  </div>
                                <% }) %>
                              </div>
                            <% } %>
                            <% if (isUnifiedArrCard) { %>
                              <div class="settings-filter-group-title">Combined <%= arrSectionLabel %> Sources</div>
                              <div class="settings-unified-source-list">
                                <% combinedArrApps.forEach((app) => { %>
                                  <% const arrIconPath = resolveAppIconPath(app); %>
                                  <% const arrSourceName = isCustomArrCombined
                                    ? (`arrcustom_combine_${arrCustomCardId}_${app.id}`)
                                    : (`arr_combine_${arrSectionKey}_${app.id}`); %>
                                  <% const arrSourceEnabled = isCustomArrCombined
                                    ? (Array.isArray(item.arrCombined?.appIds) && item.arrCombined.appIds.includes(app.id))
                                    : Boolean(arrDashboardCombine?.[arrSectionKey]?.[app.id]); %>
                                  <div class="settings-unified-source-row settings-unified-source-row--source">
                                    <label class="settings-unified-source-toggle" aria-label="Toggle source for <%= app.name %>">
                                      <input
                                        type="checkbox"
                                        name="<%= arrSourceName %>"
                                        data-combined-source-toggle
                                        data-combined-source-app-id="<%= app.id %>"
                                        <%= arrSourceEnabled ? 'checked' : '' %>
                                      />
                                    </label>
                                    <div class="settings-unified-source-app">
                                      <img class="settings-combined-icon" src="<%= arrIconPath %>" alt="" onerror="this.src='/icons/app.svg'" />
                                      <span class="settings-combined-name"><%= app.name %></span>
                                    </div>
                                  </div>
                                <% }) %>
                              </div>
                              <% if (arrSectionKey === 'activityQueue') { %>
                                <div class="settings-filter-group-title">Combined Queue Display Options</div>
                                <div class="settings-grid">
                                  <label class="radio-pill">
                                    <input type="checkbox" name="arr_combined_queue_col_detail" <%= arrCombinedQueueDisplay?.queueShowDetail !== false ? 'checked' : '' %> />
                                    <span>Detail</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="arr_combined_queue_col_subdetail" <%= arrCombinedQueueDisplay?.queueShowSubDetail !== false ? 'checked' : '' %> />
                                    <span>Sub-detail</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="arr_combined_queue_col_size" <%= arrCombinedQueueDisplay?.queueShowSize !== false ? 'checked' : '' %> />
                                    <span>Quality</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="arr_combined_queue_col_protocol" <%= arrCombinedQueueDisplay?.queueShowProtocol !== false ? 'checked' : '' %> />
                                    <span>Protocol</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="arr_combined_queue_col_timeleft" <%= arrCombinedQueueDisplay?.queueShowTimeLeft !== false ? 'checked' : '' %> />
                                    <span>Time Left</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="arr_combined_queue_col_progress" <%= arrCombinedQueueDisplay?.queueShowProgress !== false ? 'checked' : '' %> />
                                    <span>Progress</span>
                                  </label>
                                </div>
                                <div class="settings-grid" style="margin-top:12px;">
                                  <label class="field">
                                    <span>Visible items in queue</span>
                                    <input
                                      type="number"
                                      min="5"
                                      max="50"
                                      step="1"
                                      name="arr_combined_queue_visible_rows"
                                      value="<%= arrCombinedQueueDisplay?.queueVisibleRows || 10 %>"
                                    />
                                  </label>
                                </div>
                              <% } %>
                            <% } %>
                            <% if (isUnifiedDownloaderCard) { %>
                              <div class="settings-filter-group-title">Combined <%= downloaderSectionLabel %> Sources</div>
                              <div class="settings-unified-source-list">
                                <% combinedDownloaderApps.forEach((app) => { %>
                                  <% const downloaderSourceName = isCustomDownloaderCombined
                                    ? (`downloadercustom_combine_${downloaderCustomCardId}_${app.id}`)
                                    : (`downloader_combine_${downloaderSectionKey}_${app.id}`); %>
                                  <% const downloaderSourceEnabled = isCustomDownloaderCombined
                                    ? (Array.isArray(item.downloaderCombined?.appIds) && item.downloaderCombined.appIds.includes(app.id))
                                    : Boolean(downloaderDashboardCombine?.[downloaderSectionKey]?.[app.id]); %>
                                  <div class="settings-unified-source-row settings-unified-source-row--source">
                                    <label class="settings-unified-source-toggle" aria-label="Toggle source for <%= app.name %>">
                                      <input
                                        type="checkbox"
                                        name="<%= downloaderSourceName %>"
                                        data-combined-source-toggle
                                        data-combined-source-app-id="<%= app.id %>"
                                        <%= downloaderSourceEnabled ? 'checked' : '' %>
                                      />
                                    </label>
                                    <div class="settings-unified-source-app">
                                      <img class="settings-combined-icon" src="<%= resolveAppIconPath(app) %>" alt="" onerror="this.src='/icons/app.svg'" />
                                      <span class="settings-combined-name"><%= app.name %></span>
                                    </div>
                                  </div>
                                <% }) %>
                              </div>
                              <% if (downloaderSectionKey === 'activityQueue') { %>
                                <div class="settings-filter-group-title">Combined Download Queue Display Options</div>
                                <div class="settings-grid">
                                  <label class="radio-pill">
                                    <input type="checkbox" name="downloader_combined_queue_col_detail" <%= downloaderCombinedQueueDisplay?.queueShowDetail !== false ? 'checked' : '' %> />
                                    <span>Source</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="downloader_combined_queue_col_subdetail" <%= downloaderCombinedQueueDisplay?.queueShowSubDetail !== false ? 'checked' : '' %> />
                                    <span>Detail</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="downloader_combined_queue_col_size" <%= downloaderCombinedQueueDisplay?.queueShowSize !== false ? 'checked' : '' %> />
                                    <span>Size</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="downloader_combined_queue_col_protocol" <%= downloaderCombinedQueueDisplay?.queueShowProtocol !== false ? 'checked' : '' %> />
                                    <span>Protocol</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="downloader_combined_queue_col_timeleft" <%= downloaderCombinedQueueDisplay?.queueShowTimeLeft !== false ? 'checked' : '' %> />
                                    <span>Time Left</span>
                                  </label>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="downloader_combined_queue_col_progress" <%= downloaderCombinedQueueDisplay?.queueShowProgress !== false ? 'checked' : '' %> />
                                    <span>Progress</span>
                                  </label>
                                </div>
                                <div class="settings-grid" style="margin-top:12px;">
                                  <label class="field">
                                    <span>Visible items in queue</span>
                                    <input
                                      type="number"
                                      min="5"
                                      max="50"
                                      step="1"
                                      name="downloader_combined_queue_visible_rows"
                                      value="<%= downloaderCombinedQueueDisplay?.queueVisibleRows || 10 %>"
                                    />
                                  </label>
                                </div>
                              <% } %>
                            <% } %>
                            <% if (showWatchCardsPanel) { %>
                              <div class="settings-filter-group-title">Watch Statistics View</div>
                              <div class="settings-grid">
                                <label class="radio-pill">
                                  <input type="radio" name="dashboard_<%= item.appId %>_<%= element.id %>_tautulli_stats_view" value="list" <%= tautulliStatsView !== 'wheel' ? 'checked' : '' %> />
                                  <span>List View</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="radio" name="dashboard_<%= item.appId %>_<%= element.id %>_tautulli_stats_view" value="wheel" <%= tautulliStatsView === 'wheel' ? 'checked' : '' %> />
                                  <span>Wheel View</span>
                                </label>
                              </div>
                              <div class="settings-filter-group-title">Watch Statistics Cards</div>
                              <div class="settings-table settings-table--tautulli-cards">
                                <% tautulliItems.forEach((item, cardIndex) => { %>
                                  <% const orderValue = Number.isFinite(item.order) ? item.order : cardIndex + 1; %>
                                  <div class="settings-row settings-row--tautulli-cards settings-row--tautulli-inline settings-row--draggable">
                                    <button class="order-button settings-drag-handle settings-drag-handle--tautulli-inline" type="button" title="Drag to reorder" aria-label="Drag to reorder">&#x2630;</button>
                                    <label class="settings-tautulli-inline-toggle" aria-label="Enable <%= item.name %>">
                                      <input type="checkbox" name="dashboard_tautulli_card_enable_<%= element.id %>_<%= item.id %>" <%= item.enable ? 'checked' : '' %> />
                                    </label>
                                    <span class="settings-element-name settings-element-name--tautulli-inline"><%= item.name %></span>
                                    <input type="hidden" class="settings-order-input" name="dashboard_tautulli_card_order_<%= element.id %>_<%= item.id %>" value="<%= orderValue %>" />
                                  </div>
                                <% }) %>
                              </div>
                            <% } %>
                            <% if (showAppDisplayOptionsInFilter && isQueue) { %>
                              <div class="settings-filter-group-title">Queue Display Options</div>
                              <div class="settings-grid">
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_detail" <%= element.queueShowDetail !== false ? 'checked' : '' %> />
                                  <span><%= element.queueDetailLabel || 'Detail' %></span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_subdetail" <%= element.queueShowSubDetail !== false ? 'checked' : '' %> />
                                  <span><%= element.queueSubDetailLabel || 'Sub-detail' %></span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_size" <%= element.queueShowSize !== false ? 'checked' : '' %> />
                                  <span><%= ['transmission', 'nzbget', 'qbittorrent', 'sabnzbd'].includes(resolveAppBaseId(item.appId)) ? 'Size' : 'Quality' %></span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_protocol" <%= element.queueShowProtocol !== false ? 'checked' : '' %> />
                                  <span>Protocol</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_timeLeft" <%= element.queueShowTimeLeft !== false ? 'checked' : '' %> />
                                  <span>Time Left</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_progress" <%= element.queueShowProgress !== false ? 'checked' : '' %> />
                                  <span>Progress</span>
                                </label>
                              </div>
                              <div class="settings-grid" style="margin-top:12px;">
                                <label class="field">
                                  <span>Visible items in queue</span>
                                  <input
                                    type="number"
                                    min="5"
                                    max="50"
                                    step="1"
                                    name="dashboard_<%= item.appId %>_<%= element.id %>_queue_visible_rows"
                                    value="<%= element.queueVisibleRows || 10 %>"
                                  />
                                </label>
                              </div>
                            <% } else if (showAppDisplayOptionsInFilter && isTableCard) { %>
                              <% const isIndexerSearch = element.id === 'search'; %>
                              <div class="settings-filter-group-title">Table Display Options</div>
                              <div class="settings-grid">
                                <label class="field">
                                  <span><%= isIndexerSearch ? 'Visible items in table' : 'Visible items in queue' %></span>
                                  <input
                                    type="number"
                                    min="5"
                                    max="<%= isIndexerSearch ? 100 : 50 %>"
                                    step="1"
                                    name="dashboard_<%= item.appId %>_<%= element.id %>_queue_visible_rows"
                                    value="<%= element.queueVisibleRows || (isIndexerSearch ? 25 : 10) %>"
                                  />
                                </label>
                              </div>
                            <% } else if (showAppDisplayOptionsInFilter && isSpecialtyTable) { %>
                              <%
                                const spAppBaseId = resolveAppBaseId(item.appId);
                                const spCols = (() => {
                                  if (spAppBaseId === 'metube' && element.id === 'queue') return { detail: 'Status', timeLeft: 'ETA', progress: 'Progress' };
                                  if (spAppBaseId === 'wizarr' && element.id === 'users') return { detail: 'Role', size: 'Created', timeLeft: 'Expires' };
                                  if (spAppBaseId === 'wizarr' && element.id === 'invitations') return { detail: 'Uses', protocol: 'Expires', timeLeft: 'Created' };
                                  if (spAppBaseId === 'uptime-kuma' && element.id === 'status') return { detail: 'Status', timeLeft: 'Uptime', progress: 'History' };
                                  if (spAppBaseId === 'guacamole' && element.id === 'active-sessions') return { detail: 'User', protocol: 'Protocol', timeLeft: 'Started' };
                                  if (spAppBaseId === 'guacamole' && element.id === 'connections') return { detail: 'Protocol', size: 'Active' };
                                  if (spAppBaseId === 'traefik' && element.id === 'routers') return { detail: 'Status', protocol: 'Entrypoints', timeLeft: 'Service' };
                                  if (spAppBaseId === 'traefik' && element.id === 'services') return { detail: 'Status', protocol: 'Type', size: 'Servers' };
                                  return {};
                                })();
                              %>
                              <div class="settings-filter-group-title">Table Display Options</div>
                              <div class="settings-grid">
                                <% if (spCols.detail) { %>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_detail" <%= element.queueShowDetail !== false ? 'checked' : '' %> />
                                    <span><%= spCols.detail %></span>
                                  </label>
                                <% } %>
                                <% if (spCols.size) { %>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_size" <%= element.queueShowSize !== false ? 'checked' : '' %> />
                                    <span><%= spCols.size %></span>
                                  </label>
                                <% } %>
                                <% if (spCols.protocol) { %>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_protocol" <%= element.queueShowProtocol !== false ? 'checked' : '' %> />
                                    <span><%= spCols.protocol %></span>
                                  </label>
                                <% } %>
                                <% if (spCols.timeLeft) { %>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_timeLeft" <%= element.queueShowTimeLeft !== false ? 'checked' : '' %> />
                                    <span><%= spCols.timeLeft %></span>
                                  </label>
                                <% } %>
                                <% if (spCols.progress) { %>
                                  <label class="radio-pill">
                                    <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_progress" <%= element.queueShowProgress !== false ? 'checked' : '' %> />
                                    <span><%= spCols.progress %></span>
                                  </label>
                                <% } %>
                              </div>
                              <div class="settings-grid" style="margin-top:12px;">
                                <label class="field">
                                  <span>Visible items in table</span>
                                  <input
                                    type="number"
                                    min="5"
                                    max="50"
                                    step="1"
                                    name="dashboard_<%= item.appId %>_<%= element.id %>_queue_visible_rows"
                                    value="<%= element.queueVisibleRows || 10 %>"
                                  />
                                </label>
                              </div>
                            <% } %>
                            <% if (hasCarouselDisplayOptions) { %>
                              <div class="settings-filter-group-title">Carousel Display</div>
                              <div class="settings-grid">
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_showSubtitle" <%= element.showSubtitle !== false ? 'checked' : '' %> />
                                  <span>Subtitle</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_showMeta" <%= element.showMeta !== false ? 'checked' : '' %> />
                                  <span>Meta</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_showPill" <%= element.showPill !== false ? 'checked' : '' %> />
                                  <span>Pill</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_showTypeIcon" <%= element.showTypeIcon !== false ? 'checked' : '' %> />
                                  <span>Type Icon</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_showViewIcon" <%= element.showViewIcon !== false ? 'checked' : '' %> />
                                  <span>View Icon</span>
                                </label>
                                <label class="radio-pill">
                                  <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_showUsername" <%= element.showUsername !== false ? 'checked' : '' %> />
                                  <span>Username</span>
                                </label>
                              </div>
                            <% } %>
                          </div>
                        </div>
                      <% } %>
                    </div>
                    <% const orderName = item.combined ? `dashboard_combined_${item.combinedType || 'mixed'}_${item.combinedSection || element.id}_order` : `dashboard_${item.appId}_${element.id}_order`; %>
                    <input type="hidden" class="settings-order-input" name="<%= orderName %>" value="<%= orderValue %>" />
                    <% if (item.combined) { %>
                      <input type="hidden" name="<%= combinedPrefix %>_present" value="1" />
                    <% } else { %>
                      <input type="hidden" name="dashboard_<%= item.appId %>_<%= element.id %>_present" value="1" />
                    <% } %>
                    <div class="settings-cell settings-delete-cell">
                      <button
                        class="order-button default-app-delete settings-dashboard-delete"
                        type="button"
                        data-dashboard-element-key="<%= item.dashboardElementKey || '' %>"
                        title="Remove dashboard item"
                        aria-label="Remove dashboard item"
                        <%= canRemoveDashboardItem ? '' : 'disabled' %>
                      >&times;</button>
                    </div>
                  </div>
                  <div class="settings-collapsible is-collapsed settings-inline-collapsible" id="dashboardOptions-<%= rowKey %>">
                    <div class="settings-card">
                      <fieldset class="settings-card-fields" <%= isDisabled ? 'disabled' : '' %>>
                      <% if ((isQueue && !item.combined) && !showAppDisplayOptionsInFilter) { %>
                        <div class="settings-card-title">Queue Display Options</div>
                        <div class="settings-grid">
                          <label class="radio-pill">
                            <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_detail" <%= element.queueShowDetail !== false ? 'checked' : '' %> />
                            <span><%= element.queueDetailLabel || 'Detail' %></span>
                          </label>
                          <label class="radio-pill">
                            <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_subdetail" <%= element.queueShowSubDetail !== false ? 'checked' : '' %> />
                            <span><%= element.queueSubDetailLabel || 'Sub-detail' %></span>
                          </label>
                          <label class="radio-pill">
                            <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_size" <%= element.queueShowSize !== false ? 'checked' : '' %> />
                            <span><%= ['transmission', 'nzbget', 'qbittorrent', 'sabnzbd'].includes(resolveAppBaseId(item.appId)) ? 'Size' : 'Quality' %></span>
                          </label>
                          <label class="radio-pill">
                            <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_protocol" <%= element.queueShowProtocol !== false ? 'checked' : '' %> />
                            <span>Protocol</span>
                          </label>
                          <label class="radio-pill">
                            <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_timeLeft" <%= element.queueShowTimeLeft !== false ? 'checked' : '' %> />
                            <span>Time Left</span>
                          </label>
                          <label class="radio-pill">
                            <input type="checkbox" name="dashboard_<%= item.appId %>_<%= element.id %>_queue_col_progress" <%= element.queueShowProgress !== false ? 'checked' : '' %> />
                            <span>Progress</span>
                          </label>
                        </div>
                        <div class="settings-grid" style="margin-top:12px;">
                          <label class="field">
                            <span>Visible items in queue</span>
                            <input
                              type="number"
                              min="5"
                              max="50"
                              step="1"
                              name="dashboard_<%= item.appId %>_<%= element.id %>_queue_visible_rows"
                              value="<%= element.queueVisibleRows || 10 %>"
                            />
                          </label>
                        </div>
                      <% } else if ((!item.combined && isTableCard) && !showAppDisplayOptionsInFilter) { %>
                        <% const isIndexerSearch = element.id === 'search'; %>
                        <div class="settings-card-title">Table Display Options</div>
                        <div class="settings-grid">
                          <label class="field">
                            <span><%= isIndexerSearch ? 'Visible items in table' : 'Visible items in queue' %></span>
                            <input
                              type="number"
                              min="5"
                              max="<%= isIndexerSearch ? 100 : 50 %>"
                              step="1"
                              name="dashboard_<%= item.appId %>_<%= element.id %>_queue_visible_rows"
                              value="<%= element.queueVisibleRows || (isIndexerSearch ? 25 : 10) %>"
                            />
                          </label>
                        </div>
                      <% } %>
                      </fieldset>
                    </div>
                  </div>
                <% }) %>
              </div>
              <%
                const dashboardAddResultMap = {
                  added: 'Dashboard card added.',
                  removed: 'Dashboard card removed. Re-add it from the list below.',
                };
                const dashboardAddResult = String(dashboardElementResult || arrCombinedCardResult || '').trim();
                const dashboardAddError = String(dashboardElementError || arrCombinedCardError || '').trim();
                const dashboardAddNotice = dashboardAddError
                  ? dashboardAddError
                  : (dashboardAddResultMap[dashboardAddResult] || '');
                const dashboardCurrentEntries = Array.isArray(dashboardAddOptions) ? dashboardAddOptions : [];
                const groupDashboardEntries = (entries) => entries.reduce((acc, entry) => {
                  const groupName = String(entry?.group || 'Cards').trim() || 'Cards';
                  if (!acc[groupName]) acc[groupName] = [];
                  acc[groupName].push(entry);
                  return acc;
                }, {});
                const dashboardCurrentGroups = groupDashboardEntries(dashboardCurrentEntries);
              %>
              <div class="category-manager-add app-manager-add dashboard-add-row" id="dashboardAddFormDeprecated" data-dashboard-add-form>
                <div class="icon-picker dashboard-add-picker" data-dashboard-add-picker>
                  <button class="settings-select icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                    <span class="icon-picker-preview" aria-hidden="true"></span>
                    <span class="icon-picker-label">Select dashboard card</span>
                  </button>
                  <div class="icon-picker-menu" role="listbox" aria-label="Dashboard card">
                    <% if (dashboardCurrentEntries.length) { %>
                      <% Object.keys(dashboardCurrentGroups).forEach((groupName) => { %>
                        <div class="icon-picker-group-label"><%= groupName %></div>
                        <% dashboardCurrentGroups[groupName].forEach((entry) => { %>
                          <% const addDisabled = Boolean(entry?.disabled); %>
                          <button
                            class="icon-picker-option<%= addDisabled ? ' is-disabled' : '' %>"
                            type="button"
                            role="option"
                            data-dashboard-add-option
                            data-value="<%= entry.key %>"
                            data-label="<%= entry.name %>"
                            data-preview="<%= entry.icon || '/icons/app.svg' %>"
                            data-disabled="<%= addDisabled ? '1' : '0' %>"
                            <%= addDisabled ? 'disabled aria-disabled="true"' : '' %>
                          >
                            <img class="icon-picker-icon" src="<%= entry.icon || '/icons/app.svg' %>" alt="" onerror="this.src='/icons/app.svg'" />
                            <span class="icon-picker-option-label"><%= entry.name %></span>
                          </button>
                        <% }) %>
                      <% }) %>
                    <% } else { %>
                      <div class="icon-picker-empty">No current dashboard cards available</div>
                    <% } %>
                  </div>
                  <input type="hidden" name="dashboard_add_key_current" id="dashboardAddKeySelectDeprecated" data-dashboard-add-key value="" />
                </div>
                <button class="primary-button dashboard-add-btn" type="submit" formaction="/settings/dashboard/add" formmethod="post" <%= dashboardCurrentEntries.length ? '' : 'disabled' %>>Add Dashboard Card</button>
              </div>
              <% if (dashboardAddNotice) { %>
                <span class="settings-users-note<%= dashboardAddError ? ' settings-users-note--error' : '' %>"><%= dashboardAddNotice %></span>
              <% } %>
              <button class="primary-button" type="submit">Save dashboard settings</button>
            </form>
          </div>
          <div class="settings-subtab-panel" data-subtab="widgets">
            <div class="settings-card">
              <div class="settings-card-title">Widget Bars</div>
              <p class="settings-users-note">Widget bars show live stat cards on the dashboard. Build each bar below, then add it via the Dashboard tab to set its position.</p>
              <script>window._widgetBarApps = <%- JSON.stringify((widgetBarApps || []).map(function(a) { return { id: a.id, name: a.name, icon: a.icon, typeId: a.typeId, metricFields: Array.isArray(a.metricFields) ? a.metricFields : [] }; })) %>;</script>
              <script>window._widgetBarSystemIcons = <%- JSON.stringify([].concat(Array.isArray(systemIconDefaults) ? systemIconDefaults : [], Array.isArray(systemIconCustom) ? systemIconCustom : [])) %>;</script>
              <script>window._systemWidgetTypes = <%- JSON.stringify(Array.isArray(systemWidgetTypes) ? systemWidgetTypes : []) %>;</script>
              <script>window._systemWidgetSearchProviders = <%- JSON.stringify(Array.isArray(systemWidgetSearchProviders) ? systemWidgetSearchProviders : []) %>;</script>
              <script>window._systemWidgetTimezones = <%- JSON.stringify(Array.isArray(systemWidgetTimezones) ? systemWidgetTimezones : []) %>;</script>
              <div class="widget-manager-canvas" id="widgetManagerCanvas">
                <% widgetBars.forEach(function(bar) { %>
                  <%
                    const widgetBarRoleOptions = [
                      { value: 'guest', label: 'Guest' },
                      { value: 'user', label: 'User' },
                      { value: 'co-admin', label: 'Co-admin' },
                      { value: 'admin', label: 'Admin' },
                    ];
                    const widgetBarVisibilityRoles = Array.isArray(bar.visibilityRoles)
                      ? ['guest', 'user', 'co-admin', 'admin'].filter(function(role) { return bar.visibilityRoles.includes(role); })
                      : (function() {
                          const minRole = String(bar.visibilityRole || 'user').trim().toLowerCase();
                          const roleOrder = ['guest', 'user', 'co-admin', 'admin'];
                          const idx = roleOrder.indexOf(minRole);
                          return idx >= 0 ? roleOrder.slice(idx) : ['user', 'co-admin', 'admin'];
                        })();
                    const widgetBarRefreshOption = [0, 30, 60, 120].includes(Number(bar.refreshSeconds)) ? Number(bar.refreshSeconds) : 60;
                    const widgetBarIconValue = String(bar.icon || '/icons/dashboard.svg').trim() || '/icons/dashboard.svg';
                  %>
                  <div class="widget-bar-canvas-row" data-bar-id="<%= bar.id %>">
                    <div class="widget-bar-canvas-header">
                      <div class="icon-picker widget-bar-canvas-icon-picker" data-widget-bar-icon-picker>
                        <button class="widget-bar-canvas-icon-trigger icon-picker-trigger" type="button" aria-haspopup="listbox" aria-expanded="false" aria-label="Select widget bar icon" title="Select widget bar icon">
                          <span class="icon-picker-preview" aria-hidden="true">
                            <img src="<%= widgetBarIconValue %>" alt="" onerror="this.src='/icons/dashboard.svg'" />
                          </span>
                        </button>
                        <div class="icon-picker-menu" role="listbox" aria-label="Widget bar icon"></div>
                        <input type="hidden" value="<%= widgetBarIconValue %>" data-bar-icon />
                      </div>
                      <input class="settings-input widget-bar-canvas-name" type="text" value="<%= bar.name || 'Widget Bar' %>" maxlength="80" aria-label="Widget bar name" data-bar-name />
                      <div class="widget-bar-canvas-header-actions">
                        <button class="order-button default-app-delete widget-bar-canvas-delete" type="button" data-bar-delete="<%= bar.id %>" aria-label="Delete widget bar" title="Delete widget bar">
                          <img class="widget-bar-canvas-delete-icon" src="/icons/delete.svg" alt="" />
                        </button>
                        <div class="widget-bar-canvas-role-filter settings-dashboard-role-filter settings-visibility-popover" data-widget-bar-role-filter>
                          <button class="settings-visibility-trigger settings-dashboard-role-filter-trigger" type="button" aria-label="Configure widget bar visibility" aria-haspopup="true" aria-expanded="false" data-widget-bar-role-filter-trigger></button>
                          <div class="settings-visibility-menu settings-filter-menu settings-dashboard-role-filter-menu" hidden data-widget-bar-role-filter-menu>
                            <div class="settings-filter-group-title">Visible To Roles</div>
                            <div class="settings-dashboard-role-filter-list">
                              <% widgetBarRoleOptions.forEach(function(option) { %>
                                <label class="settings-dashboard-role-filter-option">
                                  <input type="checkbox" data-bar-role-value="<%= option.value %>" <%= widgetBarVisibilityRoles.includes(option.value) ? 'checked' : '' %> />
                                  <span class="settings-dashboard-role-filter-option-label"><%= option.label %></span>
                                </label>
                              <% }) %>
                            </div>
                            <div class="settings-users-note settings-dashboard-role-filter-note">No roles selected hides this widget bar.</div>
                          </div>
                        </div>
                        <select class="settings-select widget-bar-canvas-refresh widget-bar-canvas-refresh-select" aria-label="Refresh interval" data-bar-refresh title="Refresh interval">
                          <option value="0" <%= widgetBarRefreshOption === 0 ? 'selected' : '' %>>Off</option>
                          <option value="30" <%= widgetBarRefreshOption === 30 ? 'selected' : '' %>>30s</option>
                          <option value="60" <%= widgetBarRefreshOption === 60 ? 'selected' : '' %>>60s</option>
                          <option value="120" <%= widgetBarRefreshOption === 120 ? 'selected' : '' %>>120s</option>
                        </select>
                        <button class="plex-iconbtn widget-bar-canvas-scroll-nav widget-bar-canvas-scroll-prev" type="button" data-widget-bar-scroll-prev aria-label="Previous" title="Previous">
                          <div class="plex-chev plex-left" aria-hidden="true"></div>
                        </button>
                        <button class="plex-iconbtn widget-bar-canvas-scroll-nav widget-bar-canvas-scroll-next" type="button" data-widget-bar-scroll-next aria-label="Next" title="Next">
                          <div class="plex-chev plex-right" aria-hidden="true"></div>
                        </button>
                        <button class="plex-iconbtn widget-bar-canvas-collapse" type="button"
                          data-bar-collapse-toggle="<%= bar.id %>"
                          aria-expanded="true"
                          aria-label="Collapse widget bar"
                          title="Collapse widget bar">
                          <div class="plex-doublechev" aria-hidden="true">
                            <div class="plex-chev plex-up"></div>
                            <div class="plex-chev plex-down"></div>
                          </div>
                        </button>
                        <button class="primary-button widget-bar-canvas-save" type="button" data-bar-save="<%= bar.id %>">Save</button>
                      </div>
                    </div>
                    <div class="widget-bar-rows-wrap" data-rows-wrap>
                      <div class="widget-bar-row-add-strip widget-bar-row-add-strip--top">
                        <button class="secondary-button widget-bar-add-row-btn" type="button"
                          data-bar-add-row="<%= bar.id %>"
                          data-bar-add-row-position="top"
                          aria-label="Add row above"
                          title="Add row above">&#8593;</button>
                      </div>
                      <% (bar.rows || []).forEach(function(row) { %>
                        <div class="widget-bar-row" data-row-id="<%= row.id %>" data-bar-id="<%= bar.id %>">
                          <%
                            const rowPreviewSettings = row.settings || {};
                            const rowPreviewClasses = ['widget-bar-row-body',
                              rowPreviewSettings.fixedWidth ? 'row--fixed-width' : '',
                              rowPreviewSettings.scroll ? 'row--scroll' : '',
                              rowPreviewSettings.fill ? 'row--fill' : '',
                            ].filter(Boolean).join(' ');
                            const rowPreviewMaxCols = rowPreviewSettings.maxCols > 0 ? rowPreviewSettings.maxCols : 0;
                          %>
                          <div class="widget-bar-row-settings-slot">
                            <button class="widget-bar-row-settings-btn" type="button"
                              data-row-settings-toggle="<%= row.id %>"
                              aria-label="Row settings" title="Row settings">&#8250;</button>
                            <div class="widget-bar-row-settings-panel" hidden data-row-settings-panel="<%= row.id %>">
                              <div class="widget-bar-row-settings-inner">
                                <label class="widget-row-settings-label">
                                  Max columns
                                  <input type="number" min="0" max="20"
                                    value="<%= (row.settings && row.settings.maxCols) || 0 %>"
                                    data-row-setting="maxCols"
                                    class="settings-input widget-row-settings-num" />
                                  <span class="muted-hint">0 = unlimited</span>
                                </label>
                                <label class="widget-row-settings-check">
                                  <input type="checkbox" data-row-setting="fixedWidth"
                                    <%= (row.settings && row.settings.fixedWidth) ? 'checked' : '' %>>
                                  Fixed width
                                </label>
                                <label class="widget-row-settings-check">
                                  <input type="checkbox" data-row-setting="scroll"
                                    <%= (row.settings && row.settings.scroll) ? 'checked' : '' %>>
                                  Scroll (no wrap)
                                </label>
                                <label class="widget-row-settings-check">
                                  <input type="checkbox" data-row-setting="fill"
                                    <%= (row.settings && row.settings.fill) ? 'checked' : '' %>>
                                  Fill row width
                                </label>
                                <div class="widget-row-settings-actions">
                                  <button class="primary-button widget-row-settings-apply" type="button"
                                    data-row-settings-apply
                                    data-bar-id="<%= bar.id %>"
                                    data-row-id="<%= row.id %>">Apply</button>
                                  <button class="secondary-button widget-row-delete-btn" type="button"
                                    data-row-delete
                                    data-bar-id="<%= bar.id %>"
                                    data-row-id="<%= row.id %>">Delete Row</button>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="<%= rowPreviewClasses %>" data-bar-body data-row-id="<%= row.id %>"<% if (rowPreviewMaxCols > 0) { %> style="--row-max-cols: <%= rowPreviewMaxCols %>"<% } %>>
                            <% (row.widgets || []).forEach(function(widget) { %>
                              <% if (widget.systemType) { %>
                                <div class="widget-canvas-card widget-canvas-system-chip"
                                  draggable="true"
                                  data-widget-id="<%= widget.id %>"
                                  data-system-type="<%= widget.systemType %>"
                                  data-system-config="<%= JSON.stringify(widget.systemConfig || {}) %>">
                                  <img class="system-chip-icon" src="<%= widget.icon || '/icons/app.svg' %>" alt="" onerror="this.src='/icons/app.svg'" />
                                  <%
                                    const _sysCfg = (widget.systemConfig && typeof widget.systemConfig === 'object') ? widget.systemConfig : {};
                                    const _sysSummary = widget.systemType === 'sys-resources'
                                      ? [
                                        _sysCfg.cpu !== false ? 'CPU' : '',
                                        _sysCfg.memory !== false ? 'RAM' : '',
                                        (Array.isArray(_sysCfg.disks) && _sysCfg.disks.length > 0) ? (_sysCfg.disks.length + ' Disk' + (_sysCfg.disks.length === 1 ? '' : 's')) : '',
                                        _sysCfg.showTotalSpace === true ? 'Total Space' : '',
                                        (_sysCfg.search && _sysCfg.search.enabled) ? 'Search' : '',
                                        (_sysCfg.weather && _sysCfg.weather.enabled) ? 'Weather' : '',
                                      ].filter(Boolean).join(' · ')
                                      : widget.systemType === 'links'
                                        ? [
                                          (Array.isArray(_sysCfg.links) && _sysCfg.links.length > 0) ? (_sysCfg.links.length + ' Link' + (_sysCfg.links.length === 1 ? '' : 's')) : '',
                                          _sysCfg.showUrl === false ? 'Names only' : '',
                                        ].filter(Boolean).join(' · ')
                                      : widget.systemType === 'deployment-summary'
                                        ? (function () {
                                          const _stats = (_sysCfg.stats && typeof _sysCfg.stats === 'object') ? _sysCfg.stats : {};
                                          const _showOnline = _stats.online !== false;
                                          const _showOffline = _stats.offline !== false;
                                          const _showTotal = _stats.total !== false;
                                          const _visible = [_showOnline ? 'Online' : '', _showOffline ? 'Offline' : '', _showTotal ? 'Total' : ''].filter(Boolean);
                                          const _colsRaw = Number(_sysCfg.columns);
                                          const _cols = Number.isFinite(_colsRaw) ? Math.max(1, Math.min(4, Math.round(_colsRaw))) : 3;
                                          return [`${_cols} Col${_cols === 1 ? '' : 's'}`, (_visible.length ? _visible.join(' · ') : 'Online')].filter(Boolean).join(' · ');
                                        })()
                                      : '';
                                  %>
                                  <span class="system-chip-canvas-label">
                                    <%= widget.typeName %>
                                    <% if (_sysSummary) { %><small class="muted-hint"> <%= _sysSummary %></small><% } %>
                                  </span>
                                  <% if (widget.systemType === 'sys-resources' || widget.systemType === 'links' || widget.systemType === 'deployment-summary') { %>
                                    <div class="widget-canvas-system-preview <%= widget.systemType === 'links' ? 'dashboard-links-widget' : (widget.systemType === 'deployment-summary' ? 'deployment-summary-preview' : 'dashboard-system-bar') %>"
                                      data-system-preview
                                      data-system-type="<%= widget.systemType %>"
                                      data-system-config="<%= JSON.stringify(widget.systemConfig || {}) %>"></div>
                                  <% } %>
                                  <% if (widget.systemType !== 'deployment-summary') { %>
                                    <button class="widget-canvas-system-chip-edit" type="button"
                                      data-sys-widget-edit
                                      data-widget-id="<%= widget.id %>"
                                      data-bar-id="<%= bar.id %>"
                                      data-row-id="<%= row.id %>"
                                      data-system-type="<%= widget.systemType %>"
                                      data-system-config="<%= JSON.stringify(widget.systemConfig || {}) %>"
                                      title="Edit config" aria-label="Edit <%= widget.typeName %> config">✎</button>
                                  <% } %>
                                  <button class="widget-canvas-card-remove" type="button"
                                    data-widget-remove-bar="<%= bar.id %>"
                                    data-widget-remove-row="<%= row.id %>"
                                    data-widget-remove-id="<%= widget.id %>"
                                    title="Remove" aria-label="Remove <%= widget.typeName %>">&times;</button>
                                </div>
                              <% } else { %>
                                <%
                                  const widgetSelectedMetricKeys = Array.isArray(widget.selectedMetricKeys)
                                    ? widget.selectedMetricKeys.map(function(k) { return String(k || '').trim().toLowerCase(); }).filter(Boolean)
                                    : null;
                                  const widgetMetricColumns = Number.isFinite(Number(widget.metricColumns)) ? Math.max(1, Math.min(4, Math.round(Number(widget.metricColumns)))) : null;
                                  const widgetSelectedLibraryKeys = (widget.selectedLibraryKeys && typeof widget.selectedLibraryKeys === 'object' && !Array.isArray(widget.selectedLibraryKeys) && Object.keys(widget.selectedLibraryKeys).length) ? widget.selectedLibraryKeys : null;
                                %>
                                <div class="widget-canvas-card dashboard-stat-card is-loading"
                                  draggable="true"
                                  data-widget-id="<%= widget.id %>"
                                  data-app-id="<%= widget.appId %>"
                                  <% if (widgetMetricColumns) { %>data-widget-metric-cols="<%= widgetMetricColumns %>" <% } %>
                                  <% if (widget.typeId) { %>data-widget-type-id="<%= widget.typeId %>" <% } %>
                                  <% if (widgetSelectedMetricKeys !== null) { %>data-has-selected-metric-keys="1" data-selected-metric-keys="<%= widgetSelectedMetricKeys.join(',') %>" <% } %>
                                  <% if (widgetSelectedLibraryKeys) { %>data-selected-library-keys="<%= JSON.stringify(widgetSelectedLibraryKeys) %>" <% } %>>
                                  <div class="stat-card-header">
                                    <img class="stat-card-icon" src="<%= widget.icon || '/icons/app.svg' %>" alt="" onerror="this.src='/icons/app.svg'" />
                                    <span class="stat-card-name"><%= widget.typeName || widget.appId %></span>
                                    <span class="stat-card-status is-unknown">Unknown</span>
                                  </div>
                                  <div class="stat-card-metrics"></div>
                                  <button class="widget-canvas-card-remove" type="button"
                                    data-widget-remove-bar="<%= bar.id %>"
                                    data-widget-remove-row="<%= row.id %>"
                                    data-widget-remove-id="<%= widget.id %>"
                                    title="Remove"
                                    aria-label="Remove <%= widget.typeName || widget.appId %>">&times;</button>
                                </div>
                              <% } %>
                            <% }) %>
                            <div class="widget-canvas-add-slot" data-bar-add-slot="<%= bar.id %>">
                              <button class="widget-canvas-add-btn" type="button"
                                data-bar-add="<%= bar.id %>" data-row-add="<%= row.id %>"
                                aria-label="Add widget to row" aria-haspopup="true">
                                <span class="widget-canvas-add-icon">+</span>
                              </button>
                              <div class="widget-canvas-add-menu" hidden data-add-menu>
                                <div class="widget-canvas-add-group-label">System</div>
                                <% (systemWidgetTypes || []).forEach(function(sysType) { %>
                                  <button class="widget-canvas-add-option" type="button"
                                    data-add-system-type="<%= sysType.typeId %>"
                                    data-has-config="<%= sysType.hasConfig ? '1' : '' %>"
                                    data-bar-id="<%= bar.id %>"
                                    data-row-id="<%= row.id %>">
                                    <img src="<%= sysType.icon %>" alt="" onerror="this.src='/icons/app.svg'" />
                                    <span><%= sysType.label %></span>
                                  </button>
                                <% }) %>
                                <% if (widgetBarApps.length > 0) { %>
                                  <div class="widget-canvas-add-group-label">Apps</div>
                                  <% widgetBarApps.forEach(function(app) { %>
                                    <button class="widget-canvas-add-option" type="button"
                                      data-add-app-id="<%= app.id %>"
                                      data-bar-id="<%= bar.id %>"
                                      data-row-id="<%= row.id %>">
                                      <img src="<%= app.icon %>" alt="" onerror="this.src='/icons/app.svg'" />
                                      <span><%= app.name %></span>
                                    </button>
                                  <% }) %>
                                <% } %>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% }) %>
                      <div class="widget-bar-row-add-strip widget-bar-row-add-strip--bottom">
                        <button class="secondary-button widget-bar-add-row-btn" type="button"
                          data-bar-add-row="<%= bar.id %>"
                          data-bar-add-row-position="bottom"
                          aria-label="Add row below"
                          title="Add row below">&#8595;</button>
                      </div>
                    </div>
                  </div>
                <% }) %>
                <p class="settings-users-note widget-manager-empty" id="widgetBarEmpty"<%= widgetBars.length > 0 ? ' hidden' : '' %>>No widget bars yet. Create your first one below.</p>
              </div>
              <div class="widget-bar-add-row">
                <button class="primary-button" type="button" id="createWidgetBarBtn">+ Add Widget Bar</button>
                <span class="settings-users-note" id="widgetBarCreateStatus" hidden></span>
              </div>
              <div class="widget-card-customize-modal" hidden data-widget-customize-modal>
                <div class="widget-card-customize-backdrop" data-widget-customize-close></div>
                <div class="widget-card-customize-panel" role="dialog" aria-modal="true" aria-labelledby="widgetCardCustomizeTitle">
                  <div class="widget-card-customize-header">
                    <div class="widget-card-customize-title" id="widgetCardCustomizeTitle">Widget Stats</div>
                    <button class="widget-card-customize-close" type="button" data-widget-customize-close aria-label="Close">×</button>
                  </div>
                  <div class="widget-card-customize-subtitle" data-widget-customize-subtitle></div>
                  <label class="widget-card-customize-field">
                    <span>Stat Columns (Wrap)</span>
                    <select class="settings-select" data-widget-customize-metric-cols>
                      <option value="1">1</option>
                      <option value="2">2</option>
                      <option value="3">3</option>
                      <option value="4">4</option>
                    </select>
                  </label>
                  <div class="widget-card-customize-options" data-widget-customize-options></div>
                  <div class="widget-card-customize-empty" hidden data-widget-customize-empty>No configurable stats are available for this widget.</div>
                  <div class="widget-card-customize-actions">
                    <button class="secondary-button" type="button" data-widget-customize-cancel>Cancel</button>
                    <button class="secondary-button" type="button" data-widget-customize-all>Select All</button>
                    <button class="primary-button" type="button" data-widget-customize-apply>Apply</button>
                  </div>
                </div>
              </div>
              <div class="system-widget-config-modal" hidden data-sys-widget-modal>
                <div class="system-widget-config-backdrop" data-sys-widget-modal-close></div>
                <div class="system-widget-config-panel" role="dialog" aria-modal="true" aria-labelledby="sysWidgetModalTitle">
                  <div class="system-widget-config-header">
                    <div class="system-widget-config-title" id="sysWidgetModalTitle">Configure Widget</div>
                    <button class="system-widget-config-close" type="button" data-sys-widget-modal-close aria-label="Close">×</button>
                  </div>
                  <div class="system-widget-config-body" data-sys-widget-modal-body>
                    <!-- Populated by JS -->
                  </div>
                  <div class="system-widget-config-actions">
                    <button class="secondary-button" type="button" data-sys-widget-modal-cancel>Cancel</button>
                    <button class="primary-button" type="button" data-sys-widget-modal-apply>Apply</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="settings-subtab-panel" data-subtab="images">
            <div class="settings-card">
              <div class="settings-card-title">System Icons</div>
              <form method="post" action="/settings/icons/upload" class="settings-form settings-images-form" data-icon-form>
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
                <input type="hidden" name="icon_type" value="system" />
                <input type="hidden" name="icon_data" class="settings-icon-data" />
                <div class="settings-row settings-row--images-upload">
                  <input class="settings-input settings-icon-file" type="file" accept="image/*,.svg" />
                  <input class="settings-input settings-icon-name category-manager-input" type="text" name="icon_name" placeholder="Icon name (required)" required />
                  <button class="primary-button" type="submit">Upload</button>
                </div>
              </form>
              <div class="settings-icon-grid">
                <% (Array.isArray(systemIconDefaults) ? systemIconDefaults : []).forEach((iconPath) => { %>
                  <div class="settings-icon-card">
                    <img src="<%= iconPath %>" alt="" />
                    <span><%= iconPath.split('/').pop() %></span>
                  </div>
                <% }) %>
                <% (Array.isArray(systemIconCustom) ? systemIconCustom : []).forEach((iconPath) => { %>
                  <div class="settings-icon-card settings-icon-card--custom">
                    <img src="<%= iconPath %>" alt="" />
                    <span><%= iconPath.split('/').pop() %></span>
                    <form method="post" action="/settings/icons/delete" class="settings-icon-delete">
                      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
                      <input type="hidden" name="icon_type" value="system" />
                      <input type="hidden" name="icon_path" value="<%= iconPath %>" />
                      <button class="order-button" type="submit" title="Delete icon" aria-label="Delete icon">&times;</button>
                    </form>
                  </div>
                <% }) %>
              </div>
            </div>

            <div class="settings-card">
              <div class="settings-card-title">App Icons</div>
              <form method="post" action="/settings/icons/upload" class="settings-form settings-images-form" data-icon-form>
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
                <input type="hidden" name="icon_type" value="app" />
                <input type="hidden" name="icon_data" class="settings-icon-data" />
                <div class="settings-row settings-row--images-upload">
                  <input class="settings-input settings-icon-file" type="file" accept="image/*,.svg" />
                  <input class="settings-input settings-icon-name category-manager-input" type="text" name="icon_name" placeholder="Icon name (required)" required />
                  <button class="primary-button" type="submit">Upload</button>
                </div>
              </form>
              <div class="settings-icon-grid">
                <% (Array.isArray(appIconDefaults) ? appIconDefaults : []).forEach((iconPath) => { %>
                  <div class="settings-icon-card">
                    <img src="<%= iconPath %>" alt="" />
                    <span><%= iconPath.split('/').pop() %></span>
                  </div>
                <% }) %>
                <% (Array.isArray(appIconCustom) ? appIconCustom : []).forEach((iconPath) => { %>
                  <div class="settings-icon-card settings-icon-card--custom">
                    <img src="<%= iconPath %>" alt="" />
                    <span><%= iconPath.split('/').pop() %></span>
                    <form method="post" action="/settings/icons/delete" class="settings-icon-delete">
                      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
                      <input type="hidden" name="icon_type" value="app" />
                      <input type="hidden" name="icon_path" value="<%= iconPath %>" />
