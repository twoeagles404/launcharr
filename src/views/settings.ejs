        <div class="settings-card">
          <div class="settings-card-title">Releases</div>
          <div class="settings-card-sub">Click a release to view a short changelog summary.</div>
          <% const aboutReleaseEntries = Array.isArray(aboutReleases) ? aboutReleases : []; %>
          <div class="settings-release-list" id="settingsReleaseList">
            <% if (aboutReleaseEntries.length) { %>
              <% aboutReleaseEntries.forEach((release, index) => { %>
                <div class="settings-release-row">
                  <div class="settings-release-copy">
                    <div class="settings-release-head">
                      <span class="settings-release-age" data-release-published-at="<%= release.publishedAt || '' %>">Recently</span>
                      <strong class="settings-release-title">Release <%= release.tag %></strong>
                      <% if (release.isLatest) { %>
                        <span class="settings-about-pill settings-about-pill--ok">Latest</span>
