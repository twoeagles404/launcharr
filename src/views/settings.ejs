    const attachRommSettingsPanelSessionTests = () => {
      const rommButtons = Array.from(document.querySelectorAll('[data-romm-test-session]'));
      if (!rommButtons.length) return;

      const setStatus = (form, mode, message, state = 'info') => {
        const statusEl = form?.querySelector(`[data-romm-test-status="${mode}"]`);
        if (!statusEl) return;
        statusEl.hidden = false;
        statusEl.textContent = String(message || '').trim();
        if (state === 'error') {
          statusEl.style.color = '#ff9b9b';
        } else if (state === 'ok') {
          statusEl.style.color = '#9bf0b0';
        } else {
          statusEl.style.color = '';
        }
      };

      const runTest = async (button) => {
        const mode = String(button?.dataset?.rommTestSession || '').trim().toLowerCase() === 'admin' ? 'admin' : 'viewer';
        const modeLabel = mode === 'admin' ? 'admin' : 'viewer';
        const form = button.closest('form');
        if (!form) return;

        const localUrl = String(form.querySelector('[name="localUrl"]')?.value || '').trim();
        const remoteUrl = String(form.querySelector('[name="remoteUrl"]')?.value || '').trim();
        const username = String(form.querySelector('[name="username"]')?.value || '').trim();
        const password = String(form.querySelector('[name="password"]')?.value || '');
        const viewerUsername = String(form.querySelector('[name="viewerUsername"]')?.value || '').trim();
        const viewerPassword = String(form.querySelector('[name="viewerPassword"]')?.value || '');
        const action = String(form.getAttribute('action') || '');
        const actionMatch = action.match(/\/apps\/([^/]+)\/settings/i);
        const appId = actionMatch ? decodeURIComponent(actionMatch[1]) : 'romm';

        if (mode === 'admin' && (!username || !password)) {
          setStatus(form, mode, 'Romm admin Username/Password (main access fields above) are required before testing.', 'error');
          return;
        }
        if (mode === 'viewer' && (!viewerUsername || !viewerPassword)) {
          setStatus(form, mode, 'Viewer username and password are required before testing.', 'error');
          return;
        }

        try {
          button.disabled = true;
          setStatus(form, mode, `Testing RomM ${modeLabel} session (CSRF + login + /users/me)...`, 'info');
          const response = await fetch('/api/romm/viewer-session-test', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              Accept: 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              appId,
              localUrl,
              remoteUrl,
              username,
              password,
              viewerUsername,
              viewerPassword,
              credentialMode: mode,
              primeBrowser: true,
            }),
          });
          const data = await response.json().catch(() => ({}));
          const ok = Boolean(response.ok && data && data.ok);
          setStatus(
            form,
            mode,
            data?.message || (ok ? `Romm ${modeLabel} session test succeeded.` : `Romm ${modeLabel} session test failed.`),
            ok ? 'ok' : 'error'
          );
          if (!ok) {
            console.error(`[Launcharr] RomM ${modeLabel} session test failed`, data);
          } else {
            console.log(`[Launcharr] RomM ${modeLabel} session test ok`, data);
          }
        } catch (err) {
          console.error(`[Launcharr] RomM ${modeLabel} session test request failed`, err);
          setStatus(form, mode, (err && err.message) ? err.message : `Romm ${modeLabel} session test request failed.`, 'error');
        } finally {
          button.disabled = false;
        }
      };

      rommButtons.forEach((button) => {
        button.addEventListener('click', () => {
          runTest(button).catch((err) => {
            console.error('[Launcharr] RomM settings panel session test error', err);
          });
        });
      });
    };

