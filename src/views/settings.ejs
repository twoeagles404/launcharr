      const getBarScrollRows = (barEl) => Array.from((barEl || document).querySelectorAll('.widget-bar-row-body.row--scroll'));
      const refreshBarScrollButtons = (barId) => {
        const barEl = getBarCanvasEl(barId);
        if (!barEl) return;
        const hasScrollRows = getBarScrollRows(barEl).length > 0;
        const prevBtn = barEl.querySelector('[data-widget-bar-scroll-prev]');
        const nextBtn = barEl.querySelector('[data-widget-bar-scroll-next]');
        if (prevBtn) prevBtn.disabled = !hasScrollRows;
        if (nextBtn) nextBtn.disabled = !hasScrollRows;
      };
      const refreshAllBarScrollButtons = () => {
        if (!canvas) return;
        canvas.querySelectorAll('.widget-bar-canvas-row[data-bar-id]').forEach((barEl) => {
          refreshBarScrollButtons(barEl.dataset.barId || '');
        });
      };
      const scrollBarPreviewRows = (barEl, dir) => {
        if (!barEl) return;
        getBarScrollRows(barEl).forEach((rowEl) => {
          const amount = Math.max(160, Math.round(rowEl.clientWidth * 0.85));
          rowEl.scrollBy({ left: (dir < 0 ? -amount : amount), behavior: 'smooth' });
        });
      };

      const refreshBarAddMenus = (barId) => {
        const barEl = getBarCanvasEl(barId);
        if (!barEl) return;
        const usedAppIds = new Set(
          Array.from(barEl.querySelectorAll('.widget-canvas-card[data-app-id]'))
            .map((card) => normalizeWidgetAppChoiceId(card.dataset.appId))
            .filter(Boolean)
        );
        barEl.querySelectorAll('[data-bar-add-slot]').forEach((slot) => {
          const addBtn = slot.querySelector('[data-bar-add]');
          const menu = slot.querySelector('[data-add-menu]');
          if (!menu) return;
          let visibleCount = 0;
          menu.querySelectorAll('[data-add-system-type]').forEach((opt) => {
            opt.hidden = false;
            opt.disabled = false;
            visibleCount += 1;
          });
          menu.querySelectorAll('[data-add-app-id]').forEach((opt) => {
            const appId = normalizeWidgetAppChoiceId(opt.dataset.addAppId);
            const hide = usedAppIds.has(appId);
            opt.hidden = hide;
            opt.disabled = hide;
            if (!hide) visibleCount += 1;
          });
          if (addBtn) {
            addBtn.disabled = visibleCount === 0;
            addBtn.title = visibleCount === 0 ? 'All available widgets are already used in this widget bar' : 'Add widget to row';
            addBtn.setAttribute('aria-label', visibleCount === 0 ? 'No widgets left to add in this widget bar' : 'Add widget to row');
          }
          slot.classList.toggle('is-empty', visibleCount === 0);
          if (visibleCount === 0) {
            menu.hidden = true;
            menu.classList.remove('is-floating');
            menu.style.left = '';
            menu.style.top = '';
          }
        });
      };

      const refreshAllBarAddMenus = () => {
        if (!canvas) return;
        canvas.querySelectorAll('.widget-bar-canvas-row[data-bar-id]').forEach((barEl) => refreshBarAddMenus(barEl.dataset.barId || ''));
      };
      const getRowWidgetCards = (rowBodyEl) => Array.from((rowBodyEl || document).querySelectorAll('.widget-canvas-card[data-widget-id]'));
      const getRowWidgetOrder = (rowBodyEl) => getRowWidgetCards(rowBodyEl)
        .map((card) => String(card.dataset.widgetId || '').trim())
        .filter(Boolean);
      const getClosestWidgetCard = (rowBodyEl, targetEl) => {
        if (!rowBodyEl || !(targetEl instanceof Element)) return null;
        const directCard = targetEl.closest('.widget-canvas-card[data-widget-id]');
        if (directCard && rowBodyEl.contains(directCard)) return directCard;
        return null;
      };
      const persistRowWidgetOrder = async (barId, rowId, rowBodyEl) => {
        if (!barId || !rowId || !rowBodyEl) return;
        const widgetOrder = getRowWidgetOrder(rowBodyEl);
        if (!widgetOrder.length) return;
        const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}`, {
          method: 'PUT',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ widgetOrder }),
        });
        const data = await resp.json().catch(() => ({}));
        if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to save widget order.');
      };
      let widgetDragState = null;
      const clearWidgetDragVisuals = () => {
        if (!canvas) return;
        canvas.querySelectorAll('.widget-canvas-card.is-dragging').forEach((el) => el.classList.remove('is-dragging'));
        canvas.querySelectorAll('.widget-canvas-card.drag-insert-before').forEach((el) => el.classList.remove('drag-insert-before'));
        canvas.querySelectorAll('.widget-canvas-card.drag-insert-after').forEach((el) => el.classList.remove('drag-insert-after'));
        canvas.querySelectorAll('.widget-bar-row-body.drag-over').forEach((el) => el.classList.remove('drag-over'));
      };
      const placeDraggedWidgetCard = (rowBodyEl, draggedCard, targetCard, insertAfter) => {
        if (!rowBodyEl || !draggedCard) return false;
        const addSlot = rowBodyEl.querySelector('.widget-canvas-add-slot');
        if (!targetCard || targetCard === draggedCard) {
          const beforeNode = addSlot && addSlot.parentElement === rowBodyEl ? addSlot : null;
          if (beforeNode) rowBodyEl.insertBefore(draggedCard, beforeNode);
          else rowBodyEl.appendChild(draggedCard);
          return true;
        }
        if (insertAfter) {
          if (targetCard.nextSibling) rowBodyEl.insertBefore(draggedCard, targetCard.nextSibling);
          else rowBodyEl.appendChild(draggedCard);
        } else {
          rowBodyEl.insertBefore(draggedCard, targetCard);
        }
        return true;
      };
      const updateWidgetDragHoverPosition = (event, rowBodyEl) => {
        if (!widgetDragState || !rowBodyEl) return;
        const draggedCard = widgetDragState.cardEl;
        if (!draggedCard) return;
        clearWidgetDragVisuals();
        draggedCard.classList.add('is-dragging');
        rowBodyEl.classList.add('drag-over');
        const targetCard = getClosestWidgetCard(rowBodyEl, event.target);
        if (targetCard === draggedCard) {
          return;
        }
        if (!targetCard) {
          placeDraggedWidgetCard(rowBodyEl, draggedCard, null, false);
          return;
        }
        const rect = targetCard.getBoundingClientRect();
        const rowRect = rowBodyEl.getBoundingClientRect();
        const isVerticalStack = rowRect.width > 0 && rowRect.height > rowRect.width * 0.9;
        const insertAfter = isVerticalStack
          ? (event.clientY > (rect.top + rect.height / 2))
          : (event.clientX > (rect.left + rect.width / 2));
        targetCard.classList.add(insertAfter ? 'drag-insert-after' : 'drag-insert-before');
        placeDraggedWidgetCard(rowBodyEl, draggedCard, targetCard, insertAfter);
      };

      const closeAllRowSettingsPanels = (exceptRowId) => {
        if (!canvas) return;
        canvas.querySelectorAll('[data-row-settings-panel]').forEach((p) => {
          if (exceptRowId && p.dataset.rowSettingsPanel === exceptRowId) return;
          p.classList.remove('is-open');
          p.hidden = true;
          const btn = canvas.querySelector(`[data-row-settings-toggle="${CSS.escape(p.dataset.rowSettingsPanel)}"]`);
          if (btn) btn.classList.remove('is-open');
        });
      };

      const closeWidgetCustomizeModal = () => {
        widgetCustomizeState = null;
        if (!widgetCustomizeModal) return;
        widgetCustomizeModal.hidden = true;
        if (widgetCustomizeOptions) widgetCustomizeOptions.innerHTML = '';
        if (widgetCustomizeSubtitle) widgetCustomizeSubtitle.textContent = '';
        if (widgetCustomizeEmpty) widgetCustomizeEmpty.hidden = true;
      };

      const getWidgetMetricOptionsForCard = (cardEl) => {
        if (!cardEl) return [];
        const renderedMetricOptionsRaw = String(cardEl.dataset.widgetMetricOptions || '').trim();
        if (renderedMetricOptionsRaw) {
          try {
            const parsed = JSON.parse(renderedMetricOptionsRaw);
            const normalizedParsed = normalizeMetricFieldList(parsed);
            if (normalizedParsed.length) return normalizedParsed;
          } catch (_err) {
            /* ignore and fall back */
          }
        }
        const appId = String(cardEl.dataset.appId || '').trim();
        const typeId = String(cardEl.dataset.widgetTypeId || '').trim();
        const meta = getWidgetAppMeta(appId, typeId);
        return normalizeMetricFieldList(meta && meta.metricFields);
      };

      const openWidgetCustomizeModal = (cardEl) => {
        if (!widgetCustomizeModal || !widgetCustomizeOptions || !cardEl) return;
        const rowEl = cardEl.closest('.widget-bar-row[data-row-id][data-bar-id]');
        if (!rowEl) return;
        const barId = String(rowEl.dataset.barId || '').trim();
        const rowId = String(rowEl.dataset.rowId || '').trim();
        const widgetId = String(cardEl.dataset.widgetId || '').trim();
        const appId = String(cardEl.dataset.appId || '').trim();
        if (!barId || !rowId || !widgetId || !appId) return;

        const metricFields = getWidgetMetricOptionsForCard(cardEl);
        const selectedMetricKeys = parseCardSelectedMetricKeys(cardEl);
        const metricColumns = parseCardMetricColumns(cardEl, metricFields);
        const selectedSet = new Set(Array.isArray(selectedMetricKeys)
          ? selectedMetricKeys.map(normalizeMetricKey)
          : metricFields.map((f) => f.key));
        const cardTitle = String(cardEl.querySelector('.stat-card-name')?.textContent || appId).trim() || appId;

        // Build per-metric library info map from cached data on card
        const libraryInfoByMetric = {};
        const libraryInfoRaw = cardEl.dataset.widgetLibraryInfo;
        if (libraryInfoRaw) {
          try {
            const parsed = JSON.parse(libraryInfoRaw);
            if (Array.isArray(parsed)) {
              parsed.forEach((lib) => {
                const mk = normalizeMetricKey(lib && lib.metricKey);
                if (!mk) return;
                if (!libraryInfoByMetric[mk]) libraryInfoByMetric[mk] = [];
                libraryInfoByMetric[mk].push(lib);
              });
            }
          } catch (_e) { /* ignore */ }
        }
        const selectedLibraryKeys = parseCardSelectedLibraryKeys(cardEl) || {};

        widgetCustomizeState = { barId, rowId, widgetId, appId, cardEl, metricFields, libraryInfoByMetric };
        if (widgetCustomizeSubtitle) widgetCustomizeSubtitle.textContent = cardTitle;
        if (widgetCustomizeMetricCols) widgetCustomizeMetricCols.value = String(metricColumns);
        widgetCustomizeOptions.innerHTML = '';

        if (!metricFields.length) {
          if (widgetCustomizeEmpty) widgetCustomizeEmpty.hidden = false;
        } else {
          if (widgetCustomizeEmpty) widgetCustomizeEmpty.hidden = true;
          widgetCustomizeOptions.innerHTML = metricFields.map((field) => {
            const checked = selectedSet.has(field.key) ? ' checked' : '';
            const libs = libraryInfoByMetric[field.key] || [];
            const selectedLibs = selectedLibraryKeys[field.key];
            const selectedLibSet = Array.isArray(selectedLibs) ? new Set(selectedLibs.map((k) => String(k || '').trim())) : null;
            const libsHtml = libs.length > 1
              ? `<div class="widget-customize-library-list">${libs.map((lib) => {
                  const libKey = String(lib.key || '').trim();
                  const libChecked = !selectedLibSet || selectedLibSet.has(libKey) ? ' checked' : '';
                  return `<label class="widget-card-customize-check widget-customize-library-check">` +
                    `<input type="checkbox" data-widget-library-key="${escHtml(libKey)}" data-widget-library-metric="${escHtml(field.key)}"${libChecked}>` +
                    `<span>${escHtml(String(lib.title || lib.key || ''))} <em class="widget-library-count">${Number(lib.count) || 0}</em></span>` +
                    `</label>`;
                }).join('')}</div>`
              : '';
            return `<div class="widget-customize-metric-group">` +
              `<label class="widget-card-customize-check">` +
              `<input type="checkbox" data-widget-metric-key="${escHtml(field.key)}"${checked}>` +
              `<span>${escHtml(field.label || field.key)}</span>` +
              `</label>` +
              libsHtml +
              `</div>`;
          }).join('');
        }

        widgetCustomizeModal.hidden = false;
      };

      const saveWidgetCustomizeSelection = async (btn) => {
        if (!widgetCustomizeState || !widgetCustomizeModal || !widgetCustomizeOptions) return;
        const { barId, rowId, widgetId, cardEl, metricFields, libraryInfoByMetric = {} } = widgetCustomizeState;
        if (!barId || !rowId || !widgetId || !cardEl) return;
        const metricFieldKeys = new Set(metricFields.map((f) => f.key));
        const metricColumns = widgetCustomizeMetricCols
          ? Math.max(1, Math.min(4, Math.round(Number(widgetCustomizeMetricCols.value || 2) || 2)))
          : 2;
        const selectedMetricKeys = Array.from(widgetCustomizeOptions.querySelectorAll('input[data-widget-metric-key]:checked'))
          .map((input) => normalizeMetricKey(input && input.dataset && input.dataset.widgetMetricKey))
          .filter((key) => !metricFieldKeys.size || metricFieldKeys.has(key));
        // Collect per-library selections (only for metrics with >1 library)
        const selectedLibraryKeys = {};
        for (const [metricKey, libs] of Object.entries(libraryInfoByMetric)) {
          if (libs.length <= 1) continue;
          const allLibInputs = Array.from(widgetCustomizeOptions.querySelectorAll(`input[data-widget-library-metric="${CSS.escape(metricKey)}"]`));
          if (!allLibInputs.length) continue;
          const checkedKeys = allLibInputs.filter((inp) => inp.checked).map((inp) => String(inp.dataset.widgetLibraryKey || '').trim()).filter(Boolean);
          if (checkedKeys.length < allLibInputs.length) selectedLibraryKeys[metricKey] = checkedKeys;
        }
        const finalLibraryKeys = Object.keys(selectedLibraryKeys).length ? selectedLibraryKeys : null;
        const origText = btn ? btn.textContent : '';
        if (btn) {
          btn.disabled = true;
          btn.textContent = 'Saving...';
        }
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}/widgets/${encodeURIComponent(widgetId)}`, {
            method: 'PUT',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ selectedMetricKeys, metricColumns, ...(finalLibraryKeys ? { selectedLibraryKeys: finalLibraryKeys } : { selectedLibraryKeys: null }) }),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to update widget.');
          applyCardSelectedMetricKeysData(cardEl, selectedMetricKeys);
          applyCardLibraryKeysData(cardEl, finalLibraryKeys);
          applyCardMetricColumnsData(cardEl, metricColumns);
          const savedRow = (data.item && Array.isArray(data.item.rows)) ? data.item.rows.find((r) => r && r.id === rowId) : null;
          const savedWidget = savedRow && Array.isArray(savedRow.widgets) ? savedRow.widgets.find((w) => String(w && w.id || '') === widgetId) : null;
          if (savedWidget && savedWidget.typeId) cardEl.dataset.widgetTypeId = String(savedWidget.typeId);
          if (savedWidget && Number.isFinite(Number(savedWidget.metricColumns))) applyCardMetricColumnsData(cardEl, savedWidget.metricColumns);
          await fetchAndRenderCard(cardEl);
          closeWidgetCustomizeModal();
        } catch (err) {
          alert(err.message || 'Failed to update widget.');
        } finally {
          if (btn) {
            btn.disabled = false;
            btn.textContent = origText;
          }
        }
      };

      document.addEventListener('pointerdown', (e) => {
        const targetEl = (e.target instanceof Element) ? e.target : null;
        if (!targetEl || !targetEl.closest('[data-bar-add-slot]')) closeAllMenus(null);
        if (!targetEl || !targetEl.closest('.widget-bar-row-settings-slot')) closeAllRowSettingsPanels(null);
        if (!targetEl || !targetEl.closest('[data-widget-bar-role-filter]')) closeAllWidgetBarRoleFilters(null);
      });
      if (widgetCustomizeModal) {
        widgetCustomizeModal.addEventListener('click', async (e) => {
          const closeBtn = e.target.closest('[data-widget-customize-close], [data-widget-customize-cancel]');
          if (closeBtn && widgetCustomizeModal.contains(closeBtn)) {
            e.preventDefault();
            closeWidgetCustomizeModal();
            return;
          }
          const allBtn = e.target.closest('[data-widget-customize-all]');
          if (allBtn && widgetCustomizeModal.contains(allBtn)) {
            e.preventDefault();
            widgetCustomizeModal.querySelectorAll('input[data-widget-metric-key], input[data-widget-library-key]').forEach((input) => { input.checked = true; });
            return;
          }
          const applyBtn = e.target.closest('[data-widget-customize-apply]');
          if (applyBtn && widgetCustomizeModal.contains(applyBtn)) {
            e.preventDefault();
            await saveWidgetCustomizeSelection(applyBtn);
            return;
          }
        });
      }
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && widgetCustomizeModal && !widgetCustomizeModal.hidden) closeWidgetCustomizeModal();
      });

      // ── DOM helpers ──────────────────────────────────────────────────────
      const getSystemWidgetSummary = (systemType, cfgRaw) => {
        const systemTypeKey = String(systemType || '').trim().toLowerCase();
        const cfg = (cfgRaw && typeof cfgRaw === 'object') ? cfgRaw : {};
        const parts = [];
        if (systemTypeKey === 'sys-resources') {
          if (cfg.cpu !== false) parts.push('CPU');
          if (cfg.memory !== false) parts.push('RAM');
          const diskCount = Array.isArray(cfg.disks) ? cfg.disks.length : 0;
          if (diskCount > 0) parts.push(`${diskCount} Disk${diskCount === 1 ? '' : 's'}`);
          if (cfg.showTotalSpace === true) parts.push('Total Space');
          if (cfg.search && cfg.search.enabled) parts.push('Search');
          if (cfg.weather && cfg.weather.enabled) parts.push('Weather');
        } else if (systemTypeKey === 'links') {
          const linkCount = Array.isArray(cfg.links) ? cfg.links.length : 0;
          if (linkCount > 0) parts.push(`${linkCount} Link${linkCount === 1 ? '' : 's'}`);
          if (cfg.showUrl === false) parts.push('Names only');
        } else if (systemTypeKey === 'deployment-summary') {
          const stats = (cfg.stats && typeof cfg.stats === 'object') ? cfg.stats : {};
          const showOnline = stats.online !== false;
          const showOffline = stats.offline !== false;
          const showTotal = stats.total !== false;
          const visibleStats = [showOnline ? 'Online' : '', showOffline ? 'Offline' : '', showTotal ? 'Total' : ''].filter(Boolean);
          const columnsRaw = Number(cfg.columns);
          const columns = Number.isFinite(columnsRaw) ? Math.max(1, Math.min(4, Math.round(columnsRaw))) : 3;
          parts.push(`${columns} Col${columns === 1 ? '' : 's'}`);
          parts.push(visibleStats.length ? visibleStats.join(' · ') : 'Online');
        }
        return parts.join(' · ');
      };

      const buildSystemWidgetChipHtml = (widget, barId, rowId) => {
        const wId = escHtml(widget.id);
        const bId = escHtml(barId);
        const rId = escHtml(rowId);
        const sysType = escHtml(widget.systemType);
        const sysTypeKey = String(widget.systemType || '').trim().toLowerCase();
        const typeName = escHtml(widget.typeName || widget.systemType);
        const cfg = widget.systemConfig || {};
        const cfgEsc = escHtml(JSON.stringify(cfg));
        const icon = escHtml(widget.icon || '/icons/app.svg');
        const summary = getSystemWidgetSummary(widget.systemType, cfg);
        let previewHtml = '';
        if (sysTypeKey === 'sys-resources') {
          previewHtml = `<div class="widget-canvas-system-preview dashboard-system-bar" data-system-preview data-system-type="sys-resources" data-system-config="${cfgEsc}"></div>`;
        } else if (sysTypeKey === 'links') {
          previewHtml = `<div class="widget-canvas-system-preview dashboard-links-widget" data-system-preview data-system-type="links" data-system-config="${cfgEsc}"></div>`;
        } else if (sysTypeKey === 'deployment-summary') {
          previewHtml = `<div class="widget-canvas-system-preview deployment-summary-preview" data-system-preview data-system-type="deployment-summary" data-system-config="${cfgEsc}"></div>`;
        }
        const editButtonHtml = sysTypeKey === 'deployment-summary'
          ? ''
          : `<button class="widget-canvas-system-chip-edit" type="button" data-sys-widget-edit data-widget-id="${wId}" data-bar-id="${bId}" data-row-id="${rId}" data-system-type="${sysType}" data-system-config="${cfgEsc}" title="Edit config" aria-label="Edit ${typeName} config">✎</button>`;
        return `<div class="widget-canvas-card widget-canvas-system-chip" draggable="true" data-widget-id="${wId}" data-system-type="${sysType}" data-system-config="${cfgEsc}">` +
          `<img class="system-chip-icon" src="${icon}" alt="" onerror="this.src='/icons/app.svg'" />` +
          `<span class="system-chip-canvas-label">${typeName}${summary ? ` <small class="muted-hint"> ${escHtml(summary)}</small>` : ''}</span>` +
          previewHtml +
          editButtonHtml +
          `<button class="widget-canvas-card-remove" type="button" data-widget-remove-bar="${bId}" data-widget-remove-row="${rId}" data-widget-remove-id="${wId}" title="Remove" aria-label="Remove ${typeName}">&times;</button>` +
          `</div>`;
      };

      const buildRowHtml = (barId, row, apps) => {
        const rowId = escHtml(row.id);
        const bId = escHtml(barId);
        const s = row.settings || {};
        const rowBodyClasses = ['widget-bar-row-body',
          s.fixedWidth ? 'row--fixed-width' : '',
          s.scroll ? 'row--scroll' : '',
          s.fill ? 'row--fill' : '',
        ].filter(Boolean).join(' ');
        const rowMaxCols = Number(s.maxCols || 0) > 0 ? Math.max(1, Math.min(20, Math.round(Number(s.maxCols || 0)))) : 0;
        const rowBodyStyleAttr = rowMaxCols > 0 ? ` style="--row-max-cols: ${rowMaxCols}"` : '';
        const sysTypes = Array.isArray(window._systemWidgetTypes) ? window._systemWidgetTypes : [];
        const sysMenuHtml = sysTypes.length
          ? `<div class="widget-canvas-add-group-label">System</div>` +
            sysTypes.map((t) =>
              `<button class="widget-canvas-add-option" type="button" data-add-system-type="${escHtml(t.typeId)}" data-has-config="${t.hasConfig ? '1' : ''}" data-bar-id="${bId}" data-row-id="${rowId}">` +
              `<img src="${escHtml(t.icon)}" alt="" onerror="this.src='/icons/app.svg'" /><span>${escHtml(t.label)}</span></button>`
            ).join('')
          : '';
        const appMenuHtml = apps.length
          ? `<div class="widget-canvas-add-group-label">Apps</div>` +
            apps.map((app) =>
              `<button class="widget-canvas-add-option" type="button" data-add-app-id="${escHtml(app.id)}" data-bar-id="${bId}" data-row-id="${rowId}">` +
              `<img src="${escHtml(app.icon)}" alt="" onerror="this.src='/icons/app.svg'" /><span>${escHtml(app.name)}</span></button>`
            ).join('')
          : '';
        const addMenuHtml = sysMenuHtml + appMenuHtml;
        const addSlot = `<div class="widget-canvas-add-slot" data-bar-add-slot="${bId}">` +
          `<button class="widget-canvas-add-btn" type="button" data-bar-add="${bId}" data-row-add="${rowId}" aria-label="Add widget to row" aria-haspopup="true">` +
          `<span class="widget-canvas-add-icon">+</span></button>` +
          `<div class="widget-canvas-add-menu" hidden data-add-menu>${addMenuHtml}</div></div>`;
        const widgetsHtml = (row.widgets || []).map((widget) => {
          if (widget.systemType) return buildSystemWidgetChipHtml(widget, barId, row.id);
          const wId = escHtml(widget.id);
          const wApp = escHtml(widget.appId);
          const wLabel = escHtml(widget.typeName || widget.appId);
          const metricAttrs = buildWidgetCardMetricAttrs(widget);
          return `<div class="widget-canvas-card dashboard-stat-card is-loading" draggable="true" data-widget-id="${wId}" data-app-id="${wApp}"${metricAttrs}>` +
            `<div class="stat-card-header">` +
            `<img class="stat-card-icon" src="${escHtml(widget.icon || '/icons/app.svg')}" alt="" onerror="this.src='/icons/app.svg'" />` +
            `<span class="stat-card-name">${wLabel}</span>` +
            `<span class="stat-card-status is-unknown">Unknown</span>` +
            `</div><div class="stat-card-metrics"></div>` +
            `<button class="widget-canvas-card-remove" type="button" data-widget-remove-bar="${bId}" data-widget-remove-row="${rowId}" data-widget-remove-id="${wId}" title="Remove" aria-label="Remove ${wLabel}">&times;</button>` +
            `</div>`;
        }).join('');
        return `<div class="widget-bar-row" data-row-id="${rowId}" data-bar-id="${bId}">` +
          `<div class="widget-bar-row-settings-slot">` +
          `<button class="widget-bar-row-settings-btn" type="button" data-row-settings-toggle="${rowId}" aria-label="Row settings" title="Row settings">&#8250;</button>` +
          `<div class="widget-bar-row-settings-panel" hidden data-row-settings-panel="${rowId}">` +
          `<div class="widget-bar-row-settings-inner">` +
          `<label class="widget-row-settings-label">Max columns<input type="number" min="0" max="20" value="${Number(s.maxCols || 0)}" data-row-setting="maxCols" class="settings-input widget-row-settings-num" /><span class="muted-hint">0 = unlimited</span></label>` +
          `<label class="widget-row-settings-check"><input type="checkbox" data-row-setting="fixedWidth"${s.fixedWidth ? ' checked' : ''}> Fixed width</label>` +
          `<label class="widget-row-settings-check"><input type="checkbox" data-row-setting="scroll"${s.scroll ? ' checked' : ''}> Scroll (no wrap)</label>` +
          `<label class="widget-row-settings-check"><input type="checkbox" data-row-setting="fill"${s.fill ? ' checked' : ''}> Fill row width</label>` +
          `<div class="widget-row-settings-actions">` +
          `<button class="primary-button widget-row-settings-apply" type="button" data-row-settings-apply data-bar-id="${bId}" data-row-id="${rowId}">Apply</button>` +
          `<button class="secondary-button widget-row-delete-btn" type="button" data-row-delete data-bar-id="${bId}" data-row-id="${rowId}">Delete Row</button>` +
          `</div></div></div></div>` +
          `<div class="${rowBodyClasses}" data-bar-body data-row-id="${rowId}"${rowBodyStyleAttr}>${widgetsHtml}${addSlot}</div>` +
          `</div>`;
      };

      const buildBarRowsWrapHtml = (bar, apps) => {
        const barId = bar.id;
        const rowsHtml = (bar.rows || []).map((row) => buildRowHtml(barId, row, apps)).join('');
        return `<div class="widget-bar-row-add-strip widget-bar-row-add-strip--top">` +
          `<button class="secondary-button widget-bar-add-row-btn" type="button" data-bar-add-row="${escHtml(barId)}" data-bar-add-row-position="top" aria-label="Add row above" title="Add row above">&#8593;</button>` +
          `</div>` +
          rowsHtml +
          `<div class="widget-bar-row-add-strip widget-bar-row-add-strip--bottom">` +
          `<button class="secondary-button widget-bar-add-row-btn" type="button" data-bar-add-row="${escHtml(barId)}" data-bar-add-row-position="bottom" aria-label="Add row below" title="Add row below">&#8595;</button>` +
          `</div>`;
      };

      // Delegated event handling on canvas
      if (canvas) {
        canvas.addEventListener('change', (e) => {
          const targetEl = (e.target instanceof Element) ? e.target : null;
          if (!targetEl || !targetEl.matches('input[type="checkbox"][data-bar-role-value]')) return;
          const barEl = targetEl.closest('.widget-bar-canvas-row[data-bar-id]');
          if (barEl) updateWidgetBarRoleFilterSummary(barEl);
        });
        canvas.addEventListener('dragstart', (e) => {
          const targetEl = (e.target instanceof Element) ? e.target : null;
          const cardEl = targetEl && targetEl.closest('.widget-canvas-card[data-widget-id]');
          if (!cardEl || !canvas.contains(cardEl)) return;
          if (targetEl.closest('.widget-canvas-card-remove')) { e.preventDefault(); return; }
          const rowBodyEl = cardEl.closest('.widget-bar-row-body[data-bar-body]');
          const rowEl = cardEl.closest('.widget-bar-row[data-row-id][data-bar-id]');
          if (!rowBodyEl || !rowEl) return;
          widgetDragState = {
            cardEl,
            rowBodyEl,
            rowEl,
            barId: String(rowEl.dataset.barId || '').trim(),
            rowId: String(rowEl.dataset.rowId || '').trim(),
            startOrder: getRowWidgetOrder(rowBodyEl),
          };
          cardEl.classList.add('is-dragging');
          try {
            if (e.dataTransfer) {
              e.dataTransfer.effectAllowed = 'move';
              e.dataTransfer.setData('text/plain', String(cardEl.dataset.widgetId || 'widget'));
            }
          } catch (_err) { /* ignore */ }
        });
        canvas.addEventListener('dragover', (e) => {
          if (!widgetDragState) return;
          const targetEl = (e.target instanceof Element) ? e.target : null;
          const rowBodyEl = targetEl && targetEl.closest('.widget-bar-row-body[data-bar-body]');
          if (!rowBodyEl || rowBodyEl !== widgetDragState.rowBodyEl) return;
          e.preventDefault();
          try { if (e.dataTransfer) e.dataTransfer.dropEffect = 'move'; } catch (_err) { /* ignore */ }
          updateWidgetDragHoverPosition(e, rowBodyEl);
        });
        canvas.addEventListener('drop', async (e) => {
          if (!widgetDragState) return;
          const targetEl = (e.target instanceof Element) ? e.target : null;
          const rowBodyEl = targetEl && targetEl.closest('.widget-bar-row-body[data-bar-body]');
          if (!rowBodyEl || rowBodyEl !== widgetDragState.rowBodyEl) return;
          e.preventDefault();
          const { barId, rowId, startOrder } = widgetDragState;
          const endOrder = getRowWidgetOrder(rowBodyEl);
          const changed = (startOrder.length !== endOrder.length) || startOrder.some((id, idx) => id !== endOrder[idx]);
          if (!changed) {
            clearWidgetDragVisuals();
            widgetDragState = null;
            return;
          }
          try {
            await persistRowWidgetOrder(barId, rowId, rowBodyEl);
          } catch (err) {
            alert(err.message || 'Failed to save widget order.');
          } finally {
            clearWidgetDragVisuals();
            widgetDragState = null;
          }
        });
        canvas.addEventListener('dragend', () => {
          clearWidgetDragVisuals();
          widgetDragState = null;
        });
        canvas.addEventListener('click', async (e) => {
          const roleFilterTrigger = e.target.closest('[data-widget-bar-role-filter-trigger]');
          if (roleFilterTrigger && canvas.contains(roleFilterTrigger)) {
            e.preventDefault();
            e.stopPropagation();
            const filterEl = roleFilterTrigger.closest('[data-widget-bar-role-filter]');
            const menu = filterEl && filterEl.querySelector('[data-widget-bar-role-filter-menu]');
            if (!filterEl || !menu) return;
            const isOpen = roleFilterTrigger.getAttribute('aria-expanded') === 'true';
            if (isOpen) {
              roleFilterTrigger.setAttribute('aria-expanded', 'false');
              menu.hidden = true;
            } else {
              closeAllWidgetBarRoleFilters(filterEl);
              roleFilterTrigger.setAttribute('aria-expanded', 'true');
              menu.hidden = false;
            }
            return;
          }
          const roleFilterMenu = e.target.closest('[data-widget-bar-role-filter-menu]');
          if (roleFilterMenu && canvas.contains(roleFilterMenu)) {
            e.stopPropagation();
          }
          // Toggle add menu
          const addBtn = e.target.closest('[data-bar-add]');
          if (addBtn) {
            e.stopPropagation();
            const slot = addBtn.closest('[data-bar-add-slot]');
            const menu = slot && slot.querySelector('[data-add-menu]');
            if (menu) {
              const wasHidden = menu.hidden;
              closeAllMenus(null);
              menu.hidden = !wasHidden;
              if (!menu.hidden) {
                positionAddMenuFloating(menu, addBtn);
              } else {
                menu.classList.remove('is-floating');
                menu.style.left = '';
                menu.style.top = '';
              }
            }
            return;
          }
          // Pick system widget type from menu
          const sysOptBtn = e.target.closest('[data-add-system-type]');
          if (sysOptBtn) {
            const barId = String(sysOptBtn.dataset.barId || '').trim();
            const rowId = String(sysOptBtn.dataset.rowId || '').trim();
            const systemType = String(sysOptBtn.dataset.addSystemType || '').trim();
            if (!barId || !rowId || !systemType) return;
            const slot = sysOptBtn.closest('[data-bar-add-slot]');
            const menu = slot && slot.querySelector('[data-add-menu]');
            if (menu) { menu.hidden = true; menu.classList.remove('is-floating'); menu.style.left = ''; menu.style.top = ''; }
            const hasConfig = sysOptBtn.dataset.hasConfig === '1';
            if (hasConfig) {
              openSysWidgetConfigModal(barId, rowId, systemType, null, null);
            } else {
              await addSystemWidgetToRow(barId, rowId, systemType, {});
            }
            return;
          }
          // Edit system widget config
          const sysEditBtn = e.target.closest('[data-sys-widget-edit]');
          if (sysEditBtn && canvas.contains(sysEditBtn)) {
            const barId = String(sysEditBtn.dataset.barId || '').trim();
            const rowId = String(sysEditBtn.dataset.rowId || '').trim();
            const systemType = String(sysEditBtn.dataset.systemType || '').trim();
            const widgetId = String(sysEditBtn.dataset.widgetId || '').trim();
            let existingConfig = {};
            try { existingConfig = JSON.parse(sysEditBtn.dataset.systemConfig || '{}'); } catch (_e) {}
            openSysWidgetConfigModal(barId, rowId, systemType, existingConfig, widgetId);
            return;
          }
          const deploymentSummaryCard = e.target.closest('.widget-canvas-system-chip[data-widget-id][data-system-type="deployment-summary"]');
          if (deploymentSummaryCard
              && canvas.contains(deploymentSummaryCard)
              && !e.target.closest('.widget-canvas-card-remove')
              && !e.target.closest('[data-sys-widget-edit]')) {
            const rowEl = deploymentSummaryCard.closest('.widget-bar-row[data-row-id][data-bar-id]');
            const barId = String((rowEl && rowEl.dataset.barId) || '').trim();
            const rowId = String((rowEl && rowEl.dataset.rowId) || '').trim();
            const widgetId = String(deploymentSummaryCard.dataset.widgetId || '').trim();
            if (!barId || !rowId || !widgetId) return;
            let existingConfig = {};
            try { existingConfig = JSON.parse(deploymentSummaryCard.dataset.systemConfig || '{}'); } catch (_err) { /* ignore */ }
            openSysWidgetConfigModal(barId, rowId, 'deployment-summary', existingConfig, widgetId);
            return;
          }
          // Pick app from menu
          const optBtn = e.target.closest('[data-add-app-id]');
          if (optBtn) {
            const barId = String(optBtn.dataset.barId || '').trim();
            const rowId = String(optBtn.dataset.rowId || '').trim();
            const appId = String(optBtn.dataset.addAppId || '').trim();
            if (!barId || !rowId || !appId) return;
            const slot = optBtn.closest('[data-bar-add-slot]');
            const menu = slot && slot.querySelector('[data-add-menu]');
            if (menu) {
              menu.hidden = true;
              menu.classList.remove('is-floating');
              menu.style.left = '';
              menu.style.top = '';
            }
            const img = optBtn.querySelector('img');
            const lbl = optBtn.querySelector('span');
            await addWidgetToRow(barId, rowId, appId, img ? img.src : '/icons/app.svg', lbl ? lbl.textContent : appId);
            return;
          }
          // Save bar
          const collapseBtn = e.target.closest('[data-bar-collapse-toggle]');
          const prevScrollBtn = e.target.closest('[data-widget-bar-scroll-prev]');
          if (prevScrollBtn && canvas.contains(prevScrollBtn)) {
            e.preventDefault();
            if (prevScrollBtn.disabled) return;
            scrollBarPreviewRows(prevScrollBtn.closest('.widget-bar-canvas-row[data-bar-id]'), -1);
            return;
          }
          const nextScrollBtn = e.target.closest('[data-widget-bar-scroll-next]');
          if (nextScrollBtn && canvas.contains(nextScrollBtn)) {
            e.preventDefault();
            if (nextScrollBtn.disabled) return;
            scrollBarPreviewRows(nextScrollBtn.closest('.widget-bar-canvas-row[data-bar-id]'), 1);
            return;
          }
          if (collapseBtn) {
            const barId = String(collapseBtn.dataset.barCollapseToggle || '').trim();
            if (!barId || !canvas) return;
            const barEl = canvas.querySelector(`.widget-bar-canvas-row[data-bar-id="${CSS.escape(barId)}"]`);
            if (!barEl) return;
            const collapsed = !barEl.classList.contains('is-collapsed');
            applyBarCollapsedState(barEl, collapsed);
            setStoredBarCollapsed(barId, collapsed);
            return;
          }
          // Save bar
          const saveBtn = e.target.closest('[data-bar-save]');
          if (saveBtn) { await saveBar(String(saveBtn.dataset.barSave || '').trim(), saveBtn); return; }
          // Delete bar
          const delBtn = e.target.closest('[data-bar-delete]');
          if (delBtn) { await deleteBar(String(delBtn.dataset.barDelete || '').trim(), delBtn); return; }
          // Remove widget from row
          const rmBtn = e.target.closest('[data-widget-remove-bar]');
          if (rmBtn) {
            await removeWidgetFromRow(
              String(rmBtn.dataset.widgetRemoveBar || '').trim(),
              String(rmBtn.dataset.widgetRemoveRow || '').trim(),
              String(rmBtn.dataset.widgetRemoveId || '').trim(),
              rmBtn
            );
            return;
          }
          // Open widget metric customization
          const widgetCard = e.target.closest('.widget-canvas-card[data-widget-id][data-app-id]');
          if (widgetCard && canvas.contains(widgetCard) && !e.target.closest('.widget-canvas-card-remove')) {
            openWidgetCustomizeModal(widgetCard);
            return;
          }
          // Toggle row settings panel
          const settingsToggle = e.target.closest('[data-row-settings-toggle]');
          if (settingsToggle) {
            e.stopPropagation();
            const rowId = String(settingsToggle.dataset.rowSettingsToggle || '').trim();
            const panelEl = canvas.querySelector(`[data-row-settings-panel="${CSS.escape(rowId)}"]`);
            if (!panelEl) return;
            const isOpen = !panelEl.hidden;
            closeAllRowSettingsPanels(null);
            if (!isOpen) {
              panelEl.hidden = false;
              panelEl.classList.add('is-open');
              settingsToggle.classList.add('is-open');
            }
            return;
          }
          // Apply row settings
          const applyBtn = e.target.closest('[data-row-settings-apply]');
          if (applyBtn) {
            const barId = String(applyBtn.dataset.barId || '').trim();
            const rowId = String(applyBtn.dataset.rowId || '').trim();
            const panelEl = canvas.querySelector(`[data-row-settings-panel="${CSS.escape(rowId)}"]`);
            if (!barId || !rowId || !panelEl) return;
            await saveRowSettings(barId, rowId, panelEl, applyBtn);
            return;
          }
          // Delete row
          const deleteRowBtn = e.target.closest('[data-row-delete]');
          if (deleteRowBtn) {
            const barId = String(deleteRowBtn.dataset.barId || '').trim();
            const rowId = String(deleteRowBtn.dataset.rowId || '').trim();
            await deleteRow(barId, rowId, deleteRowBtn);
            return;
          }
          // Add row
          const addRowBtn = e.target.closest('[data-bar-add-row]');
          if (addRowBtn) {
            const barId = String(addRowBtn.dataset.barAddRow || '').trim();
            const rowPosition = String(addRowBtn.dataset.barAddRowPosition || '').trim().toLowerCase() === 'top' ? 'top' : 'bottom';
            await addRow(barId, addRowBtn, rowPosition);
            return;
          }
        });
      }

      // Save bar settings via PUT
      const saveBar = async (barId, btn) => {
        if (!barId || !canvas) return;
        const row = canvas.querySelector(`[data-bar-id="${CSS.escape(barId)}"]`);
        if (!row) return;
        const name = String(row.querySelector('[data-bar-name]')?.value || '').trim() || 'Widget Bar';
        const icon = normalizeWidgetBarIconValue(row.querySelector('[data-bar-icon]')?.value || DEFAULT_WIDGET_BAR_ICON);
        const visibilityRoles = getWidgetBarSelectedRoles(row);
        const refreshSeconds = Number(row.querySelector('[data-bar-refresh]')?.value || 60);
        const origText = btn.textContent;
        btn.disabled = true;
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}`, {
            method: 'PUT',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, icon, visibilityRoles, refreshSeconds }),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to save.');
          btn.textContent = 'Saved!';
          setTimeout(() => { btn.textContent = origText; }, 1500);
        } catch (err) {
          alert(err.message || 'Failed to save widget bar settings.');
        } finally {
          btn.disabled = false;
        }
      };

      // Delete bar via DELETE
      const deleteBar = async (barId, btn) => {
        if (!barId) return;
        if (!confirm('Delete this widget bar? It will be removed from all dashboards.')) return;
        const row = canvas && canvas.querySelector(`[data-bar-id="${CSS.escape(barId)}"]`);
        btn.disabled = true;
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}`, { method: 'DELETE', credentials: 'same-origin' });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to delete widget bar.');
          if (row) row.remove();
          if (emptyMsg && canvas && !canvas.querySelector('[data-bar-id]')) emptyMsg.hidden = false;
        } catch (err) {
          btn.disabled = false;
          alert(err.message || 'Failed to delete widget bar.');
        }
      };

      // Add widget to a specific row
      const addWidgetToRow = async (barId, rowId, appId, iconSrc, appLabel) => {
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}/widgets`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ appId }),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to add widget.');
          const savedBar = data.item;
          const savedRow = (savedBar?.rows || []).find((r) => r.id === rowId);
          const addedWidget = savedRow
            ? ((savedRow.widgets || []).find((w) => String(w.appId || '') === appId) || (savedRow.widgets || []).slice(-1)[0])
            : null;
          if (!addedWidget || !canvas) return;
          // Find the add slot in this specific row
          const rowEl = canvas.querySelector(`.widget-bar-row[data-row-id="${CSS.escape(rowId)}"][data-bar-id="${CSS.escape(barId)}"]`);
          const slot = rowEl && rowEl.querySelector('[data-bar-add-slot]');
          if (!slot) return;
          const resolvedAppId = escHtml(addedWidget.appId || appLabel);
          const metricAttrs = buildWidgetCardMetricAttrs(addedWidget);
          const typeName = escHtml(addedWidget.typeName || addedWidget.appId || appLabel);
          const cardHtml = `<div class="widget-canvas-card dashboard-stat-card is-loading" draggable="true" data-widget-id="${escHtml(addedWidget.id)}" data-app-id="${resolvedAppId}"${metricAttrs}>` +
            `<div class="stat-card-header">` +
            `<img class="stat-card-icon" src="${escHtml(addedWidget.icon || iconSrc)}" alt="" onerror="this.src='/icons/app.svg'" />` +
            `<span class="stat-card-name">${typeName}</span>` +
            `<span class="stat-card-status is-unknown">Unknown</span>` +
            `</div><div class="stat-card-metrics"></div>` +
            `<button class="widget-canvas-card-remove" type="button" data-widget-remove-bar="${escHtml(barId)}" data-widget-remove-row="${escHtml(rowId)}" data-widget-remove-id="${escHtml(addedWidget.id)}" title="Remove" aria-label="Remove ${resolvedAppId}">&times;</button>` +
            `</div>`;
          slot.insertAdjacentHTML('beforebegin', cardHtml);
          const newCard = slot.previousElementSibling;
          if (newCard && newCard.dataset.appId) fetchAndRenderCard(newCard);
          refreshBarAddMenus(barId);
        } catch (err) {
          alert(err.message || 'Failed to add widget.');
        }
      };

      // Add system widget to a specific row
      const addSystemWidgetToRow = async (barId, rowId, systemType, systemConfig) => {
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}/widgets`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ systemType, systemConfig: systemConfig || {} }),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to add system widget.');
          const savedBar = data.item;
          const savedRow = (savedBar?.rows || []).find((r) => r.id === rowId);
          const addedWidget = savedRow ? (savedRow.widgets || []).slice(-1)[0] : null;
          if (!addedWidget || !canvas) return;
          const rowEl = canvas.querySelector(`.widget-bar-row[data-row-id="${CSS.escape(rowId)}"][data-bar-id="${CSS.escape(barId)}"]`);
          const slot = rowEl && rowEl.querySelector('[data-bar-add-slot]');
          if (!slot) return;
          const chipHtml = buildSystemWidgetChipHtml(addedWidget, barId, rowId);
          slot.insertAdjacentHTML('beforebegin', chipHtml);
          refreshBarAddMenus(barId);
          const newChip = slot.previousElementSibling;
          if (newChip) {
            const previewEl = newChip.querySelector('[data-system-preview]');
            if (previewEl) refreshSystemPreviewCard(previewEl);
          }
        } catch (err) {
          alert(err.message || 'Failed to add system widget.');
        }
      };

      // System widget config modal
      const sysWidgetModal = panel.querySelector('[data-sys-widget-modal]');
      const sysWidgetModalBody = panel.querySelector('[data-sys-widget-modal-body]');
      let sysWidgetModalState = null;

      const SEARCH_PROVIDERS = Array.isArray(window._systemWidgetSearchProviders) ? window._systemWidgetSearchProviders : [
        { id: 'duckduckgo', label: 'DuckDuckGo' }, { id: 'google', label: 'Google' },
        { id: 'bing', label: 'Bing' }, { id: 'brave', label: 'Brave' }, { id: 'searxng', label: 'SearXNG' },
      ];
      const TIMEZONES = Array.isArray(window._systemWidgetTimezones) ? window._systemWidgetTimezones : ['UTC', 'Europe/London', 'America/New_York'];
      const SEARCH_PROVIDER_IDS = new Set(SEARCH_PROVIDERS.map((p) => String(p.id || '').trim().toLowerCase()).filter(Boolean));

      const normalizeSysResourcesConfigForForm = (cfgRaw) => {
        const cfg = (cfgRaw && typeof cfgRaw === 'object') ? cfgRaw : {};
        const rawDisks = Array.isArray(cfg.disks) ? cfg.disks : [];
        const searchCfg = (cfg.search && typeof cfg.search === 'object') ? cfg.search : {};
        const weatherCfg = (cfg.weather && typeof cfg.weather === 'object') ? cfg.weather : {};
        const lat = Number(weatherCfg.latitude);
        const lon = Number(weatherCfg.longitude);
        const cache = Number(weatherCfg.cache);
        const provider = String(searchCfg.provider || 'duckduckgo').trim().toLowerCase();
        return {
          cpu: cfg.cpu !== false,
          memory: cfg.memory !== false,
          showTotalSpace: cfg.showTotalSpace === true,
          disks: rawDisks
            .map((disk) => ({
              path: String((disk && disk.path) || '/').trim() || '/',
              label: String((disk && disk.label) || '').trim(),
            }))
            .filter((disk) => disk.path),
          search: {
            enabled: searchCfg.enabled === true,
            provider: SEARCH_PROVIDER_IDS.has(provider) ? provider : 'duckduckgo',
            target: searchCfg.target === '_self' ? '_self' : '_blank',
            baseUrl: String(searchCfg.baseUrl || '').trim(),
          },
          weather: {
            enabled: weatherCfg.enabled === true,
            label: String(weatherCfg.label || '').trim() || 'Home',
            latitude: Number.isFinite(lat) ? Math.max(-90, Math.min(90, lat)) : 0,
            longitude: Number.isFinite(lon) ? Math.max(-180, Math.min(180, lon)) : 0,
            timezone: String(weatherCfg.timezone || 'UTC').trim() || 'UTC',
            units: weatherCfg.units === 'imperial' ? 'imperial' : 'metric',
            cache: Number.isFinite(cache) ? Math.max(1, Math.min(60, Math.round(cache))) : 5,
          },
        };
      };

      const normalizeLinksUrlForForm = (rawValue) => {
        const input = String(rawValue || '').trim();
        if (!input) return '';
        let candidate = input;
        if (!/^[a-z][a-z0-9+.-]*:/i.test(candidate)) candidate = `https://${candidate}`;
        try {
          const parsed = new URL(candidate);
          if (!parsed.hostname) return '';
          if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') return '';
          return parsed.toString();
        } catch (_err) {
          return '';
        }
      };

      const normalizeLinksConfigForForm = (cfgRaw) => {
        const cfg = (cfgRaw && typeof cfgRaw === 'object') ? cfgRaw : {};
        const rawLinks = Array.isArray(cfg.links) ? cfg.links : [];
        const links = rawLinks
          .map((row) => {
            const rowObj = (row && typeof row === 'object') ? row : {};
            return {
              name: String(rowObj.name || rowObj.title || '').trim(),
              url: normalizeLinksUrlForForm(rowObj.url || rowObj.href || ''),
            };
          })
          .filter((row) => row.name || row.url)
          .slice(0, 250);
        return {
          title: String(cfg.title || cfg.name || 'Links').trim() || 'Links',
          showUrl: cfg.showUrl !== false,
          links: links.length ? links : [{ name: '', url: '' }],
        };
      };

      const normalizeDeploymentSummaryConfigForForm = (cfgRaw) => {
        const cfg = (cfgRaw && typeof cfgRaw === 'object') ? cfgRaw : {};
        const stats = (cfg.stats && typeof cfg.stats === 'object') ? cfg.stats : {};
        let showOnline = stats.online !== false;
        let showOffline = stats.offline !== false;
        let showTotal = stats.total !== false;
        if (!showOnline && !showOffline && !showTotal) showOnline = true;
        const columnsRaw = Number(cfg.columns);
        return {
          columns: Number.isFinite(columnsRaw) ? Math.max(1, Math.min(4, Math.round(columnsRaw))) : 3,
          stats: {
            online: showOnline,
            offline: showOffline,
            total: showTotal,
          },
        };
      };

      const buildSysDiskRowHtml = (disk) => {
        const safeDisk = (disk && typeof disk === 'object') ? disk : {};
        return `<div class="sys-widget-disk-row" data-sys-disk-row>` +
          `<label class="sys-widget-field"><span>Path</span><input type="text" class="settings-input" name="disk_path" value="${escHtml(String(safeDisk.path || '/').trim() || '/')}" placeholder="/" /></label>` +
          `<label class="sys-widget-field"><span>Label</span><input type="text" class="settings-input" name="disk_label" value="${escHtml(String(safeDisk.label || '').trim())}" placeholder="e.g. Media" /></label>` +
          `<button class="secondary-button sys-widget-disk-remove" type="button" data-sys-disk-remove aria-label="Remove disk">Remove</button>` +
          `</div>`;
      };

      const buildSysLinkRowHtml = (link) => {
        const safeLink = (link && typeof link === 'object') ? link : {};
        return `<div class="sys-widget-link-row" data-sys-link-row>` +
          `<label class="sys-widget-field"><span>Name</span><input type="text" class="settings-input" name="link_name" value="${escHtml(String(safeLink.name || '').trim())}" placeholder="e.g. GitHub" /></label>` +
          `<label class="sys-widget-field"><span>URL</span><input type="url" class="settings-input" name="link_url" value="${escHtml(String(safeLink.url || '').trim())}" placeholder="https://github.com" /></label>` +
          `<div class="sys-widget-link-actions">` +
            `<button class="secondary-button sys-widget-link-add" type="button" data-sys-link-add-row aria-label="Add row below">+</button>` +
            `<button class="secondary-button sys-widget-link-remove" type="button" data-sys-link-remove aria-label="Remove row">Remove</button>` +
          `</div>` +
          `</div>`;
      };

      const buildSysWidgetConfigForm = (systemType, cfg) => {
        cfg = cfg || {};
        if (systemType === 'sys-resources') {
          const merged = normalizeSysResourcesConfigForForm(cfg);
          const providerOpts = SEARCH_PROVIDERS
            .map((p) => `<option value="${escHtml(p.id)}"${merged.search.provider === p.id ? ' selected' : ''}>${escHtml(p.label)}</option>`)
            .join('');
          const tzOpts = TIMEZONES
            .map((tz) => `<option value="${escHtml(tz)}"${merged.weather.timezone === tz ? ' selected' : ''}>${escHtml(tz)}</option>`)
            .join('');
          const diskRows = merged.disks.length
            ? merged.disks.map((disk) => buildSysDiskRowHtml(disk)).join('')
            : buildSysDiskRowHtml({ path: '/', label: '' });
          return `<div class="sys-widget-grid">` +
              `<label class="sys-widget-check"><input type="checkbox" name="cpu_enabled"${merged.cpu ? ' checked' : ''} /><span>Show CPU</span></label>` +
              `<label class="sys-widget-check"><input type="checkbox" name="memory_enabled"${merged.memory ? ' checked' : ''} /><span>Show Memory</span></label>` +
              `<label class="sys-widget-check"><input type="checkbox" name="space_show_total"${merged.showTotalSpace ? ' checked' : ''} /><span>Show Total Space (RAM + Disks)</span></label>` +
            `</div>` +
            `<div class="sys-widget-group">` +
              `<div class="sys-widget-group-title">Disks</div>` +
              `<div class="sys-widget-list" data-sys-disk-list>${diskRows}</div>` +
              `<button class="secondary-button sys-widget-disk-add" type="button" data-sys-disk-add>+ Add Disk</button>` +
            `</div>` +
            `<div class="sys-widget-group">` +
              `<label class="sys-widget-check"><input type="checkbox" name="search_enabled"${merged.search.enabled ? ' checked' : ''} /><span>Enable Search</span></label>` +
              `<div class="sys-widget-section" data-sys-search-section${merged.search.enabled ? '' : ' hidden'}>` +
                `<label class="sys-widget-field"><span>Search Provider</span><select class="settings-select" name="search_provider">${providerOpts}</select></label>` +
                `<div class="sys-widget-field-searxng" data-sys-searxng-field${merged.search.provider === 'searxng' ? '' : ' hidden'}>` +
                  `<label class="sys-widget-field"><span>SearXNG Base URL</span><input type="url" class="settings-input" name="search_base_url" value="${escHtml(merged.search.baseUrl || '')}" placeholder="https://searxng.example.com" /></label>` +
                `</div>` +
                `<label class="sys-widget-field"><span>Open In</span><select class="settings-select" name="search_target"><option value="_blank"${merged.search.target !== '_self' ? ' selected' : ''}>New Tab</option><option value="_self"${merged.search.target === '_self' ? ' selected' : ''}>Same Tab</option></select></label>` +
              `</div>` +
            `</div>` +
            `<div class="sys-widget-group">` +
              `<label class="sys-widget-check"><input type="checkbox" name="weather_enabled"${merged.weather.enabled ? ' checked' : ''} /><span>Enable Weather</span></label>` +
              `<div class="sys-widget-section" data-sys-weather-section${merged.weather.enabled ? '' : ' hidden'}>` +
                `<label class="sys-widget-field"><span>Location Label</span><input type="text" class="settings-input" name="weather_label" value="${escHtml(merged.weather.label || 'Home')}" /></label>` +
                `<label class="sys-widget-field"><span>Latitude</span><input type="number" step="any" class="settings-input" name="weather_latitude" value="${escHtml(String(merged.weather.latitude ?? 0))}" /></label>` +
                `<label class="sys-widget-field"><span>Longitude</span><input type="number" step="any" class="settings-input" name="weather_longitude" value="${escHtml(String(merged.weather.longitude ?? 0))}" /></label>` +
                `<label class="sys-widget-field"><span>Timezone</span><select class="settings-select" name="weather_timezone">${tzOpts}</select></label>` +
                `<label class="sys-widget-field"><span>Units</span><select class="settings-select" name="weather_units"><option value="metric"${merged.weather.units !== 'imperial' ? ' selected' : ''}>Metric (°C)</option><option value="imperial"${merged.weather.units === 'imperial' ? ' selected' : ''}>Imperial (°F)</option></select></label>` +
                `<label class="sys-widget-field"><span>Cache (minutes)</span><input type="number" min="1" max="60" class="settings-input" name="weather_cache" value="${escHtml(String(merged.weather.cache || 5))}" /></label>` +
              `</div>` +
            `</div>`;
        }
        if (systemType === 'links') {
          const merged = normalizeLinksConfigForForm(cfg);
          const linkRowsHtml = merged.links.map((link) => buildSysLinkRowHtml(link)).join('');
          return `<div class="sys-widget-group">` +
              `<label class="sys-widget-field"><span>Widget Name</span><input type="text" class="settings-input" name="links_title" value="${escHtml(merged.title)}" placeholder="Links" /></label>` +
              `<label class="sys-widget-check"><input type="checkbox" name="links_show_url"${merged.showUrl ? ' checked' : ''} /><span>Show URL / domain in list</span></label>` +
            `</div>` +
            `<div class="sys-widget-group">` +
              `<div class="sys-widget-group-title">Links</div>` +
              `<div class="sys-widget-list sys-widget-links-list" data-sys-link-list>${linkRowsHtml}</div>` +
              `<button class="secondary-button sys-widget-link-add-global" type="button" data-sys-link-add>+ Add Link</button>` +
            `</div>`;
        }
        if (systemType === 'deployment-summary') {
          const merged = normalizeDeploymentSummaryConfigForForm(cfg);
          return `<div class="sys-widget-group">` +
              `<label class="sys-widget-field"><span>Stat Columns (Wrap)</span><select class="settings-select" name="deployment_columns">` +
                `<option value="1"${merged.columns === 1 ? ' selected' : ''}>1</option>` +
                `<option value="2"${merged.columns === 2 ? ' selected' : ''}>2</option>` +
                `<option value="3"${merged.columns === 3 ? ' selected' : ''}>3</option>` +
                `<option value="4"${merged.columns === 4 ? ' selected' : ''}>4</option>` +
              `</select></label>` +
            `</div>` +
            `<div class="sys-widget-group">` +
              `<div class="sys-widget-group-title">Visible Stats</div>` +
              `<label class="sys-widget-check"><input type="checkbox" name="deployment_show_online"${merged.stats.online ? ' checked' : ''} /><span>Online</span></label>` +
              `<label class="sys-widget-check"><input type="checkbox" name="deployment_show_offline"${merged.stats.offline ? ' checked' : ''} /><span>Offline</span></label>` +
              `<label class="sys-widget-check"><input type="checkbox" name="deployment_show_total"${merged.stats.total ? ' checked' : ''} /><span>Total</span></label>` +
              `<div class="settings-users-note">At least one stat remains visible.</div>` +
            `</div>`;
        }
        return '';
      };

      const readSysWidgetConfigForm = (systemType) => {
        if (!sysWidgetModalBody) return {};
        const get = (name) => { const el = sysWidgetModalBody.querySelector(`[name="${name}"]`); return el ? el.value : ''; };
        const checked = (name) => {
          const el = sysWidgetModalBody.querySelector(`[name="${name}"]`);
          return Boolean(el && el.checked);
        };
        if (systemType === 'sys-resources') {
          const provider = String(get('search_provider') || 'duckduckgo').trim().toLowerCase();
          const searchProvider = SEARCH_PROVIDER_IDS.has(provider) ? provider : 'duckduckgo';
          const searchEnabled = checked('search_enabled');
          const weatherEnabled = checked('weather_enabled');
          const disks = Array.from(sysWidgetModalBody.querySelectorAll('[data-sys-disk-row]'))
            .map((rowEl) => ({
              path: String(rowEl.querySelector('[name="disk_path"]')?.value || '').trim() || '/',
              label: String(rowEl.querySelector('[name="disk_label"]')?.value || '').trim(),
            }))
            .filter((disk) => disk.path);
          return {
            cpu: checked('cpu_enabled'),
            memory: checked('memory_enabled'),
            showTotalSpace: checked('space_show_total'),
            disks,
            search: {
              enabled: searchEnabled,
              provider: searchProvider,
              target: get('search_target') === '_self' ? '_self' : '_blank',
              baseUrl: searchProvider === 'searxng' ? String(get('search_base_url') || '').trim() : '',
            },
            weather: {
              enabled: weatherEnabled,
              label: String(get('weather_label') || '').trim() || 'Home',
              latitude: Number(get('weather_latitude')) || 0,
              longitude: Number(get('weather_longitude')) || 0,
              timezone: get('weather_timezone') || 'UTC',
              units: get('weather_units') === 'imperial' ? 'imperial' : 'metric',
              cache: Math.max(1, Math.min(60, Number(get('weather_cache')) || 5)),
            },
          };
        }
        if (systemType === 'links') {
          const links = Array.from(sysWidgetModalBody.querySelectorAll('[data-sys-link-row]'))
            .map((rowEl) => {
              const name = String(rowEl.querySelector('[name="link_name"]')?.value || '').trim();
              const url = normalizeLinksUrlForForm(rowEl.querySelector('[name="link_url"]')?.value || '');
              if (!url && !name) return null;
              return { name, url };
            })
            .filter((row) => row && row.url)
            .slice(0, 250);
          return {
            title: String(get('links_title') || '').trim() || 'Links',
            showUrl: checked('links_show_url'),
            links,
          };
        }
        if (systemType === 'deployment-summary') {
          const columnsRaw = Number(get('deployment_columns'));
          let showOnline = checked('deployment_show_online');
          let showOffline = checked('deployment_show_offline');
          let showTotal = checked('deployment_show_total');
          if (!showOnline && !showOffline && !showTotal) showOnline = true;
          return {
            columns: Number.isFinite(columnsRaw) ? Math.max(1, Math.min(4, Math.round(columnsRaw))) : 3,
            stats: {
              online: showOnline,
              offline: showOffline,
              total: showTotal,
            },
          };
        }
        return {};
      };

      const bindSysWidgetConfigFormInteractions = (systemType) => {
        if (!sysWidgetModalBody) return;
        if (systemType === 'sys-resources') {
          const diskList = sysWidgetModalBody.querySelector('[data-sys-disk-list]');
          const addDiskBtn = sysWidgetModalBody.querySelector('[data-sys-disk-add]');
          const searchEnabledEl = sysWidgetModalBody.querySelector('[name="search_enabled"]');
          const searchSectionEl = sysWidgetModalBody.querySelector('[data-sys-search-section]');
          const providerSelect = sysWidgetModalBody.querySelector('[name="search_provider"]');
          const searxngField = sysWidgetModalBody.querySelector('[data-sys-searxng-field]');
          const weatherEnabledEl = sysWidgetModalBody.querySelector('[name="weather_enabled"]');
          const weatherSectionEl = sysWidgetModalBody.querySelector('[data-sys-weather-section]');

          const syncSearchVisibility = () => {
            if (searchSectionEl) searchSectionEl.hidden = !(searchEnabledEl && searchEnabledEl.checked);
          };
          const syncSearxngVisibility = () => {
            if (!searxngField) return;
            const enabled = Boolean(searchEnabledEl && searchEnabledEl.checked);
            const provider = String(providerSelect && providerSelect.value || '').trim().toLowerCase();
            searxngField.hidden = !enabled || provider !== 'searxng';
          };
          const syncWeatherVisibility = () => {
            if (weatherSectionEl) weatherSectionEl.hidden = !(weatherEnabledEl && weatherEnabledEl.checked);
          };

          if (addDiskBtn && diskList) {
            addDiskBtn.addEventListener('click', () => {
              diskList.insertAdjacentHTML('beforeend', buildSysDiskRowHtml({ path: '/', label: '' }));
            });
          }
          if (diskList) {
            diskList.addEventListener('click', (e) => {
              const removeBtn = e.target.closest('[data-sys-disk-remove]');
              if (!removeBtn) return;
              const rowEl = removeBtn.closest('[data-sys-disk-row]');
              if (!rowEl) return;
              const allRows = diskList.querySelectorAll('[data-sys-disk-row]');
              if (allRows.length <= 1) {
                const pathInput = rowEl.querySelector('[name="disk_path"]');
                const labelInput = rowEl.querySelector('[name="disk_label"]');
                if (pathInput) pathInput.value = '/';
                if (labelInput) labelInput.value = '';
                return;
              }
              rowEl.remove();
            });
          }
          if (searchEnabledEl) searchEnabledEl.addEventListener('change', () => { syncSearchVisibility(); syncSearxngVisibility(); });
          if (providerSelect) providerSelect.addEventListener('change', syncSearxngVisibility);
          if (weatherEnabledEl) weatherEnabledEl.addEventListener('change', syncWeatherVisibility);

          syncSearchVisibility();
          syncSearxngVisibility();
          syncWeatherVisibility();
          return;
        }
        if (systemType === 'links') {
          const linksList = sysWidgetModalBody.querySelector('[data-sys-link-list]');
          const addLinkBtn = sysWidgetModalBody.querySelector('[data-sys-link-add]');
          if (!linksList) return;

          const addRow = (afterRowEl) => {
            const html = buildSysLinkRowHtml({ name: '', url: '' });
            if (afterRowEl && afterRowEl.parentElement === linksList) afterRowEl.insertAdjacentHTML('afterend', html);
            else linksList.insertAdjacentHTML('beforeend', html);
            const nextRow = afterRowEl ? afterRowEl.nextElementSibling : linksList.lastElementChild;
            const nameInput = nextRow && nextRow.querySelector('[name="link_name"]');
            if (nameInput) nameInput.focus();
          };

          if (addLinkBtn) addLinkBtn.addEventListener('click', () => addRow(null));
          linksList.addEventListener('click', (e) => {
            const addRowBtn = e.target.closest('[data-sys-link-add-row]');
            if (addRowBtn) {
              const rowEl = addRowBtn.closest('[data-sys-link-row]');
              addRow(rowEl || null);
              return;
            }
            const removeBtn = e.target.closest('[data-sys-link-remove]');
            if (!removeBtn) return;
            const rowEl = removeBtn.closest('[data-sys-link-row]');
            if (!rowEl) return;
            const rows = linksList.querySelectorAll('[data-sys-link-row]');
            if (rows.length <= 1) {
              const nameInput = rowEl.querySelector('[name="link_name"]');
              const urlInput = rowEl.querySelector('[name="link_url"]');
              if (nameInput) nameInput.value = '';
              if (urlInput) urlInput.value = '';
              return;
            }
            rowEl.remove();
          });
        }
      };

      const openSysWidgetConfigModal = (barId, rowId, systemType, existingConfig, widgetId) => {
        if (!sysWidgetModal || !sysWidgetModalBody) return;
        const titleEl = sysWidgetModal.querySelector('[id="sysWidgetModalTitle"]');
        const sysTypes = Array.isArray(window._systemWidgetTypes) ? window._systemWidgetTypes : [];
        const typeDef = sysTypes.find((t) => t.typeId === systemType);
        if (titleEl) titleEl.textContent = widgetId ? `Edit ${typeDef ? typeDef.label : systemType}` : `Add ${typeDef ? typeDef.label : systemType}`;
        sysWidgetModalBody.innerHTML = buildSysWidgetConfigForm(systemType, existingConfig);
        bindSysWidgetConfigFormInteractions(systemType);
        sysWidgetModalState = { barId, rowId, systemType, widgetId: widgetId || null };
        sysWidgetModal.hidden = false;
      };

      const closeSysWidgetModal = () => {
        if (sysWidgetModal) sysWidgetModal.hidden = true;
        sysWidgetModalState = null;
      };

      // System widget modal button handlers
      if (sysWidgetModal) {
        sysWidgetModal.addEventListener('click', async (e) => {
          if (e.target.closest('[data-sys-widget-modal-close]') || e.target.closest('[data-sys-widget-modal-cancel]')) {
            closeSysWidgetModal();
            return;
          }
          if (e.target.closest('[data-sys-widget-modal-apply]')) {
            if (!sysWidgetModalState) return;
            const { barId, rowId, systemType, widgetId } = sysWidgetModalState;
            const systemConfig = readSysWidgetConfigForm(systemType);
            if (widgetId) {
              // Update existing system widget config
              try {
                const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}/widgets/${encodeURIComponent(widgetId)}`, {
                  method: 'PUT',
                  credentials: 'same-origin',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ systemConfig }),
                });
                const data = await resp.json().catch(() => ({}));
                if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to update widget config.');
                // Update the chip in the canvas
                if (canvas) {
                  const rowEl = canvas.querySelector(`.widget-bar-row[data-row-id="${CSS.escape(rowId)}"][data-bar-id="${CSS.escape(barId)}"]`);
                  const chipEl = rowEl
                    ? rowEl.querySelector(`.widget-canvas-system-chip[data-widget-id="${CSS.escape(widgetId)}"]`)
                    : null;
                  if (chipEl) {
                    chipEl.dataset.systemConfig = JSON.stringify(systemConfig);
                    const editBtn = chipEl.querySelector('[data-sys-widget-edit]');
                    if (editBtn) editBtn.dataset.systemConfig = JSON.stringify(systemConfig);
                    const labelEl = chipEl.querySelector('.system-chip-canvas-label');
                    if (labelEl) {
                      const sysTypes2 = Array.isArray(window._systemWidgetTypes) ? window._systemWidgetTypes : [];
                      const td = sysTypes2.find((t) => t.typeId === systemType);
                      const typeName = td ? td.label : systemType;
                      const summary = getSystemWidgetSummary(systemType, systemConfig);
                      const sub = summary ? ` <small class="muted-hint"> ${escHtml(summary)}</small>` : '';
                      labelEl.innerHTML = escHtml(typeName) + sub;
                    }
                    const previewEl = chipEl.querySelector('[data-system-preview]');
                    if (previewEl) {
                      previewEl.setAttribute('data-system-config', JSON.stringify(systemConfig));
                      delete previewEl.dataset.renderedConfig;
                      refreshSystemPreviewCard(previewEl);
                    }
                  }
                }
                closeSysWidgetModal();
              } catch (err) { alert(err.message || 'Failed to update widget config.'); }
            } else {
              // Add new system widget
              closeSysWidgetModal();
              await addSystemWidgetToRow(barId, rowId, systemType, systemConfig);
            }
            return;
          }
        });
      }

      // Remove widget from a specific row
      const removeWidgetFromRow = async (barId, rowId, widgetId, btn) => {
        if (!barId || !rowId || !widgetId) return;
        const card = btn.closest('[data-widget-id]');
        btn.disabled = true;
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}/widgets/${encodeURIComponent(widgetId)}`, { method: 'DELETE', credentials: 'same-origin' });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to remove widget.');
          if (widgetCustomizeState && widgetCustomizeState.cardEl === card) closeWidgetCustomizeModal();
          if (card) card.remove();
          refreshBarAddMenus(barId);
        } catch (err) {
          btn.disabled = false;
          alert(err.message || 'Failed to remove widget.');
        }
      };

      // Save row settings via PUT
      const clampPreviewMaxCols = (value) => {
        const n = Number(value);
        if (!Number.isFinite(n)) return 0;
        return Math.max(0, Math.min(20, Math.round(n)));
      };

      const applyRowPreviewLayout = (barId, rowId, settings) => {
        if (!canvas || !barId || !rowId) return;
        const rowEl = canvas.querySelector(`.widget-bar-row[data-row-id="${CSS.escape(rowId)}"][data-bar-id="${CSS.escape(barId)}"]`);
        const rowBody = rowEl && rowEl.querySelector('[data-bar-body]');
        if (!rowBody) return;
        const s = settings && typeof settings === 'object' ? settings : {};
        rowBody.classList.toggle('row--fixed-width', Boolean(s.fixedWidth));
        rowBody.classList.toggle('row--scroll', Boolean(s.scroll));
        rowBody.classList.toggle('row--fill', Boolean(s.fill));
        const maxCols = clampPreviewMaxCols(s.maxCols);
        if (maxCols > 0) rowBody.style.setProperty('--row-max-cols', String(maxCols));
        else rowBody.style.removeProperty('--row-max-cols');
      };

      const saveRowSettings = async (barId, rowId, panelEl, btn) => {
        if (!barId || !rowId) return;
        const maxCols = Number(panelEl.querySelector('[data-row-setting="maxCols"]')?.value || 0);
        const fixedWidth = Boolean(panelEl.querySelector('[data-row-setting="fixedWidth"]')?.checked);
        const scroll = Boolean(panelEl.querySelector('[data-row-setting="scroll"]')?.checked);
        const fill = Boolean(panelEl.querySelector('[data-row-setting="fill"]')?.checked);
        const origText = btn ? btn.textContent : '';
        if (btn) btn.disabled = true;
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}`, {
            method: 'PUT',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ maxCols, fixedWidth, scroll, fill }),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to save row settings.');
          applyRowPreviewLayout(barId, rowId, { maxCols, fixedWidth, scroll, fill });
          refreshBarScrollButtons(barId);
          if (btn) { btn.textContent = 'Applied!'; setTimeout(() => { btn.textContent = origText; if (btn) btn.disabled = false; }, 1500); }
          closeAllRowSettingsPanels(null);
        } catch (err) {
          if (btn) btn.disabled = false;
          alert(err.message || 'Failed to save row settings.');
        }
      };

      // Delete a row via DELETE
      const deleteRow = async (barId, rowId, btn) => {
        if (!barId || !rowId) return;
        if (!confirm('Delete this row and all its widgets?')) return;
        if (btn) btn.disabled = true;
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows/${encodeURIComponent(rowId)}`, { method: 'DELETE', credentials: 'same-origin' });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to delete row.');
          const rowEl = canvas && canvas.querySelector(`.widget-bar-row[data-row-id="${CSS.escape(rowId)}"][data-bar-id="${CSS.escape(barId)}"]`);
          if (rowEl) rowEl.remove();
          refreshBarAddMenus(barId);
          refreshBarScrollButtons(barId);
        } catch (err) {
          if (btn) btn.disabled = false;
          alert(err.message || 'Failed to delete row.');
        }
      };

      // Add a new row to a bar
      const addRow = async (barId, btn, position = 'bottom') => {
        if (!barId) return;
        const insertAtTop = String(position || '').trim().toLowerCase() === 'top';
        const barEl = canvas && canvas.querySelector(`.widget-bar-canvas-row[data-bar-id="${CSS.escape(barId)}"]`);
        const rowsWrap = barEl && barEl.querySelector('[data-rows-wrap]');
        const beforeRowId = insertAtTop
          ? String(rowsWrap && rowsWrap.querySelector('.widget-bar-row[data-row-id]')?.dataset.rowId || '').trim()
          : '';
        if (btn) btn.disabled = true;
        try {
          const resp = await fetch(`/api/widget-bars/${encodeURIComponent(barId)}/rows`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(beforeRowId ? { beforeRowId } : {}),
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to add row.');
          const savedBar = data.item;
          if (!savedBar || !canvas) return;
          const apps = Array.isArray(window._widgetBarApps) ? window._widgetBarApps : [];
          if (!rowsWrap) return;
          rowsWrap.innerHTML = buildBarRowsWrapHtml(savedBar, apps);
          refreshBarAddMenus(barId);
          refreshBarScrollButtons(barId);
        } catch (err) {
          alert(err.message || 'Failed to add row.');
        } finally {
          if (btn) btn.disabled = false;
        }
      };

      // Create new bar
      const createBtn = panel.querySelector('#createWidgetBarBtn');
      if (createBtn) {
        createBtn.addEventListener('click', async () => {
          const name = 'Widgets';
          createBtn.disabled = true;
          setCreateStatus('Creating…', false);
          try {
            const resp = await fetch('/api/widget-bars', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name, visibilityRoles: ['user', 'co-admin', 'admin'], refreshSeconds: 60 }),
            });
            const data = await resp.json().catch(() => ({}));
            if (!resp.ok || !data.ok) throw new Error(data.error || 'Failed to create widget bar.');
            const bar = data.item;
            if (!bar || !canvas) throw new Error('Unexpected response.');
            const apps = Array.isArray(window._widgetBarApps) ? window._widgetBarApps : [];
            const barId = escHtml(bar.id);
            const widgetBarRoleOptions = [
              { value: 'guest', label: 'Guest' },
              { value: 'user', label: 'User' },
              { value: 'co-admin', label: 'Co-admin' },
              { value: 'admin', label: 'Admin' },
            ];
            const widgetBarVisibilityRoles = Array.isArray(bar.visibilityRoles) && bar.visibilityRoles.length
              ? ['guest', 'user', 'co-admin', 'admin'].filter((role) => bar.visibilityRoles.includes(role))
              : (function () {
                  const roleOrder = ['guest', 'user', 'co-admin', 'admin'];
                  const minRole = String(bar.visibilityRole || 'user').trim().toLowerCase();
                  const idx = roleOrder.indexOf(minRole);
                  return idx >= 0 ? roleOrder.slice(idx) : ['user', 'co-admin', 'admin'];
                })();
            const widgetBarRefreshValue = [0, 30, 60, 120].includes(Number(bar.refreshSeconds)) ? Number(bar.refreshSeconds) : 60;
            const widgetBarRefreshSelectHtml =
              `<select class="settings-select widget-bar-canvas-refresh widget-bar-canvas-refresh-select" aria-label="Refresh interval" data-bar-refresh title="Refresh interval">` +
              `<option value="0"${widgetBarRefreshValue === 0 ? ' selected' : ''}>Off</option>` +
              `<option value="30"${widgetBarRefreshValue === 30 ? ' selected' : ''}>30s</option>` +
              `<option value="60"${widgetBarRefreshValue === 60 ? ' selected' : ''}>60s</option>` +
              `<option value="120"${widgetBarRefreshValue === 120 ? ' selected' : ''}>120s</option>` +
              `</select>`;
            const widgetBarRoleFilterHtml =
              `<div class="widget-bar-canvas-role-filter settings-dashboard-role-filter settings-visibility-popover" data-widget-bar-role-filter>` +
              `<button class="settings-visibility-trigger settings-dashboard-role-filter-trigger" type="button" aria-label="Configure widget bar visibility" aria-haspopup="true" aria-expanded="false" data-widget-bar-role-filter-trigger></button>` +
              `<div class="settings-visibility-menu settings-filter-menu settings-dashboard-role-filter-menu" hidden data-widget-bar-role-filter-menu>` +
              `<div class="settings-filter-group-title">Visible To Roles</div>` +
              `<div class="settings-dashboard-role-filter-list">` +
              widgetBarRoleOptions.map((o) => (
                `<label class="settings-dashboard-role-filter-option">` +
                `<input type="checkbox" data-bar-role-value="${escHtml(o.value)}"${widgetBarVisibilityRoles.includes(o.value) ? ' checked' : ''} />` +
                `<span class="settings-dashboard-role-filter-option-label">${escHtml(o.label)}</span>` +
                `</label>`
              )).join('') +
              `</div>` +
              `<div class="settings-users-note settings-dashboard-role-filter-note">No roles selected hides this widget bar.</div>` +
              `</div>` +
              `</div>`;
            const rowsHtml = buildBarRowsWrapHtml(bar, apps);
            const barHtml =
              `<div class="widget-bar-canvas-row" data-bar-id="${barId}">` +
              `<div class="widget-bar-canvas-header">` +
              buildWidgetBarIconPickerHtml(bar.icon) +
              `<input class="settings-input widget-bar-canvas-name" type="text" value="${escHtml(bar.name || 'Widget Bar')}" maxlength="80" aria-label="Widget bar name" data-bar-name />` +
              `<div class="widget-bar-canvas-header-actions">` +
              `<button class="order-button default-app-delete widget-bar-canvas-delete" type="button" data-bar-delete="${barId}" aria-label="Delete widget bar" title="Delete widget bar"><img class="widget-bar-canvas-delete-icon" src="/icons/delete.svg" alt="" /></button>` +
              widgetBarRoleFilterHtml +
              widgetBarRefreshSelectHtml +
              `<button class="plex-iconbtn widget-bar-canvas-scroll-nav widget-bar-canvas-scroll-prev" type="button" data-widget-bar-scroll-prev aria-label="Previous" title="Previous"><div class="plex-chev plex-left" aria-hidden="true"></div></button>` +
              `<button class="plex-iconbtn widget-bar-canvas-scroll-nav widget-bar-canvas-scroll-next" type="button" data-widget-bar-scroll-next aria-label="Next" title="Next"><div class="plex-chev plex-right" aria-hidden="true"></div></button>` +
              `<button class="plex-iconbtn widget-bar-canvas-collapse" type="button" data-bar-collapse-toggle="${barId}" aria-expanded="true" aria-label="Collapse widget bar" title="Collapse widget bar"><div class="plex-doublechev" aria-hidden="true"><div class="plex-chev plex-up"></div><div class="plex-chev plex-down"></div></div></button>` +
              `<button class="primary-button widget-bar-canvas-save" type="button" data-bar-save="${barId}">Save</button>` +
              `</div>` +
              `</div><div class="widget-bar-rows-wrap" data-rows-wrap>${rowsHtml}</div></div>`;
            if (emptyMsg) emptyMsg.hidden = true;
            canvas.insertAdjacentHTML('beforeend', barHtml);
            initWidgetBarIconPicker(canvas.querySelector(`.widget-bar-canvas-row[data-bar-id="${CSS.escape(String(bar.id || ''))}"]`));
            refreshBarAddMenus(bar.id);
            refreshBarScrollButtons(bar.id);
            refreshAllWidgetBarRoleFilterSummaries();
            applyStoredBarCollapseStates();
            setCreateStatus('', false);
          } catch (err) {
            setCreateStatus(err.message || 'Failed to create widget bar.', true);
          } finally {
            createBtn.disabled = false;
          }
        });
      }

      // ── Live stats for canvas cards ──────────────────────────────────────
      const STAT_STATUS_CLASS = { up: 'is-up', down: 'is-down', unknown: 'is-unknown' };
      const STAT_STATUS_LABEL = { up: 'Online', down: 'Offline', unknown: 'Unknown' };

      const applyCanvasLibraryFilter = (metrics, libraryInfo, selectedLibraryKeys) => {
        if (!Array.isArray(libraryInfo) || !libraryInfo.length || !selectedLibraryKeys) return metrics;
        return metrics.map((m) => {
          const metricKey = normalizeMetricKey(m && m.key);
          const libFilter = selectedLibraryKeys[metricKey];
          if (!Array.isArray(libFilter) || !libFilter.length) return m;
          const libFilterSet = new Set(libFilter.map((k) => String(k || '').trim()));
          const filteredTotal = libraryInfo
            .filter((lib) => normalizeMetricKey(lib && lib.metricKey) === metricKey && libFilterSet.has(String(lib.key || '').trim()))
            .reduce((sum, lib) => sum + (Number(lib.count) || 0), 0);
          return { ...m, value: filteredTotal };
        });
      };

      const renderCanvasCard = (cardEl, data) => {
        const statusEl = cardEl.querySelector('.stat-card-status');
        const metricsEl = cardEl.querySelector('.stat-card-metrics');
        if (!statusEl || !metricsEl) return;
        const statusKey = (data && (data.status === 'up' || data.status === 'down')) ? data.status : 'unknown';
        Object.values(STAT_STATUS_CLASS).forEach((cls) => statusEl.classList.remove(cls));
        statusEl.classList.add(STAT_STATUS_CLASS[statusKey]);
        statusEl.textContent = STAT_STATUS_LABEL[statusKey] || 'Unknown';
        const rawLibraryInfo = Array.isArray(data && data.libraryInfo) ? data.libraryInfo : null;
        if (rawLibraryInfo) cardEl.dataset.widgetLibraryInfo = JSON.stringify(rawLibraryInfo);
        else delete cardEl.dataset.widgetLibraryInfo;
        const selectedLibraryKeys = parseCardSelectedLibraryKeys(cardEl);
        let allMetrics = Array.isArray(data && data.metrics) ? data.metrics : [];
        if (rawLibraryInfo && selectedLibraryKeys) allMetrics = applyCanvasLibraryFilter(allMetrics, rawLibraryInfo, selectedLibraryKeys);
        const metricOptions = allMetrics
          .map((m) => ({ key: normalizeMetricKey(m && m.key), label: String((m && (m.label || m.key)) || '').trim() }))
          .filter((m) => m.key);
        if (metricOptions.length) cardEl.dataset.widgetMetricOptions = JSON.stringify(metricOptions);
        else delete cardEl.dataset.widgetMetricOptions;
        const selectedMetricKeys = parseCardSelectedMetricKeys(cardEl);
        const selectedMetricKeySet = Array.isArray(selectedMetricKeys) ? new Set(selectedMetricKeys.map(normalizeMetricKey)) : null;
        const metrics = allMetrics
          .filter((m) => !selectedMetricKeySet || selectedMetricKeySet.has(normalizeMetricKey(m && m.key)));
        if (!cardEl.hasAttribute('data-widget-metric-cols')) {
          const autoMetricCols = Math.max(1, Math.min(4, Math.round(Number(metrics.length || allMetrics.length || 2))));
          applyCardMetricColumnsData(cardEl, autoMetricCols);
        }
        if (metrics.length) {
          metricsEl.innerHTML = metrics.map((m) => {
            const val = m.value !== undefined && m.value !== null ? String(m.value) : '—';
            return '<span class="stat-card-metric">' +
              '<span class="stat-card-metric-value">' + escHtml(val) + '</span>' +
              '<span class="stat-card-metric-label">' + escHtml(String(m.label || m.key || '')) + '</span>' +
              '</span>';
          }).join('');
        } else {
          metricsEl.innerHTML = '';
        }
        cardEl.classList.remove('is-loading');
      };

      const renderCanvasCardError = (cardEl) => {
        const statusEl = cardEl.querySelector('.stat-card-status');
        const metricsEl = cardEl.querySelector('.stat-card-metrics');
        if (statusEl) {
          Object.values(STAT_STATUS_CLASS).forEach((cls) => statusEl.classList.remove(cls));
          statusEl.classList.add(STAT_STATUS_CLASS.down);
          statusEl.textContent = STAT_STATUS_LABEL.down;
        }
        if (metricsEl) metricsEl.innerHTML = '';
        cardEl.classList.remove('is-loading');
      };

      const SYS_PREVIEW_SEARCH_PROVIDER_URLS = {
        duckduckgo: 'https://duckduckgo.com/?q={query}',
        google: 'https://www.google.com/search?q={query}',
        bing: 'https://www.bing.com/search?q={query}',
        brave: 'https://search.brave.com/search?q={query}',
      };
      const SYS_PREVIEW_WEATHER_ICONS = {
        'clear': '/icons/weather-clear.svg',
        'mainly-clear': '/icons/weather-mainly-clear.svg',
        'partly-cloudy': '/icons/weather-partly-cloudy.svg',
        'overcast': '/icons/weather-overcast.svg',
        'foggy': '/icons/weather-foggy.svg',
        'drizzle': '/icons/weather-drizzle.svg',
        'rainy': '/icons/weather-rainy.svg',
        'snowy': '/icons/weather-snowy.svg',
        'showers': '/icons/weather-showers.svg',
        'stormy': '/icons/weather-stormy.svg',
      };
      const SYS_PREVIEW_WEATHER_ICON_FALLBACK = '/icons/weather.svg';
      const SYS_PREVIEW_SEARCH_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>';
      const getLinksPreviewInitials = (label, fallback) => {
        const source = String(label || '').trim() || String(fallback || '').trim();
        if (!source) return '??';
        const tokens = source
          .replace(/[_\-.]+/g, ' ')
          .split(/\s+/)
          .map((token) => token.trim())
          .filter(Boolean);
        if (tokens.length >= 2) return `${tokens[0][0] || ''}${tokens[1][0] || ''}`.toUpperCase();
        return source.replace(/[^a-z0-9]/gi, '').slice(0, 2).toUpperCase() || source.slice(0, 2).toUpperCase();
      };
      const normalizeLinksPreviewUrl = (rawValue) => {
        const input = String(rawValue || '').trim();
        if (!input) return '';
        let candidate = input;
        if (!/^[a-z][a-z0-9+.-]*:/i.test(candidate)) candidate = `https://${candidate}`;
        try {
          const parsed = new URL(candidate);
          if (!parsed.hostname) return '';
          if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') return '';
          return parsed.toString();
        } catch (_err) {
          return '';
        }
      };
      const bindLinksPreviewFavicons = (rootEl) => {
        if (!rootEl || !(rootEl instanceof Element)) return;
        rootEl.querySelectorAll('img[data-link-favicon]').forEach((img) => {
          if (img._linksFaviconBound) return;
          img._linksFaviconBound = true;
          img.addEventListener('error', () => {
            const fallbackSrc = String(img.dataset.fallbackSrc || '').trim();
            const triedFallback = img.dataset.fallbackTried === '1';
            if (fallbackSrc && !triedFallback && img.src !== fallbackSrc) {
              img.dataset.fallbackTried = '1';
              img.src = fallbackSrc;
              return;
            }
            img.style.display = 'none';
            const initialsEl = img.closest('.dashboard-links-avatar')?.querySelector('.dashboard-links-initials');
            if (initialsEl) initialsEl.hidden = false;
          });
        });
      };

      const handleSystemPreviewSearchSubmit = (form) => {
        const input = form.querySelector('.system-search-input');
        if (!input) return;
        const query = String(input.value || '').trim();
        if (!query) return;
        const provider = String(form.dataset.searchProvider || 'duckduckgo').trim().toLowerCase();
        const target = form.dataset.searchTarget === '_self' ? '_self' : '_blank';
        let url = '';
        if (provider === 'searxng') {
          const baseUrl = String(form.dataset.searchBaseUrl || '').trim().replace(/\/$/, '');
          if (!baseUrl) return;
          url = `${baseUrl}/search?q=${encodeURIComponent(query)}`;
        } else {
          const template = SYS_PREVIEW_SEARCH_PROVIDER_URLS[provider] || SYS_PREVIEW_SEARCH_PROVIDER_URLS.duckduckgo;
          url = template.replace('{query}', encodeURIComponent(query));
        }
        if (target === '_self') window.location.href = url;
        else window.open(url, '_blank', 'noopener,noreferrer');
        input.value = '';
      };

      const bindSystemPreviewSearchForms = (rootEl) => {
        if (!rootEl || !(rootEl instanceof Element)) return;
        rootEl.querySelectorAll('.dashboard-system-search').forEach((form) => {
          if (form._searchBound) return;
          form._searchBound = true;
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            handleSystemPreviewSearchSubmit(form);
          });
        });
      };

      const formatSystemPreviewBytes = (bytes) => {
        if (!Number.isFinite(bytes) || bytes < 0) return '—';
        const units = ['B', 'KB', 'MB', 'GB', 'TB', 'PB'];
        let idx = 0;
        let value = bytes;
        while (value >= 1024 && idx < units.length - 1) {
          value /= 1024;
          idx += 1;
        }
        return `${idx === 0 ? value.toFixed(0) : value.toFixed(2).replace(/\.?0+$/, '')} ${units[idx]}`;
      };
      const normalizeSystemPreviewPath = (value) => {
        let pathValue = String(value || '').trim() || '/';
        if (!pathValue.startsWith('/')) pathValue = `/${pathValue}`;
        pathValue = pathValue.replace(/\/{2,}/g, '/');
        if (pathValue.length > 1) pathValue = pathValue.replace(/\/+$/, '');
        return pathValue || '/';
      };
      const decodeHtmlEntities = (value) => {
        const source = String(value || '');
        if (!source || source.indexOf('&') === -1) return source;
        const textarea = document.createElement('textarea');
        textarea.innerHTML = source;
        return textarea.value;
      };
      const parseSystemConfigValue = (value) => {
        const source = String(value || '').trim() || '{}';
        try { return JSON.parse(source); } catch (_err) { /* try decoded */ }
        const decoded = decodeHtmlEntities(source);
        if (decoded !== source) {
          try { return JSON.parse(decoded); } catch (_err2) { /* ignore */ }
        }
        return {};
      };

      const updateSystemPreviewBarFill = (barFillEl, pct) => {
        if (!barFillEl) return;
        barFillEl.style.width = `${pct}%`;
        barFillEl.classList.toggle('bar-warning', pct >= 70 && pct < 90);
        barFillEl.classList.toggle('bar-danger', pct >= 90);
      };

      const buildSystemPreviewBar = (previewEl) => {
        const raw = previewEl.getAttribute('data-system-config') || '{}';
        const cfg = parseSystemConfigValue(raw);
        const showTotalSpace = cfg.showTotalSpace === true;
        previewEl.dataset.systemShowTotalSpace = showTotalSpace ? '1' : '0';
        let html = '';

        if (cfg.cpu !== false) {
          html += '<div class="dashboard-system-chip is-loading" data-chip-type="cpu">' +
            '<div class="system-chip-row"><img class="system-chip-icon" src="/icons/cpu.svg" alt="" onerror="this.src=\'/icons/app.svg\'" />' +
            '<div class="system-chip-body"><span class="system-chip-value">–</span><span class="system-chip-label">CPU</span></div></div>' +
            '<div class="system-chip-bar"><div class="system-chip-bar-fill"></div></div></div>';
        }
        if (cfg.memory !== false) {
          html += '<div class="dashboard-system-chip is-loading" data-chip-type="memory">' +
            '<div class="system-chip-row"><img class="system-chip-icon" src="/icons/memory.svg" alt="" onerror="this.src=\'/icons/app.svg\'" />' +
            '<div class="system-chip-body"><span class="system-chip-value">–</span><span class="system-chip-label">' + (showTotalSpace ? 'Total' : 'Free') + '</span></div></div>' +
            '<div class="system-chip-bar"><div class="system-chip-bar-fill"></div></div></div>';
        }
        const disks = Array.isArray(cfg.disks) ? cfg.disks : [];
        disks.forEach((disk) => {
          const path = normalizeSystemPreviewPath((disk && disk.path) || '/');
          const label = String((disk && disk.label) || '').trim() || path;
          html += '<div class="dashboard-system-chip is-loading" data-chip-type="disk" data-chip-path="' + escHtml(path) + '" title="' + escHtml(label + ' (' + path + ')') + '">' +
            '<div class="system-chip-row"><img class="system-chip-icon" src="/icons/disk.svg" alt="" onerror="this.src=\'/icons/app.svg\'" />' +
            '<div class="system-chip-body"><span class="system-chip-value">–</span><span class="system-chip-label">' + escHtml(label) + '</span></div></div>' +
            '<div class="system-chip-bar"><div class="system-chip-bar-fill"></div></div></div>';
        });
        const search = (cfg.search && typeof cfg.search === 'object') ? cfg.search : {};
        if (search.enabled) {
          const baseUrl = String(search.baseUrl || '').trim().replace(/\/$/, '');
          html += '<form class="dashboard-system-search" data-search-provider="' + escHtml(search.provider || 'duckduckgo') + '"' +
            ' data-search-target="' + (search.target === '_self' ? '_self' : '_blank') + '"' +
            (search.provider === 'searxng' && baseUrl ? ' data-search-base-url="' + escHtml(baseUrl) + '"' : '') +
            ' action="" method="get" autocomplete="off" novalidate>' +
            '<input class="system-search-input" type="search" name="q" placeholder="Search..." aria-label="Search" />' +
            '<button class="system-search-btn" type="submit" aria-label="Search">' + SYS_PREVIEW_SEARCH_SVG + '</button></form>';
        }
        const weather = (cfg.weather && typeof cfg.weather === 'object') ? cfg.weather : {};
        if (weather.enabled) {
          const weatherLabel = String(weather.label || '').trim();
          html += '<div class="dashboard-system-chip dashboard-system-weather is-loading" data-chip-type="weather"' +
            ' data-weather-label="' + escHtml(weatherLabel) + '"' +
            ' data-weather-lat="' + Number(weather.latitude || 0) + '"' +
            ' data-weather-lon="' + Number(weather.longitude || 0) + '"' +
            ' data-weather-timezone="' + escHtml(String(weather.timezone || 'UTC')) + '"' +
            ' data-weather-units="' + (weather.units === 'imperial' ? 'imperial' : 'metric') + '"' +
            ' data-weather-cache="' + Math.max(1, Math.min(60, Number(weather.cache || 5))) + '">' +
            '<div class="system-chip-row"><img class="system-chip-icon system-weather-icon" src="' + SYS_PREVIEW_WEATHER_ICON_FALLBACK + '" alt="" />' +
            '<div class="system-chip-body"><span class="system-chip-value system-weather-value">–</span>' +
            '<span class="system-chip-label system-weather-condition">Loading…</span></div></div></div>';
        }

        previewEl.innerHTML = html;
        bindSystemPreviewSearchForms(previewEl);
      };

      const buildLinksPreviewWidget = (previewEl) => {
        const raw = previewEl.getAttribute('data-system-config') || '{}';
        const cfg = parseSystemConfigValue(raw);
        const title = String(cfg.title || cfg.name || 'Links').trim() || 'Links';
        const showUrl = cfg.showUrl !== false;
        const links = (Array.isArray(cfg.links) ? cfg.links : [])
          .map((row) => {
            const rowObj = (row && typeof row === 'object') ? row : {};
            const url = normalizeLinksPreviewUrl(rowObj.url || rowObj.href || '');
            if (!url) return null;
            let hostname = '';
            try { hostname = String(new URL(url).hostname || '').trim(); } catch (_err) { /* ignore */ }
            const name = String(rowObj.name || rowObj.title || '').trim() || hostname || url;
            const favicon = hostname ? `${new URL(url).origin}/favicon.ico` : '';
            const fallback = hostname ? `https://www.google.com/s2/favicons?domain=${encodeURIComponent(hostname)}&sz=64` : '';
            return { name, url, hostname, favicon, fallback };
          })
          .filter(Boolean)
          .slice(0, 250);
        const rowsHtml = links.map((link) => {
          const initials = getLinksPreviewInitials(link.name, link.hostname);
          const urlHtml = showUrl ? `<span class="dashboard-links-host">${escHtml(link.hostname || link.url)}</span>` : '';
          return `<a class="dashboard-links-row" href="${escHtml(link.url)}" target="_blank" rel="noopener noreferrer">` +
            `<span class="dashboard-links-avatar">` +
              (link.favicon ? `<img data-link-favicon src="${escHtml(link.favicon)}" data-fallback-src="${escHtml(link.fallback)}" alt="" />` : '') +
              `<span class="dashboard-links-initials"${link.favicon ? ' hidden' : ''}>${escHtml(initials)}</span>` +
            `</span>` +
            `<span class="dashboard-links-name">${escHtml(link.name)}</span>` +
            urlHtml +
          `</a>`;
        }).join('');
        previewEl.innerHTML = `<div class="dashboard-links-title">${escHtml(title)}</div>` +
          `<div class="dashboard-links-list">${rowsHtml || '<div class="dashboard-links-empty">No links configured yet</div>'}</div>`;
        bindLinksPreviewFavicons(previewEl);
      };

      const buildDeploymentSummaryPreviewWidget = (previewEl) => {
        const raw = previewEl.getAttribute('data-system-config') || '{}';
        const cfg = parseSystemConfigValue(raw);
        const stats = (cfg.stats && typeof cfg.stats === 'object') ? cfg.stats : {};
        let showOnline = stats.online !== false;
        let showOffline = stats.offline !== false;
        let showTotal = stats.total !== false;
        if (!showOnline && !showOffline && !showTotal) showOnline = true;
        const visibleStats = [];
        if (showOnline) visibleStats.push({ key: 'online', label: 'Online' });
        if (showOffline) visibleStats.push({ key: 'offline', label: 'Offline' });
        if (showTotal) visibleStats.push({ key: 'total', label: 'Total' });
        const rawColumns = Number(cfg.columns);
        let columns = Number.isFinite(rawColumns) ? Math.max(1, Math.min(4, Math.round(rawColumns))) : 3;
        columns = Math.min(columns, Math.max(1, visibleStats.length));
        previewEl.classList.add('deployment-summary-preview');
        previewEl.classList.remove('dashboard-system-bar', 'dashboard-stat-card', 'deployment-summary-stat-card');
        previewEl.setAttribute('data-widget-metric-cols', String(columns));
        previewEl.classList.add('is-loading');
        const metricsHtml = visibleStats
          .map((stat) => `<span class="stat-card-metric" data-deployment-stat="${escHtml(stat.key)}">` +
            `<span class="stat-card-metric-value">0</span>` +
            `<span class="stat-card-metric-label">${escHtml(stat.label)}</span></span>`)
          .join('');
        previewEl.innerHTML =
          `<div class="stat-card-header">` +
            `<img class="stat-card-icon" src="/icons/launcharr-icon.png" alt="" onerror="this.src='/icons/app.svg'" />` +
            `<span class="stat-card-name">Launcharr</span>` +
            `<span class="stat-card-status is-down">0.0%</span>` +
          `</div>` +
          `<div class="stat-card-metrics">${metricsHtml}</div>`;
      };

      const renderDeploymentSummaryPreviewWithData = (previewEl, data) => {
        const onlineRaw = (data && data.onlineWidgets != null) ? data.onlineWidgets : (data && data.online);
        const offlineRaw = (data && data.offlineWidgets != null) ? data.offlineWidgets : (data && data.offline);
        const unknownRaw = (data && data.unknownWidgets != null) ? data.unknownWidgets : (data && data.unknown);
        const totalRaw = (data && data.totalWidgets != null) ? data.totalWidgets : (data && data.total);
        const online = Number(onlineRaw) || 0;
        const offline = Number(offlineRaw) || 0;
        const unknown = Number(unknownRaw) || 0;
        const total = Number(totalRaw) || 0;
        const values = {
          online,
          offline: offline + unknown,
          total: Math.max(total, online + offline + unknown),
        };
        ['online', 'offline', 'total'].forEach((key) => {
          const metricEl = previewEl.querySelector(`[data-deployment-stat="${CSS.escape(key)}"]`);
          if (!metricEl) return;
          const valEl = metricEl.querySelector('.stat-card-metric-value');
          if (valEl) valEl.textContent = String(Math.max(0, Math.round(values[key] || 0)));
        });
        const statusEl = previewEl.querySelector('.stat-card-status');
        if (statusEl) {
          statusEl.classList.remove('is-up', 'is-warn', 'is-down', 'is-unknown');
          let pct = values.total > 0 ? (values.online / values.total) * 100 : 0;
          if (!Number.isFinite(pct)) pct = 0;
          pct = Math.max(0, Math.min(100, pct));
          const statusClass = pct >= 90 ? 'is-up' : (pct >= 50 ? 'is-warn' : 'is-down');
          statusEl.classList.add(statusClass);
          statusEl.textContent = `${pct.toFixed(1)}%`;
        }
        previewEl.classList.remove('is-loading');
      };

      const renderSystemPreviewWithData = (previewEl, sysData, wxData) => {
        const showTotalSpace = previewEl.dataset.systemShowTotalSpace === '1';
        const cpuChip = previewEl.querySelector('[data-chip-type="cpu"]');
        if (cpuChip && sysData) {
          const pct = Math.max(0, Math.min(100, Number(sysData.cpu && sysData.cpu.percent) || 0));
          const valEl = cpuChip.querySelector('.system-chip-value');
          if (valEl) valEl.textContent = `${pct.toFixed(0)}%`;
          updateSystemPreviewBarFill(cpuChip.querySelector('.system-chip-bar-fill'), pct);
          cpuChip.classList.remove('is-loading');
        }

        const memChip = previewEl.querySelector('[data-chip-type="memory"]');
        if (memChip && sysData) {
          const memFree = Number(sysData.memory && sysData.memory.free) || 0;
          const memTotal = Number(sysData.memory && sysData.memory.total) || 0;
          const memPct = memTotal > 0 ? Math.round((100 * (memTotal - memFree)) / memTotal) : 0;
          const valEl = memChip.querySelector('.system-chip-value');
          if (valEl) valEl.textContent = formatSystemPreviewBytes(showTotalSpace ? memTotal : memFree);
          updateSystemPreviewBarFill(memChip.querySelector('.system-chip-bar-fill'), memPct);
          memChip.classList.remove('is-loading');
        }

        previewEl.querySelectorAll('[data-chip-type="disk"]').forEach((diskChip) => {
          if (!sysData) return;
          const diskPath = normalizeSystemPreviewPath(diskChip.dataset.chipPath || '/');
          const entry = Array.isArray(sysData.disks)
            ? (sysData.disks.find((disk) => normalizeSystemPreviewPath(disk.path) === diskPath)
              || sysData.disks.find((disk) => normalizeSystemPreviewPath(disk.resolvedPath) === diskPath))
            : null;
          const valEl = diskChip.querySelector('.system-chip-value');
          if (entry && entry.ok) {
            const free = Number(entry.free) || 0;
            const total = Number(entry.total) || 0;
            const pct = total > 0 ? Math.round((100 * (total - free)) / total) : 0;
            if (valEl) valEl.textContent = formatSystemPreviewBytes(showTotalSpace ? total : free);
            updateSystemPreviewBarFill(diskChip.querySelector('.system-chip-bar-fill'), pct);
          } else if (valEl) {
            valEl.textContent = '—';
          }
          diskChip.classList.remove('is-loading');
        });

        const weatherChip = previewEl.querySelector('[data-chip-type="weather"]');
        if (weatherChip) {
          const weatherLabel = String(weatherChip.dataset.weatherLabel || '').trim();
          const weatherUnits = weatherChip.dataset.weatherUnits === 'imperial' ? '°F' : '°C';
          const valEl = weatherChip.querySelector('.system-weather-value');
          const condEl = weatherChip.querySelector('.system-weather-condition');
          const iconEl = weatherChip.querySelector('.system-weather-icon');
          if (wxData && wxData.ok) {
            const temp = Number(wxData.temperature).toFixed(1);
            if (valEl) valEl.textContent = `${weatherLabel ? `${weatherLabel}, ` : ''}${temp}${weatherUnits}`;
            if (condEl) condEl.textContent = wxData.condition || '';
            if (iconEl) {
              iconEl.src = SYS_PREVIEW_WEATHER_ICONS[wxData.icon] || SYS_PREVIEW_WEATHER_ICON_FALLBACK;
              iconEl.onerror = function () { this.src = SYS_PREVIEW_WEATHER_ICON_FALLBACK; };
            }
          } else {
            if (valEl) valEl.textContent = weatherLabel || '—';
            if (condEl) condEl.textContent = 'Unavailable';
          }
          weatherChip.classList.remove('is-loading');
        }
      };

      const fetchSystemPreviewInfo = async (diskPaths) => {
        const pathsParam = (diskPaths && diskPaths.length) ? diskPaths.join(',') : '/';
        const resp = await fetch(`/api/system-info?paths=${encodeURIComponent(pathsParam)}`, { credentials: 'same-origin' });
        if (!resp.ok) throw new Error('System info request failed');
        return resp.json();
      };

      const fetchSystemPreviewWeather = async (wxChip) => {
        const lat = Number(wxChip.dataset.weatherLat || 0);
        const lon = Number(wxChip.dataset.weatherLon || 0);
        const timezone = encodeURIComponent(String(wxChip.dataset.weatherTimezone || 'UTC'));
        const units = wxChip.dataset.weatherUnits === 'imperial' ? 'imperial' : 'metric';
        const cache = Math.max(1, Math.min(60, Number(wxChip.dataset.weatherCache || 5)));
        const url = `/api/openmeteo?lat=${lat}&lon=${lon}&timezone=${timezone}&units=${units}&cache=${cache}`;
        const resp = await fetch(url, { credentials: 'same-origin' });
        if (!resp.ok) throw new Error('Weather request failed');
        return resp.json();
      };

      const normalizeDeploymentPreviewStatus = (value) => {
        const raw = String(value || '').trim().toLowerCase();
        if (raw === 'up' || raw === 'online') return 'online';
        if (raw === 'down' || raw === 'offline') return 'offline';
        return 'unknown';
      };

      const fetchDeploymentSummaryPreviewFromBars = async () => {
        const barsResp = await fetch('/api/widget-bars', { credentials: 'same-origin' });
        if (!barsResp.ok) throw new Error('Widget bars request failed');
        const barsData = await barsResp.json().catch(() => ({}));
        const bars = Array.isArray(barsData?.items) ? barsData.items : [];
        const appIds = [];
        const seen = new Set();
        bars.forEach((bar) => {
          const rows = Array.isArray(bar?.rows) ? bar.rows : [];
          rows.forEach((row) => {
            const widgets = Array.isArray(row?.widgets) ? row.widgets : [];
            widgets.forEach((widget) => {
              if (!widget || widget.systemType || widget.available === false) return;
              const appId = String(widget.appId || '').trim();
              if (!appId || seen.has(appId)) return;
              seen.add(appId);
              appIds.push(appId);
            });
          });
        });
        if (!appIds.length) {
          return {
            ok: true,
            online: 0,
            offline: 0,
            unknown: 0,
            total: 0,
            onlineWidgets: 0,
            offlineWidgets: 0,
            unknownWidgets: 0,
            totalWidgets: 0,
          };
        }
        const statuses = await Promise.all(appIds.map(async (appId) => {
          try {
            const resp = await fetch(`/api/widget-stats/${encodeURIComponent(appId)}`, { credentials: 'same-origin' });
            if (!resp.ok) return 'unknown';
            const payload = await resp.json().catch(() => ({}));
            return normalizeDeploymentPreviewStatus(payload?.status);
          } catch (_err) {
            return 'unknown';
          }
        }));
        let online = 0;
        let offline = 0;
        let unknown = 0;
        statuses.forEach((state) => {
          if (state === 'online') online += 1;
          else if (state === 'offline') offline += 1;
          else unknown += 1;
        });
        const total = appIds.length;
        return {
          ok: true,
          online,
          offline,
          unknown,
          total,
          onlineWidgets: online,
          offlineWidgets: offline,
          unknownWidgets: unknown,
          totalWidgets: total,
        };
      };

      const fetchDeploymentSummaryPreview = async () => {
        try {
          const resp = await fetch('/api/widget-deployment-summary', { credentials: 'same-origin' });
          if (!resp.ok) throw new Error('Deployment summary request failed');
          return await resp.json();
        } catch (_err) {
          return fetchDeploymentSummaryPreviewFromBars();
        }
      };

      const refreshSystemPreviewCard = async (previewEl) => {
        if (!previewEl || !document.body.contains(previewEl)) return;
        const rawConfig = String(previewEl.getAttribute('data-system-config') || '{}');
        const previewType = String(previewEl.getAttribute('data-system-type') || (previewEl.classList.contains('dashboard-links-widget') ? 'links' : 'sys-resources')).trim().toLowerCase();
        if (previewType === 'links') {
          if (previewEl.dataset.renderedConfig !== rawConfig) {
            buildLinksPreviewWidget(previewEl);
            previewEl.dataset.renderedConfig = rawConfig;
          }
          return;
        }
        if (previewType === 'deployment-summary') {
          if (previewEl.dataset.renderedConfig !== rawConfig) {
            buildDeploymentSummaryPreviewWidget(previewEl);
            previewEl.dataset.renderedConfig = rawConfig;
          }
          try {
            const data = await fetchDeploymentSummaryPreview();
            renderDeploymentSummaryPreviewWithData(previewEl, data);
          } catch (_err) {
            renderDeploymentSummaryPreviewWithData(previewEl, {});
          }
          return;
        }
        if (previewEl.dataset.renderedConfig !== rawConfig) {
          buildSystemPreviewBar(previewEl);
          previewEl.dataset.renderedConfig = rawConfig;
        }
        const diskPaths = Array.from(previewEl.querySelectorAll('[data-chip-type="disk"][data-chip-path]'))
          .map((chipEl) => chipEl.dataset.chipPath)
          .filter(Boolean);
        const needsResources = Boolean(
          previewEl.querySelector('[data-chip-type="cpu"]')
          || previewEl.querySelector('[data-chip-type="memory"]')
          || diskPaths.length
        );
        const weatherChip = previewEl.querySelector('[data-chip-type="weather"]');
        const resourcePromise = needsResources ? fetchSystemPreviewInfo(diskPaths) : Promise.resolve(null);
        const weatherPromise = weatherChip ? fetchSystemPreviewWeather(weatherChip) : Promise.resolve(null);
        try {
          const [resourceData, weatherData] = await Promise.all([resourcePromise, weatherPromise]);
          renderSystemPreviewWithData(previewEl, resourceData, weatherData);
        } catch (_err) {
          renderSystemPreviewWithData(previewEl, null, null);
        }
      };

      const refreshAllCanvasSystemPreviews = () => {
        if (!canvas) return;
        canvas.querySelectorAll('[data-system-preview]').forEach((previewEl) => {
          refreshSystemPreviewCard(previewEl);
        });
      };

      const fetchAndRenderCard = async (cardEl) => {
        const appId = String(cardEl.dataset.appId || '').trim();
        if (!appId) return;
        try {
          const resp = await fetch('/api/widget-stats/' + encodeURIComponent(appId), { credentials: 'same-origin' });
          if (!resp.ok) { renderCanvasCardError(cardEl); return; }
          const data = await resp.json().catch(() => null);
          renderCanvasCard(cardEl, data);
        } catch (_err) {
          renderCanvasCardError(cardEl);
        }
      };

      const refreshAllCanvasCards = () => {
        if (!canvas) return;
        canvas.querySelectorAll('.widget-canvas-card[data-app-id]').forEach(fetchAndRenderCard);
      };

      // Initial load then poll every 60 seconds
      initAllWidgetBarIconPickers();
      refreshAllBarAddMenus();
      refreshAllWidgetBarRoleFilterSummaries();
      refreshAllBarScrollButtons();
      applyStoredBarCollapseStates();
      refreshAllCanvasCards();
      refreshAllCanvasSystemPreviews();
      setInterval(() => {
        refreshAllCanvasCards();
        refreshAllCanvasSystemPreviews();
      }, 60000);
    };

    initVisibilityToggles();
    attachPlexSettingsActions();
    attachRommSettingsPanelSessionTests();
    attachWidgetBarManager();
    function handleSidebarToggle() {
      if (!dashFrame) return;
      if (isMobile()) {
        dashFrame.classList.remove('sidebar-collapsed');
        const isOpen = dashFrame.classList.toggle('mobile-nav-open');
        document.body.classList.toggle('mobile-nav-open', isOpen);
        if (dashNav) dashNav.scrollTop = 0;
        setToggleIcon(isOpen);
        return;
      }
      const isCollapsed = dashFrame.classList.toggle('sidebar-collapsed');
      safeStorage.set('sidebarCollapsed', isCollapsed ? 'true' : 'false');
      if (dashNav) dashNav.scrollTop = 0;
      setToggleIcon(!isCollapsed);
    }

    toggle?.addEventListener('click', handleSidebarToggle);

    mainContent?.addEventListener('click', (event) => {
      if (event.target.closest('.sidebar-toggle')) return;
      if (event.target.closest('.main-window-bar')) return;
      closeMobileNav();
    });

    sidebar?.addEventListener('click', (event) => {
      if (!isMobile() || !dashFrame?.classList.contains('mobile-nav-open')) return;
      const link = event.target.closest('a');
      if (!link || !link.classList.contains('active')) return;
      try {
        const targetUrl = new URL(link.href, window.location.href);
        const currentPathWithQuery = `${window.location.pathname}${window.location.search}`;
        const targetPathWithQuery = `${targetUrl.pathname}${targetUrl.search}`;
        if (targetPathWithQuery !== currentPathWithQuery) return;
      } catch (err) {
        return;
      }
      event.preventDefault();
      closeMobileNav();
    });

    const userMenus = document.querySelectorAll('[data-user-menu]');

    function closeUserMenus(except) {
      userMenus.forEach((menu) => {
        if (menu === except) return;
        menu.querySelectorAll('[data-user-role-picker][open]').forEach((picker) => { picker.open = false; });
        menu.classList.remove('user-pill--open');
        menu.setAttribute('aria-expanded', 'false');
      });
    }

    userMenus.forEach((menu) => {
      menu.setAttribute('aria-expanded', 'false');
      menu.addEventListener('click', (event) => {
        if (event.target.closest('.user-menu')) return;
        event.preventDefault();
        const isOpen = menu.classList.contains('user-pill--open');
        closeUserMenus(menu);
        menu.classList.toggle('user-pill--open', !isOpen);
        menu.setAttribute('aria-expanded', !isOpen ? 'true' : 'false');
      });
      menu.addEventListener('keydown', (event) => {
        if (event.target.closest('.user-menu')) return;
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        menu.click();
      });
    });

    document.addEventListener('click', (event) => {
      if (event.target.closest('[data-user-menu]')) return;
      closeUserMenus();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      closeUserMenus();
    });
  </script>
  <script>
    try {
      const settingsLogList = document.getElementById('settingsLogList');
      const settingsLogStatus = document.getElementById('settingsLogStatus');
      const settingsLogRefresh = document.getElementById('settingsLogRefresh');
      const settingsLogApp = document.getElementById('settingsLogApp');
      const settingsLogLevel = document.getElementById('settingsLogLevel');
      const settingsWidgetStatusDebug = document.getElementById('settingsWidgetStatusDebug');
      const settingsLogPanel = document.querySelector('.settings-tab-panel[data-tab="log"]');
      const settingsLogTabBtn = document.querySelector('.settings-tab-btn[data-tab="log"]');
      const logAppNames = <%- safeJson((apps || []).reduce((acc, app) => {
        acc[String(app.id || '').toLowerCase()] = app.name || app.id;
        return acc;
      }, {})) %>;
      let settingsLogs = [];

    const escapeLogHtml = (value) => String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const formatLogTime = (value) => {
      const date = value ? new Date(value) : null;
      if (!date || Number.isNaN(date.getTime())) return '';
      return date.toLocaleString();
    };

    const renderSettingsLogs = () => {
      if (!settingsLogList) return;
      const appFilter = String(settingsLogApp?.value || '').trim().toLowerCase();
      const levelFilter = String(settingsLogLevel?.value || '').trim().toLowerCase();
      const filtered = settingsLogs.filter((entry) => {
        if (appFilter && String(entry.app || '').toLowerCase() !== appFilter) return false;
        if (levelFilter && String(entry.level || '').toLowerCase() !== levelFilter) return false;
        return true;
      });
      if (!filtered.length) {
        settingsLogList.innerHTML = '<div class="log-empty">No logs yet.</div>';
        return;
      }
      settingsLogList.innerHTML = filtered
        .map((entry) => {
          const appId = String(entry.app || 'system').toLowerCase();
          const appName = logAppNames[appId] || (appId === 'system' ? 'System' : appId);
          const level = String(entry.level || 'info').toLowerCase();
          const action = String(entry.action || 'event');
          const message = String(entry.message || '');
          const time = formatLogTime(entry.ts);
          return `
            <div class="log-row log-row--${escapeLogHtml(level)}" data-app="${escapeLogHtml(appId)}">
              <div class="log-time">${escapeLogHtml(time)}</div>
              <div class="log-message">
                <div class="log-title">
                  <span class="log-app-pill" data-app="${escapeLogHtml(appId)}">${escapeLogHtml(appName)}</span>
                  ${escapeLogHtml(action)}
                </div>
                <div class="log-text">${escapeLogHtml(message)}</div>
              </div>
            </div>
          `;
        })
        .join('');
    };

    const loadSettingsLogs = async () => {
      if (!settingsLogList || !settingsLogStatus) return;
      settingsLogStatus.textContent = 'Loading...';
      try {
        const response = await fetch('/api/logs?limit=250');
        const payload = response.ok ? await response.json() : { items: [] };
        settingsLogs = Array.isArray(payload.items) ? payload.items : [];
        renderSettingsLogs();
        settingsLogStatus.textContent = new Date().toLocaleTimeString();
      } catch (err) {
        settingsLogStatus.textContent = 'Failed to load logs';
      }
    };

    const renderWidgetStatusDebug = (snapshot) => {
      if (!settingsWidgetStatusDebug) return;
      const payload = (snapshot && typeof snapshot === 'object') ? snapshot : {};
      const delaySeconds = Number(payload.delaySeconds);
      const effectiveDelaySeconds = Number.isFinite(delaySeconds) ? Math.max(5, Math.round(delaySeconds)) : 60;
      const trackedItems = Array.isArray(payload.items) ? payload.items : [];
      const pendingItems = trackedItems.filter((item) => String(item?.pendingState || '').trim());
      if (!payload.enabled) {
        const reason = !payload.appriseEnabled
          ? 'Apprise notifications are disabled'
          : (!payload.widgetStatusEnabled ? 'Widget status alerts are disabled' : 'Disabled');
        settingsWidgetStatusDebug.textContent = `Widget monitor: ${reason}.`;
        return;
      }
      if (!trackedItems.length) {
        settingsWidgetStatusDebug.textContent = 'Widget monitor: no widget apps are currently tracked.';
        return;
      }
      if (!pendingItems.length) {
        settingsWidgetStatusDebug.textContent = `Widget monitor: no pending transitions (${trackedItems.length} apps tracked).`;
        return;
      }
      const preview = pendingItems
        .slice(0, 4)
        .map((item) => {
          const appName = String(item?.appName || item?.appId || 'App').trim();
          const currentState = String(item?.currentState || 'unknown').trim().toLowerCase() || 'unknown';
          const pendingState = String(item?.pendingState || 'unknown').trim().toLowerCase() || 'unknown';
          const elapsedRaw = Number(item?.pendingElapsedSeconds);
          const elapsedSeconds = Number.isFinite(elapsedRaw) ? Math.max(0, Math.round(elapsedRaw)) : 0;
          const shownElapsed = Math.min(effectiveDelaySeconds, elapsedSeconds);
          return `${appName} ${currentState}->${pendingState} ${shownElapsed}/${effectiveDelaySeconds}s`;
        })
        .join(' | ');
      const extraCount = pendingItems.length > 4 ? ` (+${pendingItems.length - 4} more)` : '';
      settingsWidgetStatusDebug.textContent = `Widget monitor pending (${pendingItems.length}): ${preview}${extraCount}`;
    };

    const loadWidgetStatusDebug = async () => {
      if (!settingsWidgetStatusDebug) return;
      if (settingsLogPanel && !settingsLogPanel.classList.contains('is-active')) return;
      try {
        const response = await fetch('/api/widget-status-monitor');
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const payload = await response.json();
        renderWidgetStatusDebug(payload);
      } catch (_err) {
        settingsWidgetStatusDebug.textContent = 'Widget monitor: failed to load debug state.';
      }
    };

    settingsLogRefresh?.addEventListener('click', () => {
      loadSettingsLogs();
      loadWidgetStatusDebug();
    });
    settingsLogApp?.addEventListener('change', renderSettingsLogs);
    settingsLogLevel?.addEventListener('change', renderSettingsLogs);
    settingsLogTabBtn?.addEventListener('click', () => {
      setTimeout(loadWidgetStatusDebug, 0);
    });
    loadSettingsLogs();
    loadWidgetStatusDebug();
    setInterval(loadWidgetStatusDebug, 5000);
    } catch (err) {
      console.error('[Launcharr] Settings logs init failed', err);
    }

    try {
      const settingsAboutVersion = document.getElementById('settingsAboutVersion');
      const settingsAboutLatest = document.getElementById('settingsAboutLatest');
      const settingsAboutVersionState = document.getElementById('settingsAboutVersionState');
      const settingsAboutTimeZone = document.getElementById('settingsAboutTimeZone');
      const settingsReleaseModalBackdrop = document.getElementById('settingsReleaseModalBackdrop');
      const settingsReleaseModalTitle = document.getElementById('settingsReleaseModalTitle');
      const settingsReleaseModalSubtitle = document.getElementById('settingsReleaseModalSubtitle');
      const settingsReleaseModalSummary = document.getElementById('settingsReleaseModalSummary');
      const settingsReleaseModalList = document.getElementById('settingsReleaseModalList');
      const settingsReleaseModalLink = document.getElementById('settingsReleaseModalLink');
      const settingsReleaseOpenButtons = Array.from(document.querySelectorAll('.settings-release-open'));
      const releaseModalCloseButtons = settingsReleaseModalBackdrop
        ? Array.from(settingsReleaseModalBackdrop.querySelectorAll('.settings-release-modal-close, .plex-modal-close'))
        : [];
      const aboutReleaseEntriesRaw = <%- safeJson(aboutReleases || []) %>;
      const aboutReleaseEntries = Array.isArray(aboutReleaseEntriesRaw) ? aboutReleaseEntriesRaw : [];

      // Move the release modal backdrop out of the tab panel stacking context.
      if (settingsReleaseModalBackdrop && settingsReleaseModalBackdrop.parentElement !== document.body) {
        document.body.appendChild(settingsReleaseModalBackdrop);
      }

      const normalizeVersionTag = (value) => {
        const raw = String(value || '').trim();
        if (!raw) return '';
        return raw.startsWith('v') ? raw : `v${raw}`;
      };
      const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      }[char]));
      const parseHighlight = (value) => {
        const raw = String(value || '').trim();
        if (!raw) return null;
        const match = raw.match(/^([A-Za-z][A-Za-z\s]+):\s*(.+)$/);
        if (!match) return { section: 'Update', detail: raw };
        return {
          section: String(match[1] || '').trim() || 'Update',
          detail: String(match[2] || '').trim() || raw,
        };
      };
      const formatRelativeTime = (value) => {
        const date = value ? new Date(value) : null;
        if (!date || Number.isNaN(date.getTime())) return 'Recently';
        const seconds = Math.max(0, Math.floor((Date.now() - date.getTime()) / 1000));
        if (seconds < 60) return 'Just now';
        const minutes = Math.floor(seconds / 60);
        if (minutes < 60) return `${minutes} minute${minutes === 1 ? '' : 's'} ago`;
        const hours = Math.floor(minutes / 60);
        if (hours < 24) return `${hours} hour${hours === 1 ? '' : 's'} ago`;
        const days = Math.floor(hours / 24);
        if (days < 30) return `${days} day${days === 1 ? '' : 's'} ago`;
        const months = Math.floor(days / 30);
        if (months < 12) return `${months} month${months === 1 ? '' : 's'} ago`;
        const years = Math.floor(months / 12);
        return `${years} year${years === 1 ? '' : 's'} ago`;
      };
      const updateReleaseRelativeTimes = () => {
        document.querySelectorAll('[data-release-published-at]').forEach((node) => {
          const publishedAt = String(node.getAttribute('data-release-published-at') || '').trim();
          node.textContent = formatRelativeTime(publishedAt);
        });
      };
      const setVersionState = (text, tone = '') => {
        if (!settingsAboutVersionState) return;
        settingsAboutVersionState.textContent = String(text || '').trim();
        settingsAboutVersionState.classList.remove('settings-about-pill--ok', 'settings-about-pill--warn');
        if (tone === 'ok') settingsAboutVersionState.classList.add('settings-about-pill--ok');
        if (tone === 'warn') settingsAboutVersionState.classList.add('settings-about-pill--warn');
      };
      const closeReleaseModal = () => {
        if (!settingsReleaseModalBackdrop) return;
        settingsReleaseModalBackdrop.classList.add('plex-hidden');
        window.removeEventListener('keydown', onReleaseModalKeydown);
      };
      const onReleaseModalKeydown = (event) => {
        if (event.key === 'Escape') closeReleaseModal();
      };
      const openReleaseModal = (release) => {
        if (!settingsReleaseModalBackdrop || !release) return;
        const releaseTag = normalizeVersionTag(release.tag || 'Release');
        const subtitle = release.publishedAt
          ? `${formatRelativeTime(release.publishedAt)}`
          : 'Changelog summary';
        const highlights = (Array.isArray(release.highlights) ? release.highlights : [])
          .map(parseHighlight)
          .filter(Boolean)
          .slice(0, 3);
        const summary = String(release.summary || '').trim()
          || (highlights[0] ? highlights[0].detail : 'Release notes are available.');
        if (settingsReleaseModalTitle) settingsReleaseModalTitle.textContent = `Release ${releaseTag}`;
        if (settingsReleaseModalSubtitle) settingsReleaseModalSubtitle.textContent = subtitle;
        if (settingsReleaseModalSummary) settingsReleaseModalSummary.textContent = summary;
        if (settingsReleaseModalList) {
          settingsReleaseModalList.innerHTML = highlights.length
            ? highlights.map((item) => (
              '<li class="settings-release-modal-item">' +
                `<span class="settings-release-modal-tag">${escapeHtml(item.section)}</span>` +
                `<span class="settings-release-modal-text">${escapeHtml(item.detail)}</span>` +
              '</li>'
            )).join('')
            : '<li class="settings-release-modal-item"><span class="settings-release-modal-text">No highlight entries were found for this release.</span></li>';
        }
        if (settingsReleaseModalLink) {
          settingsReleaseModalLink.href = String(release.releaseNotesUrl || '#').trim() || '#';
        }
        settingsReleaseModalBackdrop.classList.remove('plex-hidden');
        window.addEventListener('keydown', onReleaseModalKeydown);
      };

      settingsReleaseOpenButtons.forEach((button) => {
