                    <input class="theme-chip-picker" id="customThemeColor" type="color" value="#1cc6c2" aria-label="Choose custom theme color" />
                  </span>
                  <span class="theme-preset-name">Custom</span>
                  <span class="theme-preset-meta">Color wheel</span>
                </button>
